</DefaultData>
<DefaultData Format="Decorated">
<DataValue DataType="BOOL" Radix="Decimal" Value="0"/>
</DefaultData>
</Parameter>
<Parameter Name="stop_pump_one_shot" TagType="Base" DataType="BOOL" Usage="Input" Radix="Decimal" Required="true" Visible="true" ExternalAccess="Read/Write">
<DefaultData Format="L5K">
<![CDATA[0]]>
</DefaultData>
<DefaultData Format="Decorated">
<DataValue DataType="BOOL" Radix="Decimal" Value="0"/>
</DefaultData>
</Parameter>
<Parameter Name="stop_dilution_one_shot" TagType="Base" DataType="BOOL" Usage="Input" Radix="Decimal" Required="true" Visible="true" ExternalAccess="Read/Write">
<DefaultData Format="L5K">
<![CDATA[0]]>
</DefaultData>
<DefaultData Format="Decorated">
<DataValue DataType="BOOL" Radix="Decimal" Value="0"/>
</DefaultData>
</Parameter>
<Parameter Name="high_level_stop" TagType="Base" DataType="REAL" Usage="Output" Radix="Float" Required="false" Visible="false" ExternalAccess="Read/Write">
<DefaultData Format="L5K">
<![CDATA[0.00000000e+000]]>
</DefaultData>
<DefaultData Format="Decorated">
<DataValue DataType="REAL" Radix="Float" Value="0.0"/>
</DefaultData>
</Parameter>
<Parameter Name="high_level_stop_alarm" TagType="Base" DataType="BOOL" Usage="Output" Radix="Decimal" Required="false" Visible="false" ExternalAccess="Read/Write">
<DefaultData Format="L5K">
<![CDATA[0]]>
</DefaultData>
<DefaultData Format="Decorated">
<DataValue DataType="BOOL" Radix="Decimal" Value="0"/>
</DefaultData>
</Parameter>
<Parameter Name="high_level_stop_alarm_one_shot" TagType="Base" DataType="BOOL" Usage="Input" Radix="Decimal" Required="false" Visible="false" ExternalAccess="Read/Write">
<DefaultData Format="L5K">
<![CDATA[0]]>
</DefaultData>
<DefaultData Format="Decorated">
<DataValue DataType="BOOL" Radix="Decimal" Value="0"/>
</DefaultData>
</Parameter>
</Parameters>
<LocalTags/>
<Routines>
<Routine Name="Logic" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[开始稀释]]>
</Comment>
<Text>
<![CDATA[XIC(start_dilution)ONS(start_dilution_one_shot)[OTL(dilution_status_0) ,OTL(dilution_status_1) ,OTU(dilution_status_7) ,MOV(tank_level,start_dilution_level) MOV(0,dilution_middle_level) MOV(0,dilution_target) ];]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[关闭出液阀及其他阀，做好稀释准备，然后开始进浓液]]>
</Comment>
<Text>
<![CDATA[XIC(water_in_vavle)XIC(chemical_out_valve)XIC(chemical_in_valve)XIC(drain_valve)XIC(dilution_status_1)OTL(dilution_status_2);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[进浓液，直至达停卸药泵。]]>
</Comment>
<Text>
<![CDATA[XIC(water_in_vavle)XIC(chemical_out_valve)XIC(drain_valve)XIC(dilution_status_1)XIC(dilution_status_2)XIC(stop_pump)ONS(stop_pump_one_shot)[OTL(dilution_status_3) ,MOV(tank_level,dilution_middle_level) ];]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Text>
<![CDATA[XIC(dilution_status_3)CPT(dilution_target,(dilution_middle_level-start_dilution_level)*(1+dilution_factor)/dilution_factor+start_dilution_level);]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Comment>
<![CDATA[关浓液进液阀]]>
</Comment>
<Text>
<![CDATA[XIC(chemical_out_valve)XIC(chemical_in_valve)XIC(drain_valve)XIC(dilution_status_1)XIC(dilution_status_2)XIC(dilution_status_3)OTL(dilution_status_4);]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Comment>
<![CDATA[进稀释水直至到达稀释目标液位]]>
</Comment>
<Text>
<![CDATA[XIC(chemical_out_valve)XIC(chemical_in_valve)XIC(drain_valve)XIC(dilution_status_1)XIC(dilution_status_2)XIC(dilution_status_3)XIC(dilution_status_4)GEQ(tank_level,dilution_target)OTL(dilution_status_5);]]>
</Text>
</Rung>
<Rung Number="6" Type="N">
<Comment>
<![CDATA[关稀释水阀，停止进稀释水]]>
</Comment>
<Text>
<![CDATA[XIC(water_in_vavle)XIC(chemical_out_valve)XIC(chemical_in_valve)XIC(drain_valve)XIC(dilution_status_1)XIC(dilution_status_2)XIC(dilution_status_3)XIC(dilution_status_4)XIC(dilution_status_5)OTL(dilution_status_6);]]>
</Text>
</Rung>
<Rung Number="7" Type="N">
<Comment>
<![CDATA[储罐静置等待混合均匀]]>
</Comment>
<Text>
<![CDATA[XIC(water_in_vavle)XIC(chemical_out_valve)XIC(chemical_in_valve)XIC(drain_valve)XIC(dilution_status_1)XIC(dilution_status_2)XIC(dilution_status_3)XIC(dilution_status_4)XIC(dilution_status_5)XIC(dilution_status_6)TON(timer,?,?);]]>
</Text>
</Rung>
<Rung Number="8" Type="N">
<Text>
<![CDATA[XIC(timer.DN)[OTL(dilution_status_7) ,OTU(dilution_status_0) ,OTU(dilution_status_1) ,OTU(dilution_status_2) ,OTU(dilution_status_3) ,OTU(dilution_status_4) ,OTU(dilution_status_5) ,OTU(dilution_status_6) ];]]>
</Text>
</Rung>
<Rung Number="9" Type="N">
<Text>
<![CDATA[[XIC(stop_dilution) ONS(stop_dilution_one_shot) ,LEQ(dilution_factor,0) ][OTU(dilution_status_7) ,OTU(dilution_status_0) ,OTU(dilution_status_1) ,OTU(dilution_status_2) ,OTU(dilution_status_3) ,OTU(dilution_status_4) ,OTU(dilution_status_5) ,OTU(dilution_status_6) ];]]>
</Text>
</Rung>
<Rung Number="10" Type="N">
<Comment>
<![CDATA[当浓液进液液位，按照当前稀释参数，稀释之后的液位可能高于高报警液位时，要停止进浓液并开始稀释。]]>
</Comment>
<Text>
<![CDATA[CPT(high_level_stop,(high_level_alarm_setting-start_dilution_level)*dilution_factor/(1+dilution_factor)+start_dilution_level)GEQ(tank_level,high_level_stop)XIO(dilution_status_3)OTE(high_level_stop_alarm);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
</Routines>
</AddOnInstructionDefinition>
<AddOnInstructionDefinition Name="NaOH_dosing_flow_calculate" Revision="1.0" ExecutePrescan="false" ExecutePostscan="false" ExecuteEnableInFalse="false" CreatedDate="2024-03-23T05:33:55.581Z" CreatedBy="DESKTOP-EB2DFQ8\wymwym" EditedDate="2024-09-02T13:25:03.039Z" EditedBy="PC-XINGUANG\wymwym" SoftwareRevision="v34.00">
<Description>
<![CDATA[计算NaOH理论投加量]]>
</Description>
<Parameters>
<Parameter Name="EnableIn" TagType="Base" DataType="BOOL" Usage="Input" Radix="Decimal" Required="false" Visible="false" ExternalAccess="Read Only">
<Description>
<![CDATA[Enable Input - System Defined Parameter]]>
</Description>
</Parameter>
<Parameter Name="EnableOut" TagType="Base" DataType="BOOL" Usage="Output" Radix="Decimal" Required="false" Visible="false" ExternalAccess="Read Only">
<Description>
<![CDATA[Enable Output - System Defined Parameter]]>
</Description>
</Parameter>
<Parameter Name="concentration" TagType="Base" DataType="REAL" Usage="Input" Radix="Float" Required="true" Visible="true" ExternalAccess="Read/Write">
<Description>
<![CDATA[0-100%]]>
</Description>
<DefaultData Format="L5K">
<![CDATA[0.00000000e+000]]>
</DefaultData>
<DefaultData Format="Decorated">
<DataValue DataType="REAL" Radix="Float" Value="0.0"/>
</DefaultData>
</Parameter>
<Parameter Name="dosing_rate_mg_L" TagType="Base" DataType="REAL" Usage="Input" Radix="Float" Required="true" Visible="true" ExternalAccess="Read/Write">
<Description>
<![CDATA[mg/L]]>
</Description>
<DefaultData Format="L5K">
<![CDATA[0.00000000e+000]]>
</DefaultData>
<DefaultData Format="Decorated">
<DataValue DataType="REAL" Radix="Float" Value="0.0"/>
</DefaultData>
</Parameter>
<Parameter Name="flow_setting" TagType="Base" DataType="REAL" Usage="Output" Radix="Float" Required="true" Visible="true" ExternalAccess="Read/Write">
<DefaultData Format="L5K">
<![CDATA[0.00000000e+000]]>
</DefaultData>
<DefaultData Format="Decorated">
<DataValue DataType="REAL" Radix="Float" Value="0.0"/>
</DefaultData>
</Parameter>
<Parameter Name="source_water_flow" TagType="Base" DataType="REAL" Usage="Input" Radix="Float" Required="true" Visible="true" ExternalAccess="Read/Write">
<DefaultData Format="L5K">
<![CDATA[0.00000000e+000]]>
</DefaultData>
<DefaultData Format="Decorated">
<DataValue DataType="REAL" Radix="Float" Value="0.0"/>
</DefaultData>
</Parameter>
</Parameters>
<LocalTags/>
<Routines>
<Routine Name="Logic" Type="ST">
<Description>
<![CDATA[计算NaOH理论投加量]]>
</Description>
<STContent>
<Line Number="0">
<![CDATA[ (*自动控制时，投加流量由计算公式确定*)]]>
</Line>
<Line Number="1">
<![CDATA[    (*计算公式：*)]]>
</Line>
<Line Number="2">
<![CDATA[    (*1m3=1000L;1mg=1/(1000*1000)kg*)]]>
</Line>
<Line Number="3">
<![CDATA[    (*纯物质投加量(kg/h)=源水流量(m3/h)*1000*溶液投率(mg/L)/(1000*1000)=源水流量(m3/h)*溶液投率(mg/L)/1000*)]]>
</Line>
<Line Number="4">
<![CDATA[    (*纯物质投加量(kg/h)=投加流量(L/h)*溶液浓度%*)]]>
</Line>
<Line Number="5">
<![CDATA[    (*投加流量(L/h)=纯物质投加量(kg/h)/溶液浓度%=源水流量(m3/h)*溶液投率(mg/L)/1000/溶液浓度%*)]]>
</Line>
<Line Number="6">
<![CDATA[    flow_setting := source_water_flow * dosing_rate_mg_L / 1000.0 / concentration; ]]>
</Line>
</STContent>
</Routine>
</Routines>
</AddOnInstructionDefinition>
