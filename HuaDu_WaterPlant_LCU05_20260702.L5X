<Line Number="469">
<![CDATA[(*将读取的压力数值转变为重量*)]]>
</Line>
<Line Number="470">
<![CDATA[(*计算公式：m(kg)=p*S/g=p*pi*(d/2)^2/g*)]]>
</Line>
<Line Number="471">
<![CDATA[(*1000Pa*3.14*(3.5/2)^2/9.8/1000，单位:吨*)]]>
</Line>
<Line Number="472">
<![CDATA[(*g=9.8m/s^2,pi=3.14,压力变送器测量范围0-240kPa*)]]>
</Line>
<Line Number="473">
<![CDATA[NaClO_weight_8PT05:=(NaClO_tank_pressure_1*3.14*(3.5/2)**2/9.8);]]>
</Line>
<Line Number="474">
<![CDATA[NaClO_weight_8PT06:=(NaClO_tank_pressure_2*3.14*(3.5/2)**2/9.8);]]>
</Line>
<Line Number="475">
<![CDATA[NaClO_weight_8PT07:=(NaClO_tank_pressure_3*3.14*(3.5/2)**2/9.8);]]>
</Line>
<Line Number="476">
<![CDATA[NaClO_weight_8PT08:=(NaClO_tank_pressure_4*3.14*(3.5/2)**2/9.8);]]>
</Line>
<Line Number="477">
<![CDATA[NaClO_weight_8PT09:=(NaClO_tank_pressure_5*3.14*(3.5/2)**2/9.8);]]>
</Line>
<Line Number="478">
<![CDATA[NaClO_weight_8PT10:=(NaClO_tank_pressure_6*3.14*(3.5/2)**2/9.8);]]>
</Line>
<Line Number="479">
<![CDATA[NaClO_weight_8PT11:=(NaClO_tank_pressure_7*3.14*(3.5/2)**2/9.8);]]>
</Line>
<Line Number="480">
<![CDATA[NaClO_weight_8PT12:=(NaClO_tank_pressure_8*3.14*(3.5/2)**2/9.8);]]>
</Line>
