<Routine Name="valve_action_NaClO" Type="ST">
<Description>
<![CDATA[阀门动作的控制分为分类：
1、普通电动阀可以自由动作；
2、泵出口阀需要与泵联动；
3、储罐进出口阀与储罐液位联动。]]>
</Description>
<STContent>
<Line Number="0">
<![CDATA[(*阀门动作的控制分为分类：*)]]>
</Line>
<Line Number="1">
<![CDATA[    (*1、普通电动阀可以自由动作；*)]]>
</Line>
<Line Number="2">
<![CDATA[    (*2、泵出口阀需要与泵联动；*)]]>
</Line>
<Line Number="3">
<![CDATA[    (*3、储罐进出口阀与储罐液位联动。*)]]>
</Line>
<Line Number="4">
<![CDATA[]]>
</Line>
<Line Number="5">
<![CDATA[(*罐体稀释水进水电动阀*)]]>
</Line>
<Line Number="6">
<![CDATA[(*储罐作为冷备时阀门关闭*)]]>
</Line>
<Line Number="7">
<![CDATA[(*1号罐*)]]>
</Line>
<Line Number="8">
<![CDATA[if NaClO_level_high_alarm_1 or NaClO_tank_standby[1] then]]>
</Line>
<Line Number="9">
<![CDATA[    RemoteIO3:4:O.Data.4:=0;]]>
</Line>
<Line Number="10">
<![CDATA[else]]>
</Line>
<Line Number="11">
<![CDATA[	if NaClO_tank_auto_manual[1] then]]>
</Line>
<Line Number="12">
<![CDATA[		if NaClO_dilution_status_tank_1[4] then]]>
</Line>
<Line Number="13">
<![CDATA[			if NaClO_dilution_status_tank_1[5] then]]>
</Line>
<Line Number="14">
<![CDATA[				RemoteIO3:4:O.Data.4:=0;]]>
</Line>
<Line Number="15">
<![CDATA[			else]]>
</Line>
<Line Number="16">
<![CDATA[				RemoteIO3:4:O.Data.4:=1;]]>
</Line>
<Line Number="17">
<![CDATA[			end_if;]]>
</Line>
<Line Number="18">
<![CDATA[		else]]>
</Line>
<Line Number="19">
<![CDATA[			RemoteIO3:4:O.Data.4:=0;]]>
</Line>
<Line Number="20">
<![CDATA[		end_if;]]>
</Line>
<Line Number="21">
<![CDATA[	else]]>
</Line>
<Line Number="22">
<![CDATA[    	RemoteIO3:4:O.Data.4:=VE_NaClO_27_actuate;]]>
</Line>
<Line Number="23">
<![CDATA[	end_if;]]>
</Line>
<Line Number="24">
<![CDATA[end_if;]]>
</Line>
<Line Number="25">
<![CDATA[]]>
</Line>
<Line Number="26">
<![CDATA[(*2号罐*)]]>
</Line>
<Line Number="27">
<![CDATA[if NaClO_level_high_alarm_2 or NaClO_tank_standby[2] then]]>
</Line>
<Line Number="28">
<![CDATA[    RemoteIO3:4:O.Data.5:=0;]]>
</Line>
<Line Number="29">
<![CDATA[else]]>
</Line>
<Line Number="30">
<![CDATA[	if NaClO_tank_auto_manual[2] then]]>
</Line>
<Line Number="31">
<![CDATA[		if NaClO_dilution_status_tank_2[4] then]]>
</Line>
<Line Number="32">
<![CDATA[			if NaClO_dilution_status_tank_2[5] then]]>
</Line>
<Line Number="33">
<![CDATA[				RemoteIO3:4:O.Data.5:=0;]]>
</Line>
<Line Number="34">
<![CDATA[			else]]>
</Line>
<Line Number="35">
<![CDATA[				RemoteIO3:4:O.Data.5:=1;]]>
</Line>
<Line Number="36">
<![CDATA[			end_if;]]>
</Line>
<Line Number="37">
<![CDATA[		else]]>
</Line>
<Line Number="38">
<![CDATA[			RemoteIO3:4:O.Data.5:=0;]]>
</Line>
<Line Number="39">
<![CDATA[		end_if;]]>
</Line>
<Line Number="40">
<![CDATA[	else]]>
</Line>
<Line Number="41">
<![CDATA[        RemoteIO3:4:O.Data.5:=VE_NaClO_28_actuate;]]>
</Line>
<Line Number="42">
<![CDATA[	end_if;]]>
</Line>
<Line Number="43">
<![CDATA[end_if;]]>
</Line>
<Line Number="44">
<![CDATA[]]>
</Line>
<Line Number="45">
<![CDATA[(*3号罐*)]]>
</Line>
<Line Number="46">
<![CDATA[if NaClO_level_high_alarm_3 or NaClO_tank_standby[3] then]]>
</Line>
<Line Number="47">
<![CDATA[    RemoteIO3:4:O.Data.6:=0;]]>
</Line>
<Line Number="48">
<![CDATA[else]]>
</Line>
<Line Number="49">
<![CDATA[	if NaClO_tank_auto_manual[3] then]]>
</Line>
<Line Number="50">
<![CDATA[		if NaClO_dilution_status_tank_3[4] then]]>
</Line>
<Line Number="51">
<![CDATA[			if NaClO_dilution_status_tank_3[5] then]]>
</Line>
<Line Number="52">
<![CDATA[				RemoteIO3:4:O.Data.6:=0;]]>
</Line>
<Line Number="53">
<![CDATA[			else]]>
</Line>
<Line Number="54">
<![CDATA[				RemoteIO3:4:O.Data.6:=1;]]>
</Line>
<Line Number="55">
<![CDATA[			end_if;]]>
</Line>
<Line Number="56">
<![CDATA[		else]]>
</Line>
<Line Number="57">
<![CDATA[			RemoteIO3:4:O.Data.6:=0;]]>
</Line>
<Line Number="58">
<![CDATA[		end_if;]]>
</Line>
<Line Number="59">
<![CDATA[	else]]>
</Line>
<Line Number="60">
<![CDATA[        RemoteIO3:4:O.Data.6:=VE_NaClO_29_actuate;]]>
</Line>
<Line Number="61">
<![CDATA[	end_if;]]>
</Line>
<Line Number="62">
<![CDATA[end_if;]]>
</Line>
<Line Number="63">
<![CDATA[]]>
</Line>
<Line Number="64">
<![CDATA[(*4号罐*)]]>
</Line>
<Line Number="65">
<![CDATA[if NaClO_level_high_alarm_4 or NaClO_tank_standby[4] then]]>
</Line>
<Line Number="66">
<![CDATA[    RemoteIO3:4:O.Data.7:=0;]]>
</Line>
<Line Number="67">
<![CDATA[else]]>
</Line>
<Line Number="68">
<![CDATA[	if NaClO_tank_auto_manual[4] then]]>
