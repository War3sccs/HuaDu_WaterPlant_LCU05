</Line>
<Line Number="168">
<![CDATA[SCL_concentration_AI_3.InRawMin:=0;]]>
</Line>
<Line Number="169">
<![CDATA[]]>
</Line>
<Line Number="170">
<![CDATA[SCL_concentration_AI_4.InEUMax:=38.0;]]>
</Line>
<Line Number="171">
<![CDATA[SCL_concentration_AI_4.InEUMin:=0.0;]]>
</Line>
<Line Number="172">
<![CDATA[SCL_concentration_AI_4.InRawMax:=30840;]]>
