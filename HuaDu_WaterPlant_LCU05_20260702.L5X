</Comment>
<Text>
<![CDATA[SUB(CL_Out_SediT_D2,Cl_out_sediment_average_temporary,Cl_out_sediment_deviation[8])ABS(Cl_out_sediment_deviation[8],Cl_out_sediment_deviation[8])DIV(Cl_out_sediment_deviation[8],Cl_out_sediment_average_temporary,Cl_out_sediment_deviation_rate[8])GRT(Cl_out_sediment_deviation_rate[8],0.3)OTE(Cl_out_sediment_deviation_alarm[8]);]]>
</Text>
</Rung>
<Rung Number="32" Type="N">
<Comment>
<![CDATA[统计示数与4个仪表均值偏差值在30%以内的仪表数量]]>
</Comment>
<Text>
<![CDATA[[XIC(Cl_out_sediment_deviation_alarm[1]) MOV(0,Cl_OK_count[1]) ,XIO(Cl_out_sediment_deviation_alarm[1]) MOV(1,Cl_OK_count[1]) ,XIC(Cl_out_sediment_deviation_alarm[2]) MOV(0,Cl_OK_count[2]) ,XIO(Cl_out_sediment_deviation_alarm[2]) MOV(1,Cl_OK_count[2]) ,XIC(Cl_out_sediment_deviation_alarm[3]) MOV(0,Cl_OK_count[3]) ,XIO(Cl_out_sediment_deviation_alarm[3]) MOV(1,Cl_OK_count[3]) ,XIC(Cl_out_sediment_deviation_alarm[4]) MOV(0,Cl_OK_count[4]) ,XIO(Cl_out_sediment_deviation_alarm[4]) MOV(1,Cl_OK_count[4]) ,XIC(Cl_out_sediment_deviation_alarm[5]) MOV(0,Cl_OK_count[5]) ,XIO(Cl_out_sediment_deviation_alarm[5]) MOV(1,Cl_OK_count[5]) ,XIC(Cl_out_sediment_deviation_alarm[6]) MOV(0,Cl_OK_count[6]) ,XIO(Cl_out_sediment_deviation_alarm[6]) MOV(1,Cl_OK_count[6]) ,XIC(Cl_out_sediment_deviation_alarm[7]) MOV(0,Cl_OK_count[7]) ,XIO(Cl_out_sediment_deviation_alarm[7]) MOV(1,Cl_OK_count[7]) ,XIC(Cl_out_sediment_deviation_alarm[8]) MOV(0,Cl_OK_count[8]) ,XIO(Cl_out_sediment_deviation_alarm[8]) MOV(1,Cl_OK_count[8]) ];]]>
</Text>
</Rung>
<Rung Number="33" Type="N">
<Comment>
<![CDATA[统计示数与4个仪表均值偏差值在30%以内的仪表总数]]>
</Comment>
<Text>
<![CDATA[CPT(Cl_OK_count[0],Cl_OK_count[1]+Cl_OK_count[2]+Cl_OK_count[3]+Cl_OK_count[4]+Cl_OK_count[5]+Cl_OK_count[6]+Cl_OK_count[7]+Cl_OK_count[8]);]]>
</Text>
</Rung>
<Rung Number="34" Type="N">
<Comment>
<![CDATA[计算示数与4个仪表均值偏差值在30%以内的仪表示数均值]]>
</Comment>
<Text>
<![CDATA[CPT(Cl_out_sediment,(Cl_OK_count[1]*CL_Out_SediT_A1+Cl_OK_count[2]*CL_Out_SediT_A2+Cl_OK_count[3]*CL_Out_SediT_B1+Cl_OK_count[4]*CL_Out_SediT_B2+Cl_OK_count[5]*CL_Out_SediT_C1+Cl_OK_count[6]*CL_Out_SediT_C2+Cl_OK_count[7]*CL_Out_SediT_D1+Cl_OK_count[8]*CL_Out_SediT_D2)/Cl_OK_count[0]);]]>
</Text>
</Rung>
<Rung Number="35" Type="N">
<Comment>
<![CDATA[计算后加氯自动投加时的氯耗，公式如下：
（计算目标值-待滤水余氯）/投加次氯酸钠溶液理论浓度]]>
</Comment>
<Text>
<![CDATA[CPT(YaoHao_filtration_out_setting_NaClO,(Cl_target_value-Cl_out_sediment)/(NaClO_concentration/100));]]>
</Text>
</Rung>
<Rung Number="36" Type="N">
<Comment>
<![CDATA[控制方式为自动时，设置4号泵组（投加到滤池出水总管）数字泵投加流量。
备注：
目前仅参考A/B沉淀池（一标）水量，等C/D沉淀池（二标）完成建设，再同时参考二标的水量。]]>
</Comment>
<Text>
<![CDATA[XIC(NaClO_control_auto_manual[4])[TON(NaClO_compare_time[3],?,?) ,XIC(NaClO_compare_time[3].DN) [CPT(P_NaClO7_flow_set,YaoHao_filtration_out_setting_NaClO*flow_current_total_dam*10.0/(NaClO_density*NaClO_concentration)) ,CPT(P_NaClO8_flow_set,YaoHao_filtration_out_setting_NaClO*flow_current_total_dam*10.0/(NaClO_density*NaClO_concentration)) ] ];]]>
</Text>
</Rung>
<Rung Number="37" Type="N">
<Comment>
<![CDATA[控制方式为手动时，其中1台数字泵故障时，流量切换]]>
</Comment>
<Text>
<![CDATA[XIO(NaClO_control_auto_manual[4])[XIC(P_NaClO7_err) XIC(P_NaClO7_actuate) XIO(P_NaClO8_err) [MOV(P_NaClO7_flow_set,P_NaClO8_flow_set) ,MOV(P_NaClO7_flow_set,P_NaClO_flow_set_local[8]) ] ,XIC(P_NaClO8_err) XIC(P_NaClO8_actuate) XIO(P_NaClO7_err) [MOV(P_NaClO8_flow_set,P_NaClO7_flow_set) ,MOV(P_NaClO8_flow_set,P_NaClO_flow_set_local[7]) ] ];]]>
</Text>
</Rung>
<Rung Number="38" Type="N">
<Comment>
<![CDATA[控制方式为自动时，设置5号泵组（投加到清水池出水总管）数字泵投加流量。]]>
</Comment>
<Text>
<![CDATA[XIC(NaClO_control_auto_manual[5])[TON(NaClO_compare_time[4],?,?) ,XIC(NaClO_compare_time[4].DN) [CPT(P_NaClO9_flow_set,(YaoHao_clean_water_setting_NaClO*flow_current_total_dam*10.0)/(NaClO_density*NaClO_concentration)) ,CPT(P_NaClO10_flow_set,(YaoHao_clean_water_setting_NaClO*flow_current_total_dam*10.0)/(NaClO_density*NaClO_concentration)) ] ];]]>
</Text>
</Rung>
<Rung Number="39" Type="N">
<Comment>
<![CDATA[控制方式为手动时，其中1台数字泵故障时，流量切换]]>
</Comment>
<Text>
<![CDATA[XIO(NaClO_control_auto_manual[5])[XIC(P_NaClO9_err) XIC(P_NaClO9_actuate) XIO(P_NaClO10_err) [MOV(P_NaClO9_flow_set,P_NaClO10_flow_set) ,MOV(P_NaClO9_flow_set,P_NaClO_flow_set_local[10]) ] ,XIC(P_NaClO10_err) XIC(P_NaClO10_actuate) XIO(P_NaClO9_err) [MOV(P_NaClO10_flow_set,P_NaClO9_flow_set) ,MOV(P_NaClO10_flow_set,P_NaClO_flow_set_local[9]) ] ];]]>
</Text>
</Rung>
<Rung Number="40" Type="N">
<Comment>
<![CDATA[将计算得出的数字泵流量设置值传送到AO模块]]>
</Comment>
<Text>
<![CDATA[MOV(SCL_LP400_AO_1.Out,RemoteIO4:0:O.Ch0Data)MOV(SCL_LP400_AO_2.Out,RemoteIO4:0:O.Ch1Data)MOV(SCL_LP400_AO_3.Out,RemoteIO4:0:O.Ch2Data)MOV(SCL_LP400_AO_4.Out,RemoteIO4:0:O.Ch3Data)MOV(SCL_LP400_AO_5.Out,RemoteIO4:0:O.Ch4Data)MOV(SCL_LP400_AO_6.Out,RemoteIO4:0:O.Ch5Data)MOV(SCL_LP1010_AO_7.Out,RemoteIO4:0:O.Ch6Data)MOV(SCL_LP1010_AO_8.Out,RemoteIO4:0:O.Ch7Data)MOV(SCL_LP1010_AO_9.Out,RemoteIO4:0:O.Ch8Data)MOV(SCL_LP1010_AO_10.Out,RemoteIO4:0:O.Ch9Data);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
</Routines>
