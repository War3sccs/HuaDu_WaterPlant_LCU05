<Routine Name="analog_IO_setting_KMnO4" Type="ST">
<Description>
<![CDATA[设备4-20mA输入输出参数。]]>
</Description>
<STContent>
<Line Number="0">
<![CDATA[(*4-20mA输入输出参数设置*)]]>
</Line>
<Line Number="1">
<![CDATA[(*通过内置函数SCL配置输入输出4-20mA数值*)]]>
</Line>
<Line Number="2">
<![CDATA[(*模拟量输出范围:4-20mA*)]]>
</Line>
<Line Number="3">
<![CDATA[]]>
</Line>
<Line Number="4">
<![CDATA[(*数字泵反馈流量*)]]>
</Line>
<Line Number="5">
<![CDATA[(*4-20mA读入参数设置*)]]>
</Line>
<Line Number="6">
<![CDATA[(*通过内置函数SCL读取4-20mA数值*)]]>
</Line>
<Line Number="7">
<![CDATA[(*数字泵流量范围0-1020L/h*)]]>
</Line>
<Line Number="8">
<![CDATA[(*4-20mA输入范围对应是0-30480*)]]>
</Line>
<Line Number="9">
<![CDATA[SCL_LP1010_AI_13.InEUMax:=1020.0;]]>
</Line>
<Line Number="10">
<![CDATA[SCL_LP1010_AI_13.InEUMin:=0.0;]]>
</Line>
<Line Number="11">
<![CDATA[SCL_LP1010_AI_13.InRawMax:=30840;]]>
</Line>
<Line Number="12">
<![CDATA[SCL_LP1010_AI_13.InRawMin:=0;]]>
</Line>
<Line Number="13">
<![CDATA[]]>
</Line>
<Line Number="14">
<![CDATA[SCL_LP1010_AI_14.InEUMax:=1020.0;]]>
</Line>
<Line Number="15">
<![CDATA[SCL_LP1010_AI_14.InEUMin:=0.0;]]>
</Line>
<Line Number="16">
<![CDATA[SCL_LP1010_AI_14.InRawMax:=30840;]]>
</Line>
<Line Number="17">
<![CDATA[SCL_LP1010_AI_14.InRawMin:=0;]]>
</Line>
<Line Number="18">
<![CDATA[]]>
</Line>
<Line Number="19">
<![CDATA[SCL_LP1010_AI_15.InEUMax:=1020.0;]]>
</Line>
<Line Number="20">
<![CDATA[SCL_LP1010_AI_15.InEUMin:=0.0;]]>
</Line>
<Line Number="21">
<![CDATA[SCL_LP1010_AI_15.InRawMax:=30840;]]>
</Line>
<Line Number="22">
<![CDATA[SCL_LP1010_AI_15.InRawMin:=0;]]>
</Line>
<Line Number="23">
<![CDATA[]]>
</Line>
<Line Number="24">
<![CDATA[SCL_LP1010_AI_16.InEUMax:=1020.0;]]>
</Line>
<Line Number="25">
<![CDATA[SCL_LP1010_AI_16.InEUMin:=0.0;]]>
</Line>
<Line Number="26">
<![CDATA[SCL_LP1010_AI_16.InRawMax:=30840;]]>
</Line>
<Line Number="27">
<![CDATA[SCL_LP1010_AI_16.InRawMin:=0;]]>
</Line>
<Line Number="28">
<![CDATA[]]>
</Line>
<Line Number="29">
<![CDATA[SCL_LP1010_AI_17.InEUMax:=1020.0;]]>
</Line>
<Line Number="30">
<![CDATA[SCL_LP1010_AI_17.InEUMin:=0.0;]]>
</Line>
<Line Number="31">
<![CDATA[SCL_LP1010_AI_17.InRawMax:=30840;]]>
</Line>
<Line Number="32">
<![CDATA[SCL_LP1010_AI_17.InRawMin:=0;]]>
</Line>
<Line Number="33">
<![CDATA[]]>
</Line>
<Line Number="34">
<![CDATA[SCL_LP1010_AI_18.InEUMax:=1020.0;]]>
</Line>
<Line Number="35">
<![CDATA[SCL_LP1010_AI_18.InEUMin:=0.0;]]>
</Line>
<Line Number="36">
<![CDATA[SCL_LP1010_AI_18.InRawMax:=30840;]]>
</Line>
<Line Number="37">
<![CDATA[SCL_LP1010_AI_18.InRawMin:=0;]]>
</Line>
<Line Number="38">
<![CDATA[]]>
</Line>
<Line Number="39">
<![CDATA[(*将计算流量，传至AO模块，4-20mA输出*)]]>
</Line>
<Line Number="40">
<![CDATA[(*模拟量输出范围:4-20mA*)]]>
</Line>
<Line Number="41">
<![CDATA[(*数字泵流量范围:0.0-1020.0L/h*)]]>
</Line>
<Line Number="42">
<![CDATA[(*AO模块数值范围:0-30480*)]]>
</Line>
<Line Number="43">
<![CDATA[SCL_LP1010_AO_13.InEUMax:=30840;]]>
</Line>
<Line Number="44">
<![CDATA[SCL_LP1010_AO_13.InEUMin:=0.0;]]>
</Line>
<Line Number="45">
<![CDATA[SCL_LP1010_AO_13.InRawMax:=1020;]]>
</Line>
<Line Number="46">
<![CDATA[SCL_LP1010_AO_13.InRawMin:=0;]]>
</Line>
<Line Number="47">
<![CDATA[]]>
</Line>
<Line Number="48">
<![CDATA[SCL_LP1010_AO_14.InEUMax:=30840;]]>
</Line>
<Line Number="49">
<![CDATA[SCL_LP1010_AO_14.InEUMin:=0.0;]]>
</Line>
<Line Number="50">
<![CDATA[SCL_LP1010_AO_14.InRawMax:=1020;]]>
</Line>
<Line Number="51">
<![CDATA[SCL_LP1010_AO_14.InRawMin:=0;]]>
</Line>
<Line Number="52">
<![CDATA[]]>
</Line>
<Line Number="53">
<![CDATA[SCL_LP1010_AO_15.InEUMax:=30840;]]>
</Line>
<Line Number="54">
<![CDATA[SCL_LP1010_AO_15.InEUMin:=0.0;]]>
</Line>
<Line Number="55">
<![CDATA[SCL_LP1010_AO_15.InRawMax:=1020;]]>
</Line>
<Line Number="56">
<![CDATA[SCL_LP1010_AO_15.InRawMin:=0;]]>
</Line>
<Line Number="57">
<![CDATA[]]>
</Line>
<Line Number="58">
<![CDATA[SCL_LP1010_AO_16.InEUMax:=30840;]]>
</Line>
<Line Number="59">
<![CDATA[SCL_LP1010_AO_16.InEUMin:=0.0;]]>
</Line>
<Line Number="60">
<![CDATA[SCL_LP1010_AO_16.InRawMax:=1020;]]>
</Line>
<Line Number="61">
<![CDATA[SCL_LP1010_AO_16.InRawMin:=0;]]>
</Line>
<Line Number="62">
<![CDATA[]]>
</Line>
<Line Number="63">
<![CDATA[(*锰检测仪反馈信号*)]]>
</Line>
<Line Number="64">
<![CDATA[(*反馈信号范围0-10mg/L*)]]>
</Line>
<Line Number="65">
<![CDATA[SCL_Mn_AI.InEUMax:=1020.0;]]>
</Line>
<Line Number="66">
<![CDATA[SCL_Mn_AI.InEUMin:=0.0;]]>
</Line>
<Line Number="67">
<![CDATA[(*4-20mA输入范围对应是0-30480*)]]>
</Line>
<Line Number="68">
<![CDATA[SCL_Mn_AI.InRawMax:=30840;]]>
</Line>
<Line Number="69">
<![CDATA[SCL_Mn_AI.InRawMin:=0;]]>
</Line>
<Line Number="70">
<![CDATA[]]>
</Line>
<Line Number="71">
<![CDATA[(*使能ModbustTCP Client*)]]>
</Line>
<Line Number="72">
<![CDATA[Client_01_EN:=1;]]>
</Line>
</STContent>
</Routine>
<Routine Name="dosing_flow_set_KMnO4" Type="ST">
<Description>
<![CDATA[计算各数字泵投加流量：
1、手动设置时，以触摸屏设置流量为准；
2、自动控制时，以自动计算公式计算投加流量为准。
得出计算结果后，将流量传送到相关AO模块]]>
</Description>
<STContent>
<Line Number="0">
<![CDATA[(*1号制备投加装置：1、2号数字泵*)]]>
</Line>
<Line Number="1">
<![CDATA[(*计算实时锰耗*)]]>
</Line>
<Line Number="2">
<![CDATA[YaoHao_AB_actual_KMnO4:=KMnO4_flow_8FT11*KMnO4_density/Flow1_current_dam;]]>
</Line>
<Line Number="3">
<![CDATA[]]>
</Line>
<Line Number="4">
<![CDATA[(*计算流量*)]]>
</Line>
<Line Number="5">
<![CDATA[flow_calculate_KMnO4_1:=YaoHao_AB_setting_KMnO4*Flow1_current_dam/KMnO4_density;]]>
</Line>
<Line Number="6">
<![CDATA[]]>
</Line>
<Line Number="7">
<![CDATA[(*1#/2#数字泵流量计算*)]]>
</Line>
<Line Number="8">
<![CDATA[(*自动时通过锰耗、水量计算，手动时由触摸屏、上位机设置*)]]>
</Line>
<Line Number="9">
<![CDATA[if KMnO4_control_auto_manual[1] then]]>
</Line>
<Line Number="10">
<![CDATA[    P_KMnO4_1_flow_set:=flow_calculate_KMnO4_1;]]>
</Line>
<Line Number="11">
<![CDATA[    P_KMnO4_2_flow_set:=flow_calculate_KMnO4_1;]]>
</Line>
<Line Number="12">
<![CDATA[end_if;]]>
</Line>
<Line Number="13">
<![CDATA[]]>
</Line>
<Line Number="14">
<![CDATA[(*AO模块4-20mA输出*)]]>
</Line>
<Line Number="15">
<![CDATA[(*1#数字泵*)]]>
</Line>
<Line Number="16">
<![CDATA[SCL(SCL_LP1010_AO_13);]]>
</Line>
<Line Number="17">
<![CDATA[SCL_LP1010_AO_13.In:=P_KMnO4_1_flow_set;]]>
</Line>
<Line Number="18">
<![CDATA[]]>
</Line>
<Line Number="19">
<![CDATA[(*2#数字泵*)]]>
</Line>
<Line Number="20">
<![CDATA[SCL(SCL_LP1010_AO_14);]]>
</Line>
<Line Number="21">
<![CDATA[SCL_LP1010_AO_14.In:=P_KMnO4_2_flow_set;]]>
</Line>
<Line Number="22">
<![CDATA[]]>
</Line>
<Line Number="23">
<![CDATA[(*2号制备投加装置：3、4号数字泵*)]]>
</Line>
<Line Number="24">
<![CDATA[(*计算实时锰耗*)]]>
</Line>
<Line Number="25">
<![CDATA[YaoHao_CD_actual_KMnO4:=KMnO4_flow_8FT12*KMnO4_density/Flow2_current_dam;]]>
</Line>
<Line Number="26">
<![CDATA[]]>
</Line>
<Line Number="27">
<![CDATA[(*计算流量*)]]>
</Line>
<Line Number="28">
<![CDATA[flow_calculate_KMnO4_2:=YaoHao_CD_setting_KMnO4*Flow2_current_dam/KMnO4_density;]]>
</Line>
<Line Number="29">
<![CDATA[]]>
</Line>
<Line Number="30">
<![CDATA[(*3#/4#数字泵流量计算*)]]>
</Line>
<Line Number="31">
<![CDATA[(*自动时通过锰耗、水量计算，手动时由触摸屏、上位机设置*)]]>
</Line>
<Line Number="32">
<![CDATA[if KMnO4_control_auto_manual[2] then]]>
</Line>
<Line Number="33">
<![CDATA[    P_KMnO4_3_flow_set:=flow_calculate_KMnO4_2;]]>
</Line>
<Line Number="34">
<![CDATA[    P_KMnO4_4_flow_set:=flow_calculate_KMnO4_2;]]>
</Line>
<Line Number="35">
<![CDATA[end_if;]]>
</Line>
<Line Number="36">
<![CDATA[]]>
</Line>
<Line Number="37">
<![CDATA[(*AO模块4-20mA输出*)]]>
</Line>
<Line Number="38">
<![CDATA[SCL(SCL_LP1010_AO_15);]]>
</Line>
<Line Number="39">
<![CDATA[SCL_LP1010_AO_15.In:=P_KMnO4_3_flow_set;]]>
</Line>
<Line Number="40">
<![CDATA[]]>
</Line>
<Line Number="41">
<![CDATA[SCL(SCL_LP1010_AO_16);]]>
</Line>
<Line Number="42">
<![CDATA[SCL_LP1010_AO_16.In:=P_KMnO4_4_flow_set;]]>
</Line>
<Line Number="43">
<![CDATA[]]>
