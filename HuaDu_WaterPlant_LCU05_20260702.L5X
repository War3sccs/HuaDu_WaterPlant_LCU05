</Line>
<Line Number="70">
<![CDATA[			if NaClO_dilution_status_tank_4[5] then]]>
</Line>
<Line Number="71">
<![CDATA[				RemoteIO3:4:O.Data.7:=0;]]>
</Line>
<Line Number="72">
<![CDATA[			else]]>
</Line>
<Line Number="73">
<![CDATA[				RemoteIO3:4:O.Data.7:=1;]]>
</Line>
<Line Number="74">
<![CDATA[			end_if;]]>
</Line>
<Line Number="75">
<![CDATA[		else]]>
</Line>
<Line Number="76">
<![CDATA[			RemoteIO3:4:O.Data.7:=0;]]>
</Line>
<Line Number="77">
<![CDATA[		end_if;]]>
</Line>
<Line Number="78">
<![CDATA[	else]]>
</Line>
<Line Number="79">
<![CDATA[        RemoteIO3:4:O.Data.7:=VE_NaClO_30_actuate;]]>
</Line>
<Line Number="80">
<![CDATA[	end_if;]]>
</Line>
<Line Number="81">
<![CDATA[end_if;]]>
</Line>
<Line Number="82">
<![CDATA[]]>
</Line>
<Line Number="83">
<![CDATA[(*5号罐*)]]>
</Line>
<Line Number="84">
<![CDATA[if NaClO_level_high_alarm_5 or NaClO_tank_standby[5] then]]>
</Line>
<Line Number="85">
