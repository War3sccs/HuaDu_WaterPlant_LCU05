<Routine Name="valve_action_KMnO4" Type="ST">
<Description>
<![CDATA[阀门动作的控制分为分类：
1、普通电动阀可以自由动作；
2、泵出口阀需要与泵联动；
3、储罐进出口阀与储罐液位联动。]]>
</Description>
<STContent>
<Line Number="0">
<![CDATA[(*阀门动作的控制分为分类：*)]]>
</Line>
<Line Number="1">
<![CDATA[    (*1、普通电动阀可以自由动作；*)]]>
</Line>
<Line Number="2">
<![CDATA[    (*2、泵出口阀需要与泵联动；*)]]>
</Line>
<Line Number="3">
<![CDATA[]]>
</Line>
<Line Number="4">
<![CDATA[    (*1、普通电动阀控制*)]]>
</Line>
<Line Number="5">
<![CDATA[    RemoteIO4:2:O.Data.8:=VE_KMnO4_05_actuate;]]>
</Line>
<Line Number="6">
<![CDATA[RemoteIO4:2:O.Data.9:=VE_KMnO4_06_actuate;]]>
</Line>
<Line Number="7">
<![CDATA[]]>
</Line>
<Line Number="8">
<![CDATA[(*2、泵出口阀控制*)]]>
</Line>
<Line Number="9">
<![CDATA[    (*数字泵启动时，泵出口阀由数字泵控制程序控制，此时泵出口阀必须开启*)]]>
</Line>
<Line Number="10">
<![CDATA[(*1#泵的出口阀*)]]>
</Line>
<Line Number="11">
<![CDATA[if RemoteIO4:2:O.Data.0 then]]>
</Line>
<Line Number="12">
<![CDATA[	RemoteIO4:2:O.Data.4:=1;]]>
</Line>
<Line Number="13">
<![CDATA[else]]>
</Line>
<Line Number="14">
<![CDATA[	RemoteIO4:2:O.Data.4:=VE_KMnO4_01_actuate;]]>
</Line>
<Line Number="15">
<![CDATA[end_if;]]>
</Line>
<Line Number="16">
<![CDATA[(*2#泵的出口阀*)]]>
</Line>
<Line Number="17">
<![CDATA[if RemoteIO4:2:O.Data.1 then]]>
</Line>
<Line Number="18">
<![CDATA[	RemoteIO4:2:O.Data.5:=1;]]>
</Line>
<Line Number="19">
<![CDATA[else]]>
</Line>
<Line Number="20">
<![CDATA[	RemoteIO4:2:O.Data.5:=VE_KMnO4_02_actuate;]]>
</Line>
<Line Number="21">
<![CDATA[end_if;]]>
</Line>
<Line Number="22">
<![CDATA[(*3#泵的出口阀*)]]>
</Line>
<Line Number="23">
<![CDATA[if RemoteIO4:2:O.Data.2 then]]>
</Line>
<Line Number="24">
<![CDATA[	RemoteIO4:2:O.Data.6:=1;]]>
</Line>
<Line Number="25">
<![CDATA[else]]>
</Line>
<Line Number="26">
<![CDATA[	RemoteIO4:2:O.Data.6:=VE_KMnO4_03_actuate;]]>
</Line>
<Line Number="27">
<![CDATA[end_if;]]>
</Line>
<Line Number="28">
<![CDATA[(*4#泵的出口阀*)]]>
</Line>
<Line Number="29">
<![CDATA[if RemoteIO4:2:O.Data.3 then]]>
</Line>
<Line Number="30">
<![CDATA[	RemoteIO4:2:O.Data.7:=1;]]>
</Line>
<Line Number="31">
<![CDATA[else]]>
</Line>
<Line Number="32">
<![CDATA[	RemoteIO4:2:O.Data.7:=VE_KMnO4_04_actuate;]]>
</Line>
<Line Number="33">
<![CDATA[end_if;]]>
</Line>
<Line Number="34">
<![CDATA[]]>
</Line>
<Line Number="35">
<![CDATA[]]>
</Line>
<Line Number="36">
<![CDATA[]]>
</Line>
<Line Number="37">
<![CDATA[]]>
</Line>
<Line Number="38">
<![CDATA[]]>
</Line>
<Line Number="39">
<![CDATA[]]>
</Line>
<Line Number="40">
<![CDATA[]]>
</Line>
