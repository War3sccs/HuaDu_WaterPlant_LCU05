</Line>
<Line Number="295">
<![CDATA[    VE_PAC_07_actuate:=VE_PAC_actuate_local[7];]]>
</Line>
<Line Number="296">
<![CDATA[	if not PAC_tank_auto_manual[1] then]]>
</Line>
<Line Number="297">
<![CDATA[        MI_PAC1_actuate:=MI_PAC_actuate_local[1];]]>
</Line>
<Line Number="298">
<![CDATA[        MI_PAC2_actuate:=MI_PAC_actuate_local[2];]]>
