<AddOnInstructionDefinition Name="raC_Tec_NetModbusTCPClient_RespStrBit" Revision="2.0" ExecutePrescan="true" ExecutePostscan="false" ExecuteEnableInFalse="false" CreatedDate="2019-12-09T12:11:37.717Z" CreatedBy="Not Available" EditedDate="2024-09-02T13:25:04.341Z" EditedBy="PC-XINGUANG\wymwym" SoftwareRevision="v34.00">
<Parameters>
<Parameter Name="EnableIn" TagType="Base" DataType="BOOL" Usage="Input" Radix="Decimal" Required="false" Visible="false" ExternalAccess="Read Only">
<Description>
<![CDATA[Enable Input - System Defined Parameter]]>
</Description>
</Parameter>
