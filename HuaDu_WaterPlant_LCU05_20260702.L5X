<Routines>
<Routine Name="Logic" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Modbus Client Add-On Instruction.
Must use Rung Import]]>
</Comment>
<Text>
<![CDATA[NOP();]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Text>
<![CDATA[XIC(s:fs)OTU(Wrk_InitCompleted);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Text>
<![CDATA[XIO(Wrk_InitCompleted)CLR(Wrk_TransIndex)CLR(Wrk_WrIndex)CLR(Wrk_TimerIndex)CLR(Wrk_ClrReqIndex)CLR(Wrk_MSGStep)FLL(0,Wrk_Main_Read_Buffer,1);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Text>
<![CDATA[XIO(Wrk_InitCompleted)GSV(ControllerDevice,,DeviceName,Wrk_Controller_Name[0])COP(Wrk_Controller_Name[1],Wrk_Controller_Type,1);]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Comment>
<![CDATA[Check Array sizes to make sure we are not faulting controller]]>
</Comment>
<Text>
<![CDATA[XIO(Wrk_InitCompleted)SIZE(Ref_Transactions,0,Wrk_ArraySize)SUB(Wrk_ArraySize,1,Wrk_LastTransaction);]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Text>
<![CDATA[OTL(Wrk_InitCompleted);]]>
</Text>
</Rung>
<Rung Number="6" Type="N">
<Text>
<![CDATA[EQU(Wrk_MSGStep,0)MOV(5000,Wrk_RetryTimer.PRE)TON(Wrk_RetryTimer,?,?)XIC(Wrk_RetryTimer.DN)FLL(0,Wrk_Main_Read_Buffer,1)MOV(10,Wrk_MSGStep);]]>
</Text>
</Rung>
<Rung Number="7" Type="N">
<Comment>
<![CDATA[Constants for Sockets]]>
</Comment>
<Text>
<![CDATA[EQU(Wrk_MSGStep,10)MOV(1,Wrk_CreateReq.Type)MOV(2,Wrk_CreateReq.Family)MOV(0,Wrk_CreateReq.Port)MOV(15,Wrk_MSGStep);]]>
</Text>
</Rung>
<Rung Number="8" Type="N">
<Comment>
<![CDATA[Force Controller slot to 0 for 1769 and 5069 controllers]]>
</Comment>
<Text>
<![CDATA[EQU(Wrk_MSGStep,15)MOV(20,Wrk_MSGStep)[EQU(Wrk_Controller_Type,16#39363731) ,EQU(Wrk_Controller_Type,16#39363035) ]CLR(Ref_Connection.LocalSlot);]]>
</Text>
</Rung>
<Rung Number="9" Type="N">
<Comment>
<![CDATA[Parse Local IP String. - Steps 20-29
This is only needed for 5380/5480 with dual port mode.]]>
</Comment>
<Text>
<![CDATA[EQU(Wrk_MSGStep,20)COP(Ref_Connection.LocalAddress,Wrk_TempIPStr,1)FLL(0,Wrk_TempOctet[0],4)[MOV(21,Wrk_MSGStep) ,LES(Wrk_TempIPStr.LEN,7) MOV(29,Wrk_MSGStep) ];]]>
</Text>
</Rung>
<Rung Number="10" Type="N">
<Comment>
<![CDATA[Parse 1st octet]]>
</Comment>
<Text>
<![CDATA[EQU(Wrk_MSGStep,21)STOD(Wrk_TempIPStr,Wrk_TempOctet[3])DTOS(Wrk_TempOctet[3],Wrk_TempStrOctet)ADD(Wrk_TempStrOctet.LEN,1,Wrk_TempStrOctetlen)[LEQ(Wrk_TempIPStr.LEN,Wrk_TempStrOctetlen) MOV(29,Wrk_MSGStep) ,GRT(Wrk_TempIPStr.LEN,Wrk_TempStrOctetlen) DELETE(Wrk_TempIPStr,Wrk_TempStrOctetlen,1,Wrk_TempIPStr) MOV(22,Wrk_MSGStep) ];]]>
</Text>
</Rung>
<Rung Number="11" Type="N">
<Comment>
<![CDATA[Parse second octet]]>
</Comment>
<Text>
<![CDATA[EQU(Wrk_MSGStep,22)STOD(Wrk_TempIPStr,Wrk_TempOctet[2])DTOS(Wrk_TempOctet[2],Wrk_TempStrOctet)ADD(Wrk_TempStrOctet.LEN,1,Wrk_TempStrOctetlen)[LEQ(Wrk_TempIPStr.LEN,Wrk_TempStrOctetlen) MOV(29,Wrk_MSGStep) ,GRT(Wrk_TempIPStr.LEN,Wrk_TempStrOctetlen) DELETE(Wrk_TempIPStr,Wrk_TempStrOctetlen,1,Wrk_TempIPStr) MOV(23,Wrk_MSGStep) ];]]>
</Text>
</Rung>
<Rung Number="12" Type="N">
<Comment>
<![CDATA[Parse 3rd octet]]>
</Comment>
<Text>
<![CDATA[EQU(Wrk_MSGStep,23)STOD(Wrk_TempIPStr,Wrk_TempOctet[1])DTOS(Wrk_TempOctet[1],Wrk_TempStrOctet)ADD(Wrk_TempStrOctet.LEN,1,Wrk_TempStrOctetlen)[LEQ(Wrk_TempIPStr.LEN,Wrk_TempStrOctetlen) MOV(29,Wrk_MSGStep) ,GRT(Wrk_TempIPStr.LEN,Wrk_TempStrOctetlen) DELETE(Wrk_TempIPStr,Wrk_TempStrOctetlen,1,Wrk_TempIPStr) MOV(24,Wrk_MSGStep) ];]]>
</Text>
</Rung>
<Rung Number="13" Type="N">
<Comment>
<![CDATA[Parse last octet and create HEX address]]>
</Comment>
<Text>
<![CDATA[EQU(Wrk_MSGStep,24)STOD(Wrk_TempIPStr,Wrk_TempOctet[0])BTD(Wrk_TempOctet[0],0,Wrk_CreateReq.Addr,0,8)BTD(Wrk_TempOctet[1],0,Wrk_CreateReq.Addr,8,8)BTD(Wrk_TempOctet[2],0,Wrk_CreateReq.Addr,16,8)BTD(Wrk_TempOctet[3],0,Wrk_CreateReq.Addr,24,8)MOV(30,Wrk_MSGStep);]]>
</Text>
</Rung>
<Rung Number="14" Type="N">
<Comment>
<![CDATA[Clear Address if string was invalid]]>
</Comment>
<Text>
<![CDATA[EQU(Wrk_MSGStep,29)CLR(Wrk_CreateReq.Addr)MOV(30,Wrk_MSGStep);]]>
</Text>
</Rung>
<Rung Number="15" Type="N">
<Text>
<![CDATA[EQU(Wrk_MSGStep,30)MOV(5000,Wrk_ConnectReq.Timeout)CONCAT(Ref_Connection.DestAddress,Wrk_PortStr,Wrk_ConnectReq.DestAddr)DTOS(Ref_Connection.DestinationPort,Wrk_TempStr)CONCAT(Wrk_ConnectReq.DestAddr,Wrk_TempStr,Wrk_ConnectReq.DestAddr)MOV(90,Wrk_MSGStep);]]>
</Text>
</Rung>
<Rung Number="16" Type="N">
<Comment>
<![CDATA[Create Path for messages to the local module
]]>
</Comment>
<Text>
<![CDATA[EQU(Wrk_MSGStep,90)[MOV(1,Ref_MsgCreate.Path.DATA[0]) MOV(Ref_Connection.LocalSlot,Ref_MsgCreate.Path.DATA[1]) MOV(2,Ref_MsgCreate.Path.LEN) ,COP(Ref_MsgCreate.Path,Ref_MsgConnect.Path,1) COP(Ref_MsgCreate.Path,Ref_MsgRead.Path,1) COP(Ref_MsgCreate.Path,Ref_MsgWrite.Path,1) COP(Ref_MsgCreate.Path,Ref_MsgDelete.Path,1) COP(Ref_MsgCreate.Path,Ref_MsgSetAttrSingle.Path,1) ]MOV(100,Wrk_MSGStep);]]>
</Text>
</Rung>
<Rung Number="17" Type="N">
<Text>
<![CDATA[EQU(Wrk_MSGStep,100)[XIC(Inp_Enable) OTL(Sts_EN) OTU(Sts_Faulted) MOV(0,Sts_LastError) MOV(110,Wrk_MSGStep) ,XIO(Inp_Enable) MOV(800,Wrk_MSGStep) ];]]>
</Text>
</Rung>
<Rung Number="18" Type="N">
<Text>
<![CDATA[EQU(Wrk_MSGStep,110)CLR(Wrk_Instance)COP(Wrk_CreateReq,Ref_Connection.MSG_Src[0],12)MOV(12,Ref_MsgCreate.REQ_LEN)[MSG(Ref_MsgCreate) ,MOV(120,Wrk_MSGStep) ];]]>
</Text>
</Rung>
<Rung Number="19" Type="N">
<Text>
<![CDATA[EQU(Wrk_MSGStep,120)[XIO(Ref_MsgCreate.EN) [XIC(Ref_MsgCreate.DN) COP(Ref_Connection.MSG_Dest[0],Wrk_Instance,1) MOV(130,Wrk_MSGStep) ,XIC(Ref_MsgCreate.ER) MOV(900,Wrk_MSGStep) ] ,XIO(Inp_Enable) MOV(800,Wrk_MSGStep) ];]]>
</Text>
</Rung>
<Rung Number="20" Type="N">
<Comment>
<![CDATA[Set Linger
]]>
</Comment>
<Text>
<![CDATA[EQU(Wrk_MSGStep,130)MOV(1,Ref_Connection.MSG_Src[496])FLL(0,Ref_Connection.MSG_Src[497],3)MOV(Wrk_Instance,Ref_MsgSetAttrSingle.Instance)MOV(10,Ref_MsgSetAttrSingle.Attribute)MOV(140,Wrk_MSGStep)MSG(Ref_MsgSetAttrSingle);]]>
</Text>
</Rung>
<Rung Number="21" Type="N">
<Text>
<![CDATA[EQU(Wrk_MSGStep,140)[XIC(Ref_MsgSetAttrSingle.DN) ,XIC(Ref_MsgSetAttrSingle.ER) ]MOV(200,Wrk_MSGStep);]]>
</Text>
</Rung>
<Rung Number="22" Type="N">
<Text>
<![CDATA[EQU(Wrk_MSGStep,200)RES(Ref_Transactions[Wrk_WrIndex].Diagnostic.NoReplyCounter)[XIC(Inp_Enable) MOV(210,Wrk_MSGStep) ,XIO(Inp_Enable) MOV(800,Wrk_MSGStep) ];]]>
</Text>
</Rung>
<Rung Number="23" Type="N">
<Text>
<![CDATA[EQU(Wrk_MSGStep,210)MOV(Wrk_Instance,Ref_MsgConnect.Instance)ADD(Wrk_ConnectReq.DestAddr.LEN,8,Ref_MsgConnect.REQ_LEN)COP(Wrk_ConnectReq,Ref_Connection.MSG_Src[0],Ref_MsgConnect.REQ_LEN)MOV(10000000,Ref_MsgConnect.UnconnectedTimeout)[MSG(Ref_MsgConnect) ,MOV(220,Wrk_MSGStep) ];]]>
</Text>
</Rung>
<Rung Number="24" Type="N">
<Text>
<![CDATA[EQU(Wrk_MSGStep,220)[XIO(Ref_MsgConnect.EN) [XIC(Ref_MsgConnect.DN) MOV(0,Sts_LastError) OTL(Sts_Connected) MOV(230,Wrk_MSGStep) ,XIC(Ref_MsgConnect.ER) MOV(910,Wrk_MSGStep) ] ,XIO(Inp_Enable) MOV(800,Wrk_MSGStep) ];]]>
</Text>
</Rung>
<Rung Number="25" Type="N">
<Text>
<![CDATA[EQU(Wrk_MSGStep,230)CLR(Wrk_ClrReqIndex)MOV(232,Wrk_MSGStep);]]>
</Text>
</Rung>
<Rung Number="26" Type="N">
<Text>
<![CDATA[LBL(Loop_ClrTrig)EQU(Wrk_MSGStep,232)MOV(300,Wrk_MSGStep)[OTU(Ref_Transactions[Wrk_ClrReqIndex].Diagnostic.ReqBuilt) ,OTU(Ref_Transactions[Wrk_ClrReqIndex].Diagnostic.Overload) ,OTU(Ref_Transactions[Wrk_ClrReqIndex].Diagnostic.Overlap) ]LES(Wrk_ClrReqIndex,Wrk_LastTransaction)ADD(Wrk_ClrReqIndex,1,Wrk_ClrReqIndex)MOV(232,Wrk_MSGStep)JMP(Loop_ClrTrig);]]>
</Text>
</Rung>
<Rung Number="27" Type="N">
<Comment>
<![CDATA[State 300 is the starting point of the main loop:
Triggers (3xx)
Write Messages (4xx),
Read Messages (5xx),
Packet Processing (6xx)]]>
</Comment>
<Text>
<![CDATA[NOP();]]>
</Text>
</Rung>
<Rung Number="28" Type="N">
<Text>
<![CDATA[EQU(Wrk_MSGStep,300)MOV(310,Wrk_MSGStep);]]>
</Text>
</Rung>
<Rung Number="29" Type="N">
<Text>
<![CDATA[EQU(Wrk_MSGStep,310)MOV(320,Wrk_MSGStep)XIO(Inp_Enable)MOV(800,Wrk_MSGStep);]]>
</Text>
</Rung>
<Rung Number="30" Type="N">
<Comment>
<![CDATA[Triggers Start Here]]>
</Comment>
<Text>
<![CDATA[NOP();]]>
</Text>
</Rung>
<Rung Number="31" Type="N">
<Text>
<![CDATA[EQU(Wrk_MSGStep,320)MOV(0,Wrk_TransIndex)MOV(330,Wrk_MSGStep);]]>
</Text>
</Rung>
<Rung Number="32" Type="N">
<Comment>
<![CDATA[Can't have a poll interval less than 80 ms. If less than 80, then we will set it to 1 second]]>
</Comment>
<Text>
<![CDATA[LBL(Loop_Triggers)EQU(Wrk_MSGStep,330)[LES(Ref_Transactions[Wrk_TransIndex].PollInterval,80) MOV(1000,Ref_Transactions[Wrk_TransIndex].PollInterval) ,MOV(340,Wrk_MSGStep) ];]]>
</Text>
</Rung>
<Rung Number="33" Type="N">
<Comment>
<![CDATA[Dont do anything if transaction is not enabled]]>
</Comment>
<Text>
<![CDATA[EQU(Wrk_MSGStep,340)MOV(350,Wrk_MSGStep)XIO(Ref_Transactions[Wrk_TransIndex].Enabled)[OTU(Ref_Transactions[Wrk_TransIndex].Diagnostic.ReqBuilt) ,OTU(Ref_Transactions[Wrk_TransIndex].Diagnostic.Overload) ,OTU(Ref_Transactions[Wrk_TransIndex].Diagnostic.Overlap) ]MOV(390,Wrk_MSGStep);]]>
</Text>
</Rung>
<Rung Number="34" Type="N">
<Text>
<![CDATA[EQU(Wrk_MSGStep,350)OTU(Wrk_TransactionTriggers[Wrk_TransIndex])MOV(360,Wrk_MSGStep);]]>
</Text>
</Rung>
<Rung Number="35" Type="N">
<Text>
<![CDATA[EQU(Wrk_MSGStep,360)MOV(390,Wrk_MSGStep)XIC(Ref_Transactions[Wrk_TransIndex].Enabled)XIC(Ref_Transactions[Wrk_TransIndex].Diagnostic.IntervalTimer.DN)RES(Ref_Transactions[Wrk_TransIndex].Diagnostic.IntervalTimer)[XIO(Ref_Transactions[Wrk_TransIndex].Diagnostic.ReqBuilt) OTL(Wrk_TransactionTriggers[Wrk_TransIndex]) OTU(Ref_Transactions[Wrk_TransIndex].Diagnostic.Overlap) ,XIC(Ref_Transactions[Wrk_TransIndex].Diagnostic.ReqBuilt) OTL(Ref_Transactions[Wrk_TransIndex].Diagnostic.Overlap) ];]]>
</Text>
</Rung>
<Rung Number="36" Type="N">
<Text>
<![CDATA[EQU(Wrk_MSGStep,390)MOV(400,Wrk_MSGStep)LES(Wrk_TransIndex,Wrk_LastTransaction)ADD(Wrk_TransIndex,1,Wrk_TransIndex)MOV(330,Wrk_MSGStep)JMP(Loop_Triggers);]]>
</Text>
</Rung>
<Rung Number="37" Type="N">
<Comment>
<![CDATA[Triggers End Here]]>
</Comment>
<Text>
<![CDATA[NOP();]]>
</Text>
</Rung>
<Rung Number="38" Type="N">
<Comment>
<![CDATA[Write Section Starts Here
]]>
</Comment>
<Text>
<![CDATA[NOP();]]>
</Text>
</Rung>
<Rung Number="39" Type="N">
<Text>
<![CDATA[EQU(Wrk_MSGStep,400)MOV(0,Wrk_WrIndex)MOV(410,Wrk_MSGStep);]]>
</Text>
</Rung>
<Rung Number="40" Type="N">
<Comment>
<![CDATA[Rebuild the request string if the ReqBuilt flag is cleared or this is a write operation.]]>
</Comment>
<Text>
<![CDATA[EQU(Wrk_MSGStep,410)[XIC(Wrk_TransactionTriggers[Wrk_WrIndex]) raC_Tec_NetModbusTCPClient_BuildReqStr(Wrk_BRS,Ref_Transactions[Wrk_WrIndex],Ref_ModbusData) [XIO(Wrk_BRS.ER) OTL(Ref_Transactions[Wrk_WrIndex].Diagnostic.ReqBuilt) MOV(420,Wrk_MSGStep) ,XIC(Wrk_BRS.ER) MOV(480,Wrk_MSGStep) ] ,XIO(Wrk_TransactionTriggers[Wrk_WrIndex]) MOV(480,Wrk_MSGStep) ];]]>
</Text>
</Rung>
<Rung Number="41" Type="N">
<Comment>
<![CDATA[Create a new transaction ID in the Request String and trigger a write of the request
]]>
</Comment>
<Text>
<![CDATA[EQU(Wrk_MSGStep,420)XIC(Ref_Transactions[Wrk_WrIndex].Diagnostic.ReqBuilt)XIC(Wrk_TransactionTriggers[Wrk_WrIndex])[[EQU(Wrk_IDCounter,32767) MOV(0,Wrk_IDCounter) ,ADD(Wrk_IDCounter,1,Wrk_IDCounter) ] MOV(Wrk_IDCounter,Ref_Transactions[Wrk_WrIndex].Diagnostic.TransID) ,SWPB(Ref_Transactions[Wrk_WrIndex].Diagnostic.TransID,REVERSE,Wrk_TempInt) COP(Wrk_TempInt,Ref_Transactions[Wrk_WrIndex].Diagnostic.Request.DATA[0],2) ][OTL(Wrk_WriteNow[Wrk_WrIndex]) ,OTU(Wrk_TransactionTriggers[Wrk_WrIndex]) ,MOV(430,Wrk_MSGStep) ];]]>
</Text>
</Rung>
<Rung Number="42" Type="N">
<Comment>
<![CDATA[Before we write, check to see if we have a reply, 
if none increment the noReply counter for this connection.  
If so reset the count.
After 10 reset the connection.]]>
</Comment>
<Text>
<![CDATA[EQU(Wrk_MSGStep,430)[XIC(Ref_Transactions[Wrk_WrIndex].TransComplete) RES(Ref_Transactions[Wrk_WrIndex].Diagnostic.NoReplyCounter) ,XIC(Wrk_WriteNow[Wrk_WrIndex]) MOV(440,Wrk_MSGStep) ];]]>
</Text>
</Rung>
<Rung Number="43" Type="N">
<Comment>
<![CDATA[If  this transaction is flagged for transmit, then copy the request string intoSource, set the packet size, do the write message function and clear the Write_Now flag .
]]>
</Comment>
<Text>
<![CDATA[EQU(Wrk_MSGStep,440)XIC(Wrk_WriteNow[Wrk_WrIndex])XIO(Ref_MsgWrite.EN)XIO(Ref_MsgRead.EN)[MOV(20,Wrk_TempDINT) COP(Wrk_TempDINT,Ref_Connection.MSG_Src[0],4) FLL(0,Ref_Connection.MSG_Src[4],8) ,COP(Ref_Transactions[Wrk_WrIndex].Diagnostic.Request.LEN,Ref_Connection.MSG_Src[12],4) COP(Ref_Transactions[Wrk_WrIndex].Diagnostic.Request.DATA[0],Ref_Connection.MSG_Src[16],Ref_Transactions[Wrk_WrIndex].Diagnostic.Request.LEN) ADD(Ref_Transactions[Wrk_WrIndex].Diagnostic.Request.LEN,16,Ref_MsgWrite.REQ_LEN) ,XIO(Ref_Transactions[Wrk_WrIndex].TransComplete) MOV(2,Ref_Transactions[Wrk_WrIndex].TransStat) [MOV(10,Ref_Transactions[Wrk_WrIndex].Diagnostic.NoReplyCounter.PRE) ,CTU(Ref_Transactions[Wrk_WrIndex].Diagnostic.NoReplyCounter,10,0) ] ,XIC(Ref_Transactions[Wrk_WrIndex].TransComplete) MOV(1,Ref_Transactions[Wrk_WrIndex].TransStat) ,OTU(Ref_Transactions[Wrk_WrIndex].TransComplete) OTU(Wrk_WriteNow[Wrk_WrIndex]) MOV(450,Wrk_MSGStep) ];]]>
</Text>
</Rung>
<Rung Number="44" Type="N">
<Text>
<![CDATA[EQU(Wrk_MSGStep,450)[MOV(Wrk_Instance,Ref_MsgWrite.Instance) MOV(3000000,Ref_MsgWrite.UnconnectedTimeout) MSG(Ref_MsgWrite) ,XIC(Ref_MsgWrite.DN) MOV(480,Wrk_MSGStep) ,XIC(Ref_MsgWrite.ER) MOV(-2,Sts_LastError) MOV(940,Wrk_MSGStep) ];]]>
</Text>
</Rung>
<Rung Number="45" Type="N">
<Comment>
<![CDATA[Write message is done, repeat for all transactions]]>
</Comment>
<Text>
<![CDATA[EQU(Wrk_MSGStep,480)MOV(500,Wrk_MSGStep)LES(Wrk_WrIndex,Wrk_LastTransaction)ADD(Wrk_WrIndex,1,Wrk_WrIndex)MOV(410,Wrk_MSGStep);]]>
</Text>
</Rung>
<Rung Number="46" Type="N">
<Comment>
<![CDATA[Read Section Starts Here
]]>
</Comment>
<Text>
<![CDATA[NOP();]]>
</Text>
</Rung>
<Rung Number="47" Type="N">
<Comment>
<![CDATA[Prepare Data for Read]]>
</Comment>
<Text>
<![CDATA[EQU(Wrk_MSGStep,500)MOV(0,Wrk_MSGRead_SRC[0])MOV(484,Wrk_MSGRead_SRC[1])COP(Wrk_MSGRead_SRC[0],Ref_Connection.MSG_Src[0],8)MOV(8,Ref_MsgRead.REQ_LEN)MOV(510,Wrk_MSGStep);]]>
</Text>
</Rung>
<Rung Number="48" Type="N">
<Comment>
<![CDATA[Prepare Data for Read]]>
</Comment>
<Text>
<![CDATA[EQU(Wrk_MSGStep,510)XIO(Ref_MsgRead.EN)XIO(Ref_MsgWrite.EN)MOV(520,Wrk_MSGStep);]]>
</Text>
</Rung>
<Rung Number="49" Type="N">
<Text>
<![CDATA[EQU(Wrk_MSGStep,520)[MOV(Wrk_Instance,Ref_MsgRead.Instance) MOV(3000000,Ref_MsgRead.UnconnectedTimeout) MSG(Ref_MsgRead) ,XIC(Ref_MsgRead.ER) MOV(-4,Sts_LastError) MOV(920,Wrk_MSGStep) ,XIC(Ref_MsgRead.DN) MOV(530,Wrk_MSGStep) ];]]>
</Text>
</Rung>
<Rung Number="50" Type="N">
<Comment>
<![CDATA[Handling Read Message Buffer]]>
</Comment>
<Text>
<![CDATA[EQU(Wrk_MSGStep,530)COP(Ref_Connection.MSG_Dest[8],Wrk_TempString.LEN,1)[GRT(Wrk_TempString.LEN,0) COP(Ref_Connection.MSG_Dest[12],Wrk_TempString.DATA[0],Wrk_TempString.LEN) CONCAT(Wrk_Main_Read_Buffer,Wrk_TempString,Wrk_Main_Read_Buffer) ,MOV(540,Wrk_MSGStep) ];]]>
</Text>
</Rung>
<Rung Number="51" Type="N">
<Comment>
<![CDATA[We come here if Read message is Done]]>
</Comment>
<Text>
<![CDATA[EQU(Wrk_MSGStep,540)MOV(600,Wrk_MSGStep);]]>
</Text>
</Rung>
<Rung Number="52" Type="N">
<Comment>
<![CDATA[Incoming Packet Processing]]>
</Comment>
<Text>
<![CDATA[NOP();]]>
</Text>
</Rung>
<Rung Number="53" Type="N">
<Comment>
<![CDATA[This will check main read buffer for new modbus string.
First check the header, response should be at least 
8 bytes.Bytes 4 an 5 will contain additional packet length.
If all bytes of this message are received, the packet will be extracted from the Main read buffer and parsed.
Revised in Ver 2.04]]>
</Comment>
<Text>
<![CDATA[EQU(Wrk_MSGStep,600)MOV(610,Wrk_MSGStep)GEQ(Wrk_Main_Read_Buffer.LEN,8)[COP(Wrk_Main_Read_Buffer.DATA[4],Wrk_AdditionalLen,1) SWPB(Wrk_AdditionalLen,REVERSE,Wrk_AdditionalLen1) ADD(Wrk_AdditionalLen1,6,Wrk_AdditionaLenRead) ,GEQ(Wrk_AdditionaLenRead,8) GEQ(Wrk_Main_Read_Buffer.LEN,Wrk_AdditionaLenRead) [MID(Wrk_Main_Read_Buffer,Wrk_AdditionaLenRead,1,Wrk_ModbusPacket) ,DELETE(Wrk_Main_Read_Buffer,Wrk_AdditionaLenRead,1,Wrk_Main_Read_Buffer) ,OTE(Wrk_DataReceived) ] ];]]>
</Text>
</Rung>
<Rung Number="54" Type="N">
<Comment>
<![CDATA[Check for malformed packets by checking transaction type and protocol identifier.   Clear the buffer  if found.  
This is just a safety measure in case corrupt data ever gets left in the buffer.
]]>
</Comment>
<Text>
<![CDATA[EQU(Wrk_MSGStep,610)MOV(620,Wrk_MSGStep)XIO(Wrk_DataReceived)MOV(690,Wrk_MSGStep)[NEQ(Wrk_Main_Read_Buffer.DATA[2],0) ,NEQ(Wrk_Main_Read_Buffer.DATA[3],0) ,MOV(Wrk_Main_Read_Buffer.DATA[8],Wrk_CmdFromReadPacket) LES(Wrk_CmdFromReadPacket,1) ,GRT(Wrk_CmdFromReadPacket,6) NEQ(Wrk_CmdFromReadPacket,15) NEQ(Wrk_CmdFromReadPacket,16) ]FLL(0,Wrk_Main_Read_Buffer,1);]]>
</Text>
</Rung>
<Rung Number="55" Type="N">
<Comment>
<![CDATA[Once data is ready,  extract the Modbus_ID, Modbus_Unit, and extract the data packet from the Modbus TCP packet
Revised in V2.04]]>
</Comment>
<Text>
<![CDATA[EQU(Wrk_MSGStep,620)MOV(625,Wrk_MSGStep)[SUB(Wrk_AdditionalLen1,1,Wrk_ModbusBytes) FLL(0,Wrk_ModbusID,1) FLL(0,Wrk_ModbusUnit,1) FLL(0,Wrk_ModbusCmdString,1) ,CLR(Wrk_CmdFromReadPacket) CLR(Wrk_ModbusTransID) ];]]>
</Text>
</Rung>
<Rung Number="56" Type="N">
<Comment>
<![CDATA[Once data is ready,  extract the Modbus_ID, Modbus_Unit, and extract the data packet from the Modbus TCP packet
revised in V2.04]]>
</Comment>
<Text>
<![CDATA[EQU(Wrk_MSGStep,625)MOV(630,Wrk_MSGStep)EQU(Wrk_ModbusPacket.LEN,Wrk_AdditionaLenRead)[MID(Wrk_ModbusPacket,2,1,Wrk_ModbusID) MUL(Wrk_ModbusID.DATA[0],256,Wrk_ModbusTransID) OR(Wrk_ModbusID.DATA[1],Wrk_ModbusTransID,Wrk_ModbusTransID) MID(Wrk_ModbusPacket,1,7,Wrk_ModbusUnit) ,MID(Wrk_ModbusPacket,Wrk_ModbusBytes,8,Wrk_ModbusCmdString) MOV(Wrk_ModbusCmdString.DATA[0],Wrk_CmdFromReadPacket) ];]]>
</Text>
</Rung>
<Rung Number="57" Type="N">
<Comment>
<![CDATA[For these transaction types (all writes), the only thing necessary is to mark the Transaction ID as received  
AOI _CheckWriteReply will match the transaction code to the request and mark the packet as received.

]]>
</Comment>
<Text>
<![CDATA[EQU(Wrk_MSGStep,630)MOV(640,Wrk_MSGStep)[EQU(Wrk_CmdFromReadPacket,5) ,EQU(Wrk_CmdFromReadPacket,6) ,EQU(Wrk_CmdFromReadPacket,15) ,EQU(Wrk_CmdFromReadPacket,16) ]MOV(690,Wrk_MSGStep)raC_Tec_NetModbusTCPClient_ChkWrReply(Wrk_CWR,Ref_Transactions,Wrk_ModbusTransID,Wrk_ModbusBytes,Wrk_CmdFromReadPacket,Wrk_LastTransaction);]]>
</Text>
</Rung>
<Rung Number="58" Type="N">
<Comment>
<![CDATA[Analyze incoming command for bit read commands
Trans Type 1.
Addresses 0xxxx  handling
For Transaction types of 1 and 2, call Sub_Check_Write_Reply to match Transaction code and mark received, 
then AOI _RespStrBit to parse the data and write it to the local data arrays.]]>
</Comment>
<Text>
<![CDATA[EQU(Wrk_MSGStep,640)MOV(650,Wrk_MSGStep)EQU(Wrk_CmdFromReadPacket,1)MOV(690,Wrk_MSGStep)[MOV(Wrk_ModbusCmdString.DATA[1],Wrk_ModbusCmdLen) raC_Tec_NetModbusTCPClient_ChkWrReply(Wrk_CWR,Ref_Transactions,Wrk_ModbusTransID,Wrk_ModbusBytes,Wrk_CmdFromReadPacket,Wrk_LastTransaction) ,XIC(Wrk_CWR.TransFound) CMP(Wrk_CWR.Count<=Wrk_ModbusCmdLen*8) raC_Tec_NetModbusTCPClient_RespStrBit(Wrk_RSB,0,Wrk_CWR.Count,Wrk_CWR.LocalOffset,Ref_ModbusData,Wrk_ModbusCmdString) ];]]>
</Text>
</Rung>
<Rung Number="59" Type="N">
<Comment>
<![CDATA[Analyze incoming command for bit read commands
Trans Type 2.
Addresses 0xxxx 1xxxx handling
For Transaction types of 1 and 2, call Sub_Check_Write_Reply to match Transaction code and mark received, 
then AOI _RespStrBit to parse the data and write it to the local data arrays.]]>
</Comment>
<Text>
<![CDATA[EQU(Wrk_MSGStep,650)MOV(660,Wrk_MSGStep)EQU(Wrk_CmdFromReadPacket,2)MOV(690,Wrk_MSGStep)[MOV(Wrk_ModbusCmdString.DATA[1],Wrk_ModbusCmdLen) raC_Tec_NetModbusTCPClient_ChkWrReply(Wrk_CWR,Ref_Transactions,Wrk_ModbusTransID,Wrk_ModbusBytes,Wrk_CmdFromReadPacket,Wrk_LastTransaction) ,XIC(Wrk_CWR.TransFound) CMP(Wrk_CWR.Count<=Wrk_ModbusCmdLen*8) raC_Tec_NetModbusTCPClient_RespStrBit(Wrk_RSB,1,Wrk_CWR.Count,Wrk_CWR.LocalOffset,Ref_ModbusData,Wrk_ModbusCmdString) ];]]>
</Text>
</Rung>
<Rung Number="60" Type="N">
<Comment>
<![CDATA[Analyze incoming command for REGISTER commands
Transaction Type 4.
Adresses 3xxxxx and 4xxxxx handling
Finally calling AOI _CheckWriteReply to match the Transaction ID ot the request and mark the transaction as received and AOI _RespStrWORD to unpack the data and write it to the local arrays.
]]>
</Comment>
<Text>
<![CDATA[EQU(Wrk_MSGStep,660)MOV(670,Wrk_MSGStep)EQU(Wrk_CmdFromReadPacket,3)MOV(690,Wrk_MSGStep)[AND(Wrk_ModbusCmdString.DATA[1],255,Wrk_ModbusCmdTemp) DIV(Wrk_ModbusCmdTemp,2,Wrk_ModbusCmdLen) raC_Tec_NetModbusTCPClient_ChkWrReply(Wrk_CWR,Ref_Transactions,Wrk_ModbusTransID,Wrk_ModbusBytes,Wrk_CmdFromReadPacket,Wrk_LastTransaction) ,XIC(Wrk_CWR.TransFound) LEQ(Wrk_CWR.Count,Wrk_ModbusCmdLen) raC_Tec_NetModbusTCPClient_RespStrWord(Wrk_RSW,0,Wrk_CWR.Count,Wrk_CWR.LocalOffset,Ref_ModbusData,Wrk_ModbusCmdString) ];]]>
</Text>
</Rung>
<Rung Number="61" Type="N">
<Comment>
<![CDATA[Analyze incoming command for REGISTER commands
Transaction Type 4.
Adresses 3xxxxx and 4xxxxx handling
Finally calling AOI _CheckWriteReply to match the Transaction ID ot the request and mark the transaction as received and AOI _RespStrWORD to unpack the data and write it to the local arrays.
]]>
</Comment>
<Text>
<![CDATA[EQU(Wrk_MSGStep,670)MOV(680,Wrk_MSGStep)EQU(Wrk_CmdFromReadPacket,4)MOV(690,Wrk_MSGStep)[AND(Wrk_ModbusCmdString.DATA[1],255,Wrk_ModbusCmdTemp) DIV(Wrk_ModbusCmdTemp,2,Wrk_ModbusCmdLen) raC_Tec_NetModbusTCPClient_ChkWrReply(Wrk_CWR,Ref_Transactions,Wrk_ModbusTransID,Wrk_ModbusBytes,Wrk_CmdFromReadPacket,Wrk_LastTransaction) ,XIC(Wrk_CWR.TransFound) LEQ(Wrk_CWR.Count,Wrk_ModbusCmdLen) raC_Tec_NetModbusTCPClient_RespStrWord(Wrk_RSW,1,Wrk_CWR.Count,Wrk_CWR.LocalOffset,Ref_ModbusData,Wrk_ModbusCmdString) ];]]>
</Text>
</Rung>
<Rung Number="62" Type="N">
<Comment>
<![CDATA[Check for Exception Replies from the remote device.  This is indicated by the 8th bit being sent in the return transaction type.  i.e. Transaction type of 3 would be returned as 131 decimal.
]]>
</Comment>
<Text>
<![CDATA[EQU(Wrk_MSGStep,680)MOV(690,Wrk_MSGStep)XIC(Wrk_CmdFromReadPacket.7)raC_Tec_NetModbusTCPClient_ChkWrReply(Wrk_CWR,Ref_Transactions,Wrk_ModbusTransID,Wrk_ModbusBytes,Wrk_CmdFromReadPacket,Wrk_LastTransaction);]]>
</Text>
</Rung>
<Rung Number="63" Type="N">
<Comment>
<![CDATA[Finished packet processing or No Data Received]]>
</Comment>
<Text>
<![CDATA[EQU(Wrk_MSGStep,690)MOV(700,Wrk_MSGStep);]]>
</Text>
</Rung>
<Rung Number="64" Type="N">
<Comment>
<![CDATA[Incoming Packet Processing END
]]>
</Comment>
<Text>
<![CDATA[NOP();]]>
</Text>
</Rung>
<Rung Number="65" Type="N">
<Comment>
<![CDATA[All done]]>
</Comment>
<Text>
<![CDATA[EQU(Wrk_MSGStep,700)RES(Wrk_StepLockTimer)MOV(300,Wrk_MSGStep);]]>
</Text>
</Rung>
<Rung Number="66" Type="N">
<Comment>
<![CDATA[Inp_Enable removed]]>
</Comment>
<Text>
<![CDATA[EQU(Wrk_MSGStep,800)RES(Wrk_StepLockTimer)MOV(0,Wrk_ClrReqIndex)OTU(Sts_EN)OTU(Sts_Connected)OTU(Sts_Faulted)MOV(-12,Sts_LastError)MOV(810,Wrk_MSGStep);]]>
</Text>
</Rung>
<Rung Number="67" Type="N">
<Text>
<![CDATA[LBL(ClearReq)EQU(Wrk_MSGStep,810)[OTU(Ref_Transactions[Wrk_ClrReqIndex].Diagnostic.ReqBuilt) MOV(820,Wrk_MSGStep) ,LES(Wrk_ClrReqIndex,Wrk_LastTransaction) ADD(Wrk_ClrReqIndex,1,Wrk_ClrReqIndex) MOV(810,Wrk_MSGStep) JMP(ClearReq) ];]]>
</Text>
</Rung>
<Rung Number="68" Type="N">
<Text>
<![CDATA[EQU(Wrk_MSGStep,820)MOV(990,Wrk_MSGStep);]]>
</Text>
</Rung>
<Rung Number="69" Type="N">
<Comment>
<![CDATA[Create Message fail
]]>
</Comment>
<Text>
<![CDATA[EQU(Wrk_MSGStep,900)OTL(Sts_Faulted)MOV(-8,Sts_LastError)MOV(990,Wrk_MSGStep);]]>
</Text>
</Rung>
<Rung Number="70" Type="N">
<Comment>
<![CDATA[Connect Message fail
]]>
</Comment>
<Text>
<![CDATA[EQU(Wrk_MSGStep,910)OTL(Sts_Faulted)MOV(-9,Sts_LastError)MOV(990,Wrk_MSGStep);]]>
</Text>
</Rung>
<Rung Number="71" Type="N">
<Comment>
<![CDATA[Read Mseeage Fail]]>
</Comment>
<Text>
<![CDATA[EQU(Wrk_MSGStep,920)OTL(Sts_Faulted)MOV(990,Wrk_MSGStep);]]>
</Text>
</Rung>
<Rung Number="72" Type="N">
<Comment>
<![CDATA[Write Message Fail
]]>
</Comment>
<Text>
<![CDATA[EQU(Wrk_MSGStep,940)OTL(Sts_Faulted)MOV(990,Wrk_MSGStep);]]>
</Text>
</Rung>
<Rung Number="73" Type="N">
<Comment>
<![CDATA[Check if we have instance]]>
</Comment>
<Text>
<![CDATA[EQU(Wrk_MSGStep,990)FLL(0,Wrk_Main_Read_Buffer,1)OTU(Sts_Connected)[EQU(Wrk_Instance,0) MOV(0,Wrk_MSGStep) ,NEQ(Wrk_Instance,0) MOV(992,Wrk_MSGStep) ];]]>
</Text>
</Rung>
<Rung Number="74" Type="N">
<Comment>
<![CDATA[Try to Delete this instance
]]>
</Comment>
<Text>
<![CDATA[EQU(Wrk_MSGStep,992)MOV(Wrk_Instance,Ref_MsgDelete.Instance)MOV(994,Wrk_MSGStep)MSG(Ref_MsgDelete);]]>
</Text>
</Rung>
<Rung Number="75" Type="N">
<Text>
<![CDATA[EQU(Wrk_MSGStep,994)XIO(Ref_MsgDelete.EN)[XIC(Ref_MsgDelete.DN) ,XIC(Ref_MsgDelete.ER) ]CLR(Wrk_Instance)MOV(0,Wrk_MSGStep);]]>
</Text>
</Rung>
<Rung Number="76" Type="N">
<Text>
<![CDATA[MOV(0,Wrk_TimerIndex);]]>
</Text>
</Rung>
<Rung Number="77" Type="N">
<Text>
<![CDATA[LBL(Timers)[GEQ(Ref_Transactions[Wrk_TimerIndex].PollInterval,50) SUB(Ref_Transactions[Wrk_TimerIndex].PollInterval,40,Ref_Transactions[Wrk_TimerIndex].Diagnostic.IntervalTimer.PRE) ,LES(Ref_Transactions[Wrk_TimerIndex].PollInterval,50) MOV(50,Ref_Transactions[Wrk_TimerIndex].Diagnostic.IntervalTimer.PRE) ,TON(Ref_Transactions[Wrk_TimerIndex].Diagnostic.IntervalTimer,?,?) ,LES(Wrk_TimerIndex,Wrk_LastTransaction) ADD(Wrk_TimerIndex,1,Wrk_TimerIndex) JMP(Timers) ];]]>
