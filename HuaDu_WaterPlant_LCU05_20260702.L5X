</Line>
<Line Number="271">
<![CDATA[    VE_PAC_03_actuate:=VE_PAC_actuate_local[3];]]>
</Line>
<Line Number="272">
<![CDATA[    VE_PAC_04_actuate:=VE_PAC_actuate_local[4];]]>
</Line>
<Line Number="273">
<![CDATA[	P_PAC3_actuate:=RemoteIO1:2:O.Data.6;]]>
</Line>
<Line Number="274">
<![CDATA[	P_PAC4_actuate:=RemoteIO1:2:O.Data.7;]]>
</Line>
<Line Number="275">
<![CDATA[    (*手动控制时数字泵流量在此设置，自动控制时由YaoHao程序设置*)]]>
</Line>
<Line Number="276">
<![CDATA[    if (not PAC_control_auto_manual[2])]]>
</Line>
<Line Number="277">
<![CDATA[    and (not PAC_control_auto_manual[12])]]>
</Line>
<Line Number="278">
<![CDATA[    then]]>
