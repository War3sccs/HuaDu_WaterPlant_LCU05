<Text>
<![CDATA[[EQU(HMI_Tab,31) CMP(HMI.Index0x+wrk_LoopIndex<1023) ,EQU(HMI_Tab,32) CMP(HMI.Index1x+wrk_LoopIndex<1023) ]LES(wrk_LoopIndex,63)ADD(wrk_LoopIndex,1,wrk_LoopIndex)JMP(loop0x1x);]]>
