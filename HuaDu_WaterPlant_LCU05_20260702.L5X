<Line Number="203">
<![CDATA[SCL_pH_AI_6.InEUMax:=14.0;]]>
</Line>
<Line Number="204">
<![CDATA[SCL_pH_AI_6.InEUMin:=0.0;]]>
</Line>
<Line Number="205">
<![CDATA[SCL_pH_AI_6.InRawMax:=30840;]]>
