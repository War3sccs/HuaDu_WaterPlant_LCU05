<![CDATA[        P_PAC_flow_set_local[3]:=P_PAC3_flow_set;]]>
</Line>
<Line Number="283">
<![CDATA[        P_PAC_flow_set_local[4]:=P_PAC4_flow_set;]]>
</Line>
<Line Number="284">
<![CDATA[    end_if;]]>
</Line>
<Line Number="285">
<![CDATA[end_if;]]>
</Line>
<Line Number="286">
<![CDATA[]]>
</Line>
<Line Number="287">
<![CDATA[(*1号PAC池*)]]>
</Line>
<Line Number="288">
<![CDATA[if PAC_tank_local_remote[1] then]]>
</Line>
<Line Number="289">
<![CDATA[	VE_PAC_actuate_local[5]:=VE_PAC_05_actuate;]]>
</Line>
<Line Number="290">
<![CDATA[	VE_PAC_actuate_local[7]:=VE_PAC_07_actuate;]]>
</Line>
<Line Number="291">
<![CDATA[    MI_PAC_actuate_local[1]:=MI_PAC1_actuate;]]>
</Line>
<Line Number="292">
<![CDATA[    MI_PAC_actuate_local[2]:=MI_PAC2_actuate;]]>
</Line>
<Line Number="293">
<![CDATA[else]]>
</Line>
<Line Number="294">
