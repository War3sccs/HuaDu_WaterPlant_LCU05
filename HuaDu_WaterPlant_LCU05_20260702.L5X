<Routine Name="dosing_flow_set_NaOH" Type="ST">
<Description>
<![CDATA[计算各数字泵投加流量：
1、手动设置时，以触摸屏设置流量为准；
2、自动控制时，以自动计算公式计算投加流量为准。
得出计算结果后，将流量传送到相关AO模块]]>
</Description>
<STContent>
<Line Number="0">
<![CDATA[(*1#-2#投加泵流量控制*)]]>
</Line>
<Line Number="1">
<![CDATA[(*计算实时碱耗*)]]>
</Line>
<Line Number="2">
<![CDATA[YaoHao_AB_actual_NaOH:=NaOH_flow_8FT03*NaOH_density/Flow1_current_dam;]]>
</Line>
<Line Number="3">
<![CDATA[]]>
</Line>
<Line Number="4">
<![CDATA[(*计算流量*)]]>
</Line>
<Line Number="5">
<![CDATA[flow_calculate_NaOH_1:=YaoHao_AB_setting_NaOH*Flow1_current_dam/NaOH_density;]]>
</Line>
<Line Number="6">
<![CDATA[]]>
</Line>
<Line Number="7">
<![CDATA[(*3#-4#投加泵流量控制*)]]>
</Line>
<Line Number="8">
<![CDATA[(*计算实时碱耗*)]]>
</Line>
<Line Number="9">
<![CDATA[YaoHao_CD_actual_NaOH:=NaOH_flow_8FT04*NaOH_density/Flow2_current_dam;]]>
</Line>
<Line Number="10">
<![CDATA[]]>
</Line>
<Line Number="11">
<![CDATA[(*计算流量*)]]>
</Line>
<Line Number="12">
<![CDATA[flow_calculate_NaOH_2:=YaoHao_CD_setting_NaOH*Flow2_current_dam/NaOH_density;]]>
</Line>
<Line Number="13">
<![CDATA[]]>
</Line>
<Line Number="14">
<![CDATA[(*5#-6#投加泵流量控制*)]]>
</Line>
<Line Number="15">
<![CDATA[(*计算实时碱耗*)]]>
</Line>
<Line Number="16">
<![CDATA[YaoHao_filtration_actual_NaOH:=NaOH_flow_8FT05*NaOH_density/(Flow1_current_dam+Flow2_current_dam);]]>
</Line>
<Line Number="17">
<![CDATA[]]>
</Line>
<Line Number="18">
<![CDATA[(*计算流量*)]]>
</Line>
<Line Number="19">
<![CDATA[flow_calculate_NaOH_3:=YaoHao_filtration_setting_NaOH*(Flow1_current_dam+Flow2_current_dam)/NaOH_density;]]>
</Line>
<Line Number="20">
<![CDATA[]]>
</Line>
<Line Number="21">
<![CDATA[(*投加泵运行频率*)]]>
</Line>
<Line Number="22">
<![CDATA[(*1号泵组1、2号投加泵*)]]>
</Line>
<Line Number="23">
<![CDATA[(*普通自动*)]]>
</Line>
<Line Number="24">
<![CDATA[if NaOH_control_auto_manual[1] then]]>
</Line>
<Line Number="25">
<![CDATA[(*自动控制时以工频50Hz运行*)]]>
</Line>
<Line Number="26">
<![CDATA[    P_NaOH1_frequency_set:=50;]]>
</Line>
<Line Number="27">
<![CDATA[    P_NaOH2_frequency_set:=50;]]>
</Line>
<Line Number="28">
<![CDATA[end_if;]]>
</Line>
<Line Number="29">
<![CDATA[(*智慧投加*)]]>
</Line>
<Line Number="30">
<![CDATA[if NaOH_control_auto_manual[21] then]]>
</Line>
<Line Number="31">
<![CDATA[(*智慧投加时，频率由上位机设置*)]]>
</Line>
<Line Number="32">
<![CDATA[    P_NaOH1_frequency_set:=NaOH_AB_AI_frequency_set;]]>
</Line>
<Line Number="33">
<![CDATA[    P_NaOH2_frequency_set:=NaOH_AB_AI_frequency_set;]]>
</Line>
<Line Number="34">
<![CDATA[(*调流电动阀开度*)]]>
</Line>
<Line Number="35">
<![CDATA[    NaOH_flow_valve_1_set:=NaOH_AB_AI_flow_valve_set;]]>
</Line>
<Line Number="36">
<![CDATA[end_if;]]>
</Line>
<Line Number="37">
<![CDATA[(*频率转换*)]]>
</Line>
<Line Number="38">
<![CDATA[SCL(SCL_frequency_AO_1);]]>
</Line>
<Line Number="39">
<![CDATA[SCL_frequency_AO_1.In:=P_NaOH1_frequency_set;]]>
</Line>
<Line Number="40">
<![CDATA[SCL(SCL_frequency_AO_2);]]>
</Line>
<Line Number="41">
<![CDATA[SCL_frequency_AO_2.In:=P_NaOH2_frequency_set;]]>
</Line>
<Line Number="42">
<![CDATA[]]>
</Line>
<Line Number="43">
<![CDATA[]]>
</Line>
<Line Number="44">
<![CDATA[(*2号泵组3、4号投加泵*)]]>
</Line>
<Line Number="45">
<![CDATA[if NaOH_control_auto_manual[2] then]]>
</Line>
<Line Number="46">
<![CDATA[(*自动控制时以工频50Hz运行*)]]>
</Line>
<Line Number="47">
<![CDATA[    P_NaOH3_frequency_set:=50;]]>
</Line>
<Line Number="48">
<![CDATA[    P_NaOH4_frequency_set:=50;]]>
</Line>
<Line Number="49">
<![CDATA[end_if;]]>
</Line>
<Line Number="50">
<![CDATA[(*智慧投加*)]]>
</Line>
<Line Number="51">
<![CDATA[if NaOH_control_auto_manual[22] then]]>
</Line>
<Line Number="52">
<![CDATA[(*智慧投加时，频率由上位机设置*)]]>
</Line>
<Line Number="53">
<![CDATA[    P_NaOH3_frequency_set:=NaOH_CD_AI_frequency_set;]]>
</Line>
<Line Number="54">
<![CDATA[    P_NaOH4_frequency_set:=NaOH_CD_AI_frequency_set;]]>
</Line>
<Line Number="55">
<![CDATA[(*调流电动阀开度*)]]>
</Line>
<Line Number="56">
<![CDATA[    NaOH_flow_valve_2_set:=NaOH_CD_AI_flow_valve_set;]]>
</Line>
<Line Number="57">
<![CDATA[end_if;]]>
</Line>
<Line Number="58">
<![CDATA[(*频率转换*)]]>
</Line>
<Line Number="59">
<![CDATA[SCL(SCL_frequency_AO_3);]]>
</Line>
<Line Number="60">
<![CDATA[SCL_frequency_AO_3.In:=P_NaOH3_frequency_set;]]>
</Line>
<Line Number="61">
<![CDATA[SCL(SCL_frequency_AO_4);]]>
</Line>
<Line Number="62">
<![CDATA[SCL_frequency_AO_4.In:=P_NaOH4_frequency_set;]]>
</Line>
<Line Number="63">
<![CDATA[]]>
</Line>
<Line Number="64">
<![CDATA[(*3号泵组5、6号投加泵*)]]>
</Line>
<Line Number="65">
<![CDATA[if NaOH_control_auto_manual[3] then]]>
</Line>
<Line Number="66">
<![CDATA[(*自动控制时以工频50Hz运行*)]]>
</Line>
<Line Number="67">
<![CDATA[    P_NaOH5_frequency_set:=50;]]>
</Line>
<Line Number="68">
<![CDATA[    P_NaOH6_frequency_set:=50;]]>
</Line>
<Line Number="69">
<![CDATA[end_if;]]>
</Line>
<Line Number="70">
<![CDATA[(*智慧投加*)]]>
</Line>
<Line Number="71">
<![CDATA[if NaOH_control_auto_manual[23] then]]>
</Line>
<Line Number="72">
<![CDATA[(*智慧投加时，频率由上位机设置*)]]>
</Line>
<Line Number="73">
<![CDATA[    P_NaOH5_frequency_set:=NaOH_filtration_AI_frequency_set;]]>
</Line>
<Line Number="74">
<![CDATA[    P_NaOH6_frequency_set:=NaOH_filtration_AI_frequency_set;]]>
</Line>
<Line Number="75">
<![CDATA[(*调流电动阀开度*)]]>
</Line>
<Line Number="76">
<![CDATA[    NaOH_flow_valve_3_set:=NaOH_filtration_AI_flow_valve_set;]]>
</Line>
<Line Number="77">
<![CDATA[end_if;]]>
</Line>
<Line Number="78">
<![CDATA[(*频率转换*)]]>
</Line>
<Line Number="79">
<![CDATA[SCL(SCL_frequency_AO_5);]]>
</Line>
<Line Number="80">
<![CDATA[SCL_frequency_AO_5.In:=P_NaOH5_frequency_set;]]>
</Line>
<Line Number="81">
<![CDATA[SCL(SCL_frequency_AO_6);]]>
</Line>
<Line Number="82">
<![CDATA[SCL_frequency_AO_6.In:=P_NaOH6_frequency_set;]]>
</Line>
<Line Number="83">
<![CDATA[]]>
</Line>
<Line Number="84">
<![CDATA[]]>
</Line>
<Line Number="85">
<![CDATA[]]>
</Line>
</STContent>
</Routine>
<Routine Name="MainRoutine" Type="RLL">
<Description>
<![CDATA[主程序]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[NaOH系统4-20mA输入输出参数重置为默认值。]]>
</Comment>
<Text>
<![CDATA[XIC(analog_IO_setting_reset[2])JSR(analog_IO_setting_NaOH,0);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[将I/O输入的数值，同步到系统变量，方便触摸屏及上位机读取]]>
</Comment>
<Text>
<![CDATA[JSR(synchronize_NaOH,0);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[将4个NaOH储罐当前液位，与液位过高报警值、液位过低报警值对照，如果液位过高、过低，则发出报警。
如果液位过高，则自动关闭进液阀。如果液位过低，则自动关闭出液位。]]>
</Comment>
<Text>
<![CDATA[JSR(tank_control_NaOH,0);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[投加泵的启动/停止控制]]>
</Comment>
<Text>
<![CDATA[JSR(pump_action_NaOH,0);]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Comment>
<![CDATA[计算各数字泵投加流量，并传到相关AO模块输出。]]>
</Comment>
<Text>
<![CDATA[JSR(dosing_flow_set_NaOH,0);]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Comment>
<![CDATA[阀门动作控制]]>
</Comment>
<Text>
<![CDATA[JSR(valve_action_NaOH,0);]]>
</Text>
</Rung>
<Rung Number="6" Type="N">
<Comment>
<![CDATA[将计算得出的数字泵流量设置值传送到AO模块]]>
</Comment>
<Text>
<![CDATA[MOV(SCL_frequency_AO_1.Out,RemoteIO2:6:O.Ch0Data)MOV(SCL_frequency_AO_2.Out,RemoteIO2:6:O.Ch1Data)MOV(SCL_frequency_AO_3.Out,RemoteIO2:6:O.Ch2Data)MOV(SCL_frequency_AO_4.Out,RemoteIO2:6:O.Ch3Data)MOV(SCL_frequency_AO_5.Out,RemoteIO2:6:O.Ch4Data)MOV(SCL_frequency_AO_6.Out,RemoteIO2:6:O.Ch5Data);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="pump_action_NaOH" Type="RLL">
<Description>
<![CDATA[控制投加泵/转运泵的启动/停止]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[1#投加泵控制]]>
</Comment>
<Text>
<![CDATA[dosing_pump_start_stop_NaOH(dosing_pump_control_NaOH_1,VE_NaOH_21_open,VE_NaOH_22_open,VE_NaOH_15_open,P_NaOH1_actuate,RemoteIO2:1:O.Data.0);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[2#投加泵控制]]>
</Comment>
<Text>
<![CDATA[dosing_pump_start_stop_NaOH(dosing_pump_control_NaOH_2,VE_NaOH_21_open,VE_NaOH_22_open,VE_NaOH_16_open,P_NaOH2_actuate,RemoteIO2:1:O.Data.2);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[3#投加泵控制]]>
</Comment>
<Text>
<![CDATA[dosing_pump_start_stop_NaOH(dosing_pump_control_NaOH_3,VE_NaOH_21_open,VE_NaOH_22_open,VE_NaOH_17_open,P_NaOH3_actuate,RemoteIO2:1:O.Data.4);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[4#投加泵控制]]>
</Comment>
<Text>
<![CDATA[dosing_pump_start_stop_NaOH(dosing_pump_control_NaOH_4,VE_NaOH_21_open,VE_NaOH_22_open,VE_NaOH_18_open,P_NaOH4_actuate,RemoteIO2:1:O.Data.6);]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Comment>
<![CDATA[5#投加泵控制]]>
</Comment>
<Text>
<![CDATA[dosing_pump_start_stop_NaOH(dosing_pump_control_NaOH_5,VE_NaOH_21_open,VE_NaOH_22_open,VE_NaOH_19_open,P_NaOH5_actuate,RemoteIO2:1:O.Data.8);]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Comment>
<![CDATA[6#投加泵控制]]>
</Comment>
<Text>
<![CDATA[dosing_pump_start_stop_NaOH(dosing_pump_control_NaOH_6,VE_NaOH_21_open,VE_NaOH_22_open,VE_NaOH_20_open,P_NaOH6_actuate,RemoteIO2:1:O.Data.10);]]>
</Text>
</Rung>
<Rung Number="6" Type="N">
<Comment>
<![CDATA[1#转运泵启动/停止控制，确保泵启动前，上游所有阀门都已经开到位。]]>
</Comment>
<Text>
<![CDATA[XIC(P_NaClO7_actuate)[XIC(VE_NaOH_29_open) ,XIC(VE_NaOH_33_open) XIC(VE_NaOH_30_open) ]XIC(VE_NaOH_31_open)OTE(RemoteIO2:1:O.Data.12);]]>
</Text>
</Rung>
<Rung Number="7" Type="N">
<Comment>
<![CDATA[1#转运泵启动/停止控制，确保泵启动前，上游所有阀门都已经开到位。]]>
</Comment>
<Text>
<![CDATA[XIC(P_NaClO8_actuate)[XIC(VE_NaOH_30_open) ,XIC(VE_NaOH_33_open) XIC(VE_NaOH_29_open) ]XIC(VE_NaOH_32_open)OTE(RemoteIO2:1:O.Data.13);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="synchronize_NaOH" Type="ST">
<Description>
<![CDATA[同步I/O输入的数值。]]>
</Description>
<STContent>
<Line Number="0">
<![CDATA[(*投加泵故障状态*)]]>
</Line>
<Line Number="1">
<![CDATA[P_NaOH1_err:=RemoteIO1:5:I.Data.0;]]>
</Line>
<Line Number="2">
<![CDATA[P_NaOH2_err:=RemoteIO1:5:I.Data.1;]]>
</Line>
<Line Number="3">
<![CDATA[P_NaOH3_err:=RemoteIO1:5:I.Data.2;]]>
</Line>
<Line Number="4">
<![CDATA[P_NaOH4_err:=RemoteIO1:5:I.Data.3;]]>
</Line>
<Line Number="5">
<![CDATA[P_NaOH5_err:=RemoteIO1:5:I.Data.4;]]>
</Line>
<Line Number="6">
<![CDATA[P_NaOH6_err:=RemoteIO1:5:I.Data.5;]]>
</Line>
<Line Number="7">
<![CDATA[]]>
</Line>
<Line Number="8">
<![CDATA[(*投加泵运行状态*)]]>
</Line>
<Line Number="9">
<![CDATA[P_NaOH1_run:=RemoteIO1:5:I.Data.6;]]>
</Line>
<Line Number="10">
<![CDATA[P_NaOH2_run:=RemoteIO1:5:I.Data.7;]]>
</Line>
<Line Number="11">
<![CDATA[P_NaOH3_run:=RemoteIO1:5:I.Data.8;]]>
</Line>
<Line Number="12">
<![CDATA[P_NaOH4_run:=RemoteIO1:5:I.Data.9;]]>
</Line>
<Line Number="13">
<![CDATA[P_NaOH5_run:=RemoteIO1:5:I.Data.10;]]>
</Line>
<Line Number="14">
<![CDATA[P_NaOH6_run:=RemoteIO1:5:I.Data.11;]]>
</Line>
<Line Number="15">
<![CDATA[]]>
</Line>
<Line Number="16">
<![CDATA[(*转运泵运行状态*)]]>
</Line>
<Line Number="17">
<![CDATA[P_NaOH7_run:=RemoteIO1:5:I.Data.12;]]>
</Line>
<Line Number="18">
<![CDATA[P_NaOH8_run:=RemoteIO1:5:I.Data.13;]]>
</Line>
<Line Number="19">
<![CDATA[]]>
</Line>
<Line Number="20">
<![CDATA[(*卸料泵运行状态*)]]>
</Line>
<Line Number="21">
<![CDATA[P_NaOH9_run:=RemoteIO1:5:I.Data.14;]]>
</Line>
<Line Number="22">
<![CDATA[P_NaOH10_run:=RemoteIO1:5:I.Data.15;]]>
</Line>
<Line Number="23">
<![CDATA[]]>
</Line>
