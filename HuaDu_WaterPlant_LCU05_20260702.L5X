</Line>
<Line Number="159">
<![CDATA[	RemoteIO2:2:O.Data.10:=0;]]>
</Line>
<Line Number="160">
<![CDATA[else]]>
</Line>
<Line Number="161">
<![CDATA[	RemoteIO2:2:O.Data.10:=VE_NaOH_29_actuate;]]>
</Line>
<Line Number="162">
<![CDATA[end_if;]]>
</Line>
<Line Number="163">
<![CDATA[(*4#罐的出口阀*)]]>
</Line>
<Line Number="164">
<![CDATA[if NaOH_level_low_alarm_4 or NaOH_tank_standby[4] then]]>
</Line>
<Line Number="165">
<![CDATA[	RemoteIO2:2:O.Data.11:=0;]]>
</Line>
<Line Number="166">
<![CDATA[else]]>
</Line>
<Line Number="167">
<![CDATA[	RemoteIO2:2:O.Data.11:=VE_NaOH_30_actuate;]]>
</Line>
<Line Number="168">
<![CDATA[end_if;]]>
</Line>
<Line Number="169">
<![CDATA[]]>
