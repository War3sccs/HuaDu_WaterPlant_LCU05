<Line Number="227">
<![CDATA[(*1号泵组*)]]>
</Line>
<Line Number="228">
<![CDATA[if PAC_control_local_remote[1] then]]>
</Line>
<Line Number="229">
<![CDATA[	P_PAC_actuate_local[1]:=P_PAC1_actuate;]]>
</Line>
<Line Number="230">
<![CDATA[	P_PAC_actuate_local[2]:=P_PAC2_actuate;]]>
</Line>
<Line Number="231">
<![CDATA[	VE_PAC_actuate_local[1]:=VE_PAC_01_actuate;]]>
</Line>
<Line Number="232">
<![CDATA[	VE_PAC_actuate_local[2]:=VE_PAC_02_actuate;]]>
</Line>
<Line Number="233">
<![CDATA[	P_PAC_actuate_local[1]:=RemoteIO1:2:O.Data.4;]]>
</Line>
<Line Number="234">
<![CDATA[	P_PAC_actuate_local[2]:=RemoteIO1:2:O.Data.5;]]>
</Line>
<Line Number="235">
<![CDATA[    (*手动控制时数字泵流量在此设置，自动控制时由YaoHao程序设置*)]]>
</Line>
<Line Number="236">
<![CDATA[    P_PAC_flow_set_local[1]:=P_PAC1_flow_set;]]>
</Line>
<Line Number="237">
<![CDATA[    P_PAC_flow_set_local[2]:=P_PAC2_flow_set;]]>
</Line>
<Line Number="238">
<![CDATA[else]]>
</Line>
<Line Number="239">
<![CDATA[	P_PAC1_actuate:=P_PAC_actuate_local[1];]]>
</Line>
<Line Number="240">
<![CDATA[	P_PAC2_actuate:=P_PAC_actuate_local[2];]]>
</Line>
<Line Number="241">
<![CDATA[    VE_PAC_01_actuate:=VE_PAC_actuate_local[1];]]>
</Line>
<Line Number="242">
<![CDATA[    VE_PAC_02_actuate:=VE_PAC_actuate_local[2];]]>
</Line>
<Line Number="243">
<![CDATA[	P_PAC1_actuate:=RemoteIO1:2:O.Data.4;]]>
</Line>
<Line Number="244">
<![CDATA[	P_PAC2_actuate:=RemoteIO1:2:O.Data.5;]]>
</Line>
<Line Number="245">
<![CDATA[    (*手动控制时数字泵流量在此设置，自动控制时由YaoHao程序设置*)]]>
</Line>
<Line Number="246">
<![CDATA[    if (not PAC_control_auto_manual[1])]]>
</Line>
<Line Number="247">
<![CDATA[    and (not PAC_control_auto_manual[11])]]>
</Line>
<Line Number="248">
<![CDATA[    then]]>
</Line>
<Line Number="249">
<![CDATA[        P_PAC1_flow_set:=P_PAC_flow_set_local[1];]]>
</Line>
<Line Number="250">
<![CDATA[        P_PAC2_flow_set:=P_PAC_flow_set_local[2];]]>
</Line>
<Line Number="251">
<![CDATA[    else]]>
</Line>
<Line Number="252">
<![CDATA[        P_PAC_flow_set_local[1]:=P_PAC1_flow_set;]]>
</Line>
<Line Number="253">
<![CDATA[        P_PAC_flow_set_local[2]:=P_PAC2_flow_set;]]>
</Line>
<Line Number="254">
<![CDATA[    end_if;]]>
</Line>
<Line Number="255">
<![CDATA[end_if;]]>
</Line>
<Line Number="256">
<![CDATA[]]>
