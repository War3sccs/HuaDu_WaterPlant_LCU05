<AddOnInstructionDefinition Name="flow_deviation" Revision="1.0" ExecutePrescan="false" ExecutePostscan="false" ExecuteEnableInFalse="false" CreatedDate="2024-09-01T11:17:36.900Z" CreatedBy="PC-XINGUANG\wymwym" EditedDate="2024-10-16T09:25:43.712Z" EditedBy="PC-XINGUANG\wymwym" SoftwareRevision="v34.00">
<Description>
<![CDATA[流量计、数字泵反馈的流量数值，如果偏差大于设定值，则自动触发系统偏流报警。]]>
</Description>
<Parameters>
<Parameter Name="EnableIn" TagType="Base" DataType="BOOL" Usage="Input" Radix="Decimal" Required="false" Visible="false" ExternalAccess="Read Only">
<Description>
<![CDATA[Enable Input - System Defined Parameter]]>
</Description>
</Parameter>
<Parameter Name="EnableOut" TagType="Base" DataType="BOOL" Usage="Output" Radix="Decimal" Required="false" Visible="false" ExternalAccess="Read Only">
<Description>
<![CDATA[Enable Output - System Defined Parameter]]>
</Description>
</Parameter>
<Parameter Name="deviation" TagType="Base" DataType="REAL" Usage="Input" Radix="Float" Required="true" Visible="true" ExternalAccess="Read/Write">
<DefaultData Format="L5K">
<![CDATA[0.00000000e+000]]>
</DefaultData>
<DefaultData Format="Decorated">
<DataValue DataType="REAL" Radix="Float" Value="0.0"/>
</DefaultData>
</Parameter>
<Parameter Name="flow_pump_1" TagType="Base" DataType="REAL" Usage="Input" Radix="Float" Required="true" Visible="true" ExternalAccess="Read/Write">
<DefaultData Format="L5K">
<![CDATA[0.00000000e+000]]>
</DefaultData>
<DefaultData Format="Decorated">
<DataValue DataType="REAL" Radix="Float" Value="0.0"/>
</DefaultData>
</Parameter>
<Parameter Name="flow_pump_2" TagType="Base" DataType="REAL" Usage="Input" Radix="Float" Required="true" Visible="true" ExternalAccess="Read/Write">
<DefaultData Format="L5K">
<![CDATA[0.00000000e+000]]>
</DefaultData>
<DefaultData Format="Decorated">
<DataValue DataType="REAL" Radix="Float" Value="0.0"/>
</DefaultData>
</Parameter>
<Parameter Name="flow_meter" TagType="Base" DataType="REAL" Usage="Input" Radix="Float" Required="true" Visible="true" ExternalAccess="Read/Write">
<DefaultData Format="L5K">
<![CDATA[0.00000000e+000]]>
</DefaultData>
<DefaultData Format="Decorated">
<DataValue DataType="REAL" Radix="Float" Value="0.0"/>
</DefaultData>
</Parameter>
<Parameter Name="run_pump_1" TagType="Base" DataType="BOOL" Usage="Input" Radix="Decimal" Required="true" Visible="true" ExternalAccess="Read/Write">
<DefaultData Format="L5K">
<![CDATA[0]]>
</DefaultData>
<DefaultData Format="Decorated">
<DataValue DataType="BOOL" Radix="Decimal" Value="0"/>
</DefaultData>
</Parameter>
<Parameter Name="run_pump_2" TagType="Base" DataType="BOOL" Usage="Input" Radix="Decimal" Required="true" Visible="true" ExternalAccess="Read/Write">
<DefaultData Format="L5K">
<![CDATA[0]]>
</DefaultData>
<DefaultData Format="Decorated">
<DataValue DataType="BOOL" Radix="Decimal" Value="0"/>
</DefaultData>
</Parameter>
<Parameter Name="deviation_pump_1" TagType="Base" DataType="BOOL" Usage="Output" Radix="Decimal" Required="true" Visible="true" ExternalAccess="Read/Write">
<DefaultData Format="L5K">
<![CDATA[0]]>
</DefaultData>
<DefaultData Format="Decorated">
<DataValue DataType="BOOL" Radix="Decimal" Value="0"/>
</DefaultData>
</Parameter>
<Parameter Name="deviation_pump_2" TagType="Base" DataType="BOOL" Usage="Output" Radix="Decimal" Required="true" Visible="true" ExternalAccess="Read/Write">
<DefaultData Format="L5K">
<![CDATA[0]]>
</DefaultData>
<DefaultData Format="Decorated">
<DataValue DataType="BOOL" Radix="Decimal" Value="0"/>
</DefaultData>
</Parameter>
<Parameter Name="deviation_meter" TagType="Base" DataType="BOOL" Usage="Output" Radix="Decimal" Required="true" Visible="true" ExternalAccess="Read/Write">
<DefaultData Format="L5K">
<![CDATA[0]]>
</DefaultData>
<DefaultData Format="Decorated">
<DataValue DataType="BOOL" Radix="Decimal" Value="0"/>
</DefaultData>
</Parameter>
<Parameter Name="pump_flow_set_1" TagType="Base" DataType="REAL" Usage="Input" Radix="Float" Required="true" Visible="true" ExternalAccess="Read/Write">
<DefaultData Format="L5K">
<![CDATA[0.00000000e+000]]>
</DefaultData>
<DefaultData Format="Decorated">
<DataValue DataType="REAL" Radix="Float" Value="0.0"/>
</DefaultData>
</Parameter>
<Parameter Name="pump_flow_set_2" TagType="Base" DataType="REAL" Usage="Input" Radix="Float" Required="true" Visible="true" ExternalAccess="Read/Write">
<DefaultData Format="L5K">
<![CDATA[0.00000000e+000]]>
</DefaultData>
<DefaultData Format="Decorated">
<DataValue DataType="REAL" Radix="Float" Value="0.0"/>
</DefaultData>
</Parameter>
</Parameters>
<LocalTags/>
<Routines>
<Routine Name="Logic" Type="ST">
<STContent>
<Line Number="0">
<![CDATA[if (flow_pump_1+flow_pump_2-flow_meter)/(flow_pump_1+flow_pump_2)>deviation then]]>
</Line>
<Line Number="1">
<![CDATA[	if run_pump_1 and not run_pump_2 then]]>
</Line>
<Line Number="2">
<![CDATA[		deviation_pump_1 :=1;]]>
</Line>
<Line Number="3">
<![CDATA[		deviation_meter :=1;]]>
</Line>
<Line Number="4">
<![CDATA[	end_if;]]>
</Line>
<Line Number="5">
<![CDATA[	if not run_pump_1 and run_pump_2 then]]>
</Line>
<Line Number="6">
<![CDATA[		deviation_pump_2 :=1;]]>
</Line>
<Line Number="7">
<![CDATA[		deviation_meter :=1;]]>
</Line>
<Line Number="8">
<![CDATA[	end_if;]]>
</Line>
<Line Number="9">
<![CDATA[	if run_pump_1 and run_pump_2 then]]>
</Line>
<Line Number="10">
<![CDATA[		deviation_meter :=1;]]>
</Line>
<Line Number="11">
<![CDATA[	end_if;]]>
</Line>
<Line Number="12">
<![CDATA[else]]>
</Line>
<Line Number="13">
<![CDATA[	deviation_pump_1:=0;]]>
</Line>
<Line Number="14">
<![CDATA[	deviation_pump_2:=0;]]>
</Line>
<Line Number="15">
<![CDATA[	deviation_meter:=0;]]>
</Line>
<Line Number="16">
<![CDATA[end_if;]]>
</Line>
<Line Number="17">
<![CDATA[]]>
</Line>
<Line Number="18">
<![CDATA[(*if run_pump_1 then]]>
</Line>
<Line Number="19">
<![CDATA[	if (pump_flow_set_1-flow_pump_1)/pump_flow_set_1>deviation then]]>
</Line>
<Line Number="20">
<![CDATA[		deviation_pump_1 :=1;]]>
</Line>
<Line Number="21">
<![CDATA[	end_if;]]>
</Line>
<Line Number="22">
<![CDATA[end_if;*)]]>
</Line>
<Line Number="23">
<![CDATA[]]>
</Line>
<Line Number="24">
<![CDATA[(*if run_pump_2 then]]>
</Line>
<Line Number="25">
<![CDATA[	if (pump_flow_set_2-flow_pump_2)/pump_flow_set_2>deviation then]]>
</Line>
<Line Number="26">
<![CDATA[		deviation_pump_2 :=1;]]>
</Line>
<Line Number="27">
<![CDATA[	end_if;]]>
</Line>
<Line Number="28">
<![CDATA[end_if;*)]]>
</Line>
</STContent>
</Routine>
</Routines>
</AddOnInstructionDefinition>
