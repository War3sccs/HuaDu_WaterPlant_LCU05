<Text>
<![CDATA[XIC(VE_NaClO11_close)XIC(VE_NaClO12_close)XIC(VE_NaClO13_close)XIC(VE_NaClO14_close)XIC(VE_NaClO15_close)XIC(VE_NaClO16_close)XIC(VE_NaClO17_close)XIC(VE_NaClO18_close)OTE(NaClO_tank_valve_alarm);]]>
</Text>
</Rung>
