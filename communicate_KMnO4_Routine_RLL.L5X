<AddOnInstructionDefinition Name="raC_Opr_NetModbusTCPClient" Revision="2.4" RevisionExtension="0" ExecutePrescan="true" ExecutePostscan="false" ExecuteEnableInFalse="false" CreatedDate="2019-12-05T18:51:23.267Z" CreatedBy="Not Available" EditedDate="2022-10-03T11:55:03.899Z" EditedBy="Not Available" SoftwareRevision="v31.02"
>
<Description>
<![CDATA[Modbus TCP Client]]>
</Description>
<RevisionNote>
<![CDATA[2.0.0 Initial Release in AOI format
2.0.1 Corrected local IP address logic
2.1.0 Corrected Overload and Overlap indicators
2.2.0 Changed BeginAddress from INT to DINT, force LocalSlot 0 for CompactLogix
2.3.0 HMI interface
2.4.0 Improved malformed packet handling]]>
</RevisionNote>
<Parameters>
<Parameter Name="EnableIn" TagType="Base" DataType="BOOL" Usage="Input" Radix="Decimal" Required="false" Visible="false" ExternalAccess="Read Only">
<Description>
<![CDATA[Enable Input - System Defined Parameter]]>
</Description>
</Parameter>
