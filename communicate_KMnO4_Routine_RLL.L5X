</Rung>
<Rung Number="1" Type="N">
<Text>
<![CDATA[LBL(Loop1)XIC(Transactions[Wrk_TransactionPtr].Enabled)EQU(TransactionID,Transactions[Wrk_TransactionPtr].Diagnostic.TransID)[XIO(Command.7) CLR(Transactions[Wrk_TransactionPtr].TransStat) CLR(Transactions[Wrk_TransactionPtr].Diagnostic.TransLastError) ,XIC(Command.7) MOV(-1,Transactions[Wrk_TransactionPtr].TransStat) MOV(ModbusBytes,Transactions[Wrk_TransactionPtr].Diagnostic.TransLastError) ]MOV(Transactions[Wrk_TransactionPtr].LocalAddress,LocalOffset)MOV(Transactions[Wrk_TransactionPtr].Count,Count)[OTL(Transactions[Wrk_TransactionPtr].TransComplete) ,OTU(Transactions[Wrk_TransactionPtr].Diagnostic.ReqBuilt) ,OTU(Transactions[Wrk_TransactionPtr].Diagnostic.Overload) ,OTL(TransFound) ];]]>
</Text>
