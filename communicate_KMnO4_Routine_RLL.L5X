<Routines Use="Context">
<Routine Use="Target" Name="communicate_KMnO4" Type="RLL">
<Description>
<![CDATA[与2套KMnO4制备装置通讯。以及测试和活性炭西门子PLC的通讯]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[读写KMnO4制备装置参数]]>
</Comment>
<Text>
<![CDATA[XIO(communicate_to_Micro850.DN)TON(communicate_to_Micro850,?,?);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[读写KMnO4制备装置参数]]>
</Comment>
<Text>
<![CDATA[XIC(communicate_to_Micro850.DN)XIO(KMnO4_solution_system_1.EN)MSG(KMnO4_solution_system_1);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
