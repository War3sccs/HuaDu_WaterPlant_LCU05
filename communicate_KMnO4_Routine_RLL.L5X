<DataType Name="raC_UDT_ModbusClientTransaction" Family="NoFamily" Class="User">
<Members>
<Member Name="ZZZZZZZZZZraC_UDT_Mo0" DataType="SINT" Dimension="0" Radix="Decimal" Hidden="true" ExternalAccess="Read/Write"/>
<Member Name="Enabled" DataType="BIT" Dimension="0" Radix="Decimal" Hidden="false" Target="ZZZZZZZZZZraC_UDT_Mo0" BitNumber="0" ExternalAccess="Read/Write">
<Description>
<![CDATA[Enables (1) or disables (0) the transaction]]>
</Description>
</Member>
<Member Name="PollInterval" DataType="DINT" Dimension="0" Radix="Decimal" Hidden="false" ExternalAccess="Read/Write">
<Description>
<![CDATA[Time between triggers in milliseconds. Minimum is 80 msec. Anyting below 80 will be set to 1 seconds]]>
</Description>
</Member>
<Member Name="TransType" DataType="INT" Dimension="0" Radix="Decimal" Hidden="false" ExternalAccess="Read/Write">
<Description>
<![CDATA[Transaction code for the Modbus Protocol. Acceptable values are 1-Coil Read, 2- Discrete Input read, 3-Holding Register Read, 4-Input Register Read, 5-Write Single Coil, 6-Single Holding Register Write, 15-Multiple Coil Write, 16 Multiple Holding Register Write]]>
</Description>
</Member>
<Member Name="StationID" DataType="SINT" Dimension="0" Radix="Decimal" Hidden="false" ExternalAccess="Read/Write">
<Description>
<![CDATA[Station ID ( Unit Identifier).
Commonly used if going through a gateway or bridge in which case it is the device address on the other side of the gateway.  Other wise leave as 0]]>
</Description>
</Member>
<Member Name="BeginAddress" DataType="DINT" Dimension="0" Radix="Decimal" Hidden="false" ExternalAccess="Read/Write">
<Description>
<![CDATA[Beginning address in remote device to read from or write to.]]>
</Description>
</Member>
<Member Name="Count" DataType="INT" Dimension="0" Radix="Decimal" Hidden="false" ExternalAccess="Read/Write">
<Description>
<![CDATA[The number of items in remote device to read from or write to.]]>
</Description>
</Member>
<Member Name="LocalAddress" DataType="INT" Dimension="0" Radix="Decimal" Hidden="false" ExternalAccess="Read/Write">
<Description>
<![CDATA[Beginning address in in this programs' "_Data" arrays]]>
</Description>
</Member>
<Member Name="ZZZZZZZZZZraC_UDT_Mo8" DataType="SINT" Dimension="0" Radix="Decimal" Hidden="true" ExternalAccess="Read/Write"/>
<Member Name="TransComplete" DataType="BIT" Dimension="0" Radix="Decimal" Hidden="false" Target="ZZZZZZZZZZraC_UDT_Mo8" BitNumber="0" ExternalAccess="Read/Write">
<Description>
<![CDATA[Transaction Complete Flag.  Check the TransStat to see if the transaction was successful or if a Modbus exception code was returned.]]>
</Description>
</Member>
<Member Name="TransStat" DataType="INT" Dimension="0" Radix="Decimal" Hidden="false" ExternalAccess="Read/Write">
<Description>
<![CDATA[Status result of the transaction.  
0 = success, 
1 = in process
2 = retry
-1 = exception]]>
</Description>
</Member>
<Member Name="Diagnostic" DataType="raC_UDT_ModbusClientTransactionDiag" Dimension="0" Radix="NullType" Hidden="false" ExternalAccess="Read/Write"/>
</Members>
