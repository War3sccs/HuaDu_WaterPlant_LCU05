<LocalTags/>
<Routines>
<Routine Name="Logic" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[投加泵启动的条件：1、至少有1个NaOH池出药阀开到位；3、泵入口电动阀开到位。]]>
</Comment>
<Text>
<![CDATA[XIC(start_stop_command)[XIC(tank_valve_1) ,XIC(tank_valve_2) ]XIC(pump_valve_in_status)OTE(start_stop_action);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[投加泵启动时，自动将泵进口电动阀打开]]>
</Comment>
<Text>
<![CDATA[XIC(start_stop_command)OTL(pump_valve_in_status);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
</Routines>
</AddOnInstructionDefinition>
