<Routine Name="MainRoutine" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[设置PAC系统4-20mA输入输出参数。]]>
</Comment>
<Text>
<![CDATA[JSR(analog_IO_setting_PAC,0);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[将I/O输入的数值，同步到系统变量，方便触摸屏及上位机读取]]>
</Comment>
<Text>
<![CDATA[JSR(synchronize_PAC,0);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[将4个PAC池当前液位，与液位过高报警值、液位过低报警值对照，如果液位过高、过低，则发出报警。
如果液位过高，则自动关闭进液阀。如果液位过低，则自动关闭出液位。]]>
</Comment>
<Text>
<![CDATA[JSR(tank_control_PAC,0);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[数字泵的启动/停止控制]]>
</Comment>
<Text>
<![CDATA[JSR(pump_action_PAC,0);]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Comment>
<![CDATA[计算各数字泵投加流量，并传到相关AO模块输出。]]>
</Comment>
<Text>
<![CDATA[JSR(dosing_flow_set_PAC,0);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="pump_action_PAC" Type="RLL">
<Description>
<![CDATA[控制数字泵的启动/停止]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[1#数字泵控制]]>
</Comment>
<Text>
<![CDATA[pump_start_stop_PAC(PAC_pump_action_1,VE_PAC_11_open,VE_PAC_07_open,VE_PAC_08_open,VE_PAC_09_open,VE_PAC_10_open,VE_PAC_01_open,P_PAC1_actuate,RemoteIO1:2:O.Data.4,VE_PAC_01_actuate);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[2#数字泵控制]]>
</Comment>
<Text>
<![CDATA[pump_start_stop_PAC(PAC_pump_action_2,VE_PAC_11_open,VE_PAC_07_open,VE_PAC_08_open,VE_PAC_09_open,VE_PAC_10_open,VE_PAC_02_open,P_PAC2_actuate,RemoteIO1:2:O.Data.5,VE_PAC_02_actuate);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[3#数字泵控制]]>
</Comment>
<Text>
<![CDATA[pump_start_stop_PAC(PAC_pump_action_3,VE_PAC_11_open,VE_PAC_07_open,VE_PAC_08_open,VE_PAC_09_open,VE_PAC_10_open,VE_PAC_03_open,P_PAC3_actuate,RemoteIO1:2:O.Data.6,VE_PAC_03_actuate);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[4#数字泵控制]]>
</Comment>
<Text>
<![CDATA[pump_start_stop_PAC(PAC_pump_action_4,VE_PAC_11_open,VE_PAC_07_open,VE_PAC_08_open,VE_PAC_09_open,VE_PAC_10_open,VE_PAC_04_open,P_PAC4_actuate,RemoteIO1:2:O.Data.7,VE_PAC_04_actuate);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
