<AddOnInstructionDefinitions>
<AddOnInstructionDefinition Name="dosing_flow_setting" Revision="1.0" ExecutePrescan="false" ExecutePostscan="false" ExecuteEnableInFalse="false" CreatedDate="2024-03-22T01:28:55.217Z" CreatedBy="DESKTOP-EB2DFQ8\wymwym" EditedDate="2024-03-22T04:47:30.878Z" EditedBy="DESKTOP-EB2DFQ8\wymwym" SoftwareRevision="v34.00">
<Description>
<![CDATA[计算投加流量：
1、手动设置时，以触摸屏设置流量为准；
2、自动控制时，以自动计算公式计算投加流量为准。]]>
</Description>
<Parameters>
<Parameter Name="EnableIn" TagType="Base" DataType="BOOL" Usage="Input" Radix="Decimal" Required="false" Visible="false" ExternalAccess="Read Only">
<Description>
<![CDATA[Enable Input - System Defined Parameter]]>
</Description>
</Parameter>
<Parameter Name="EnableOut" TagType="Base" DataType="BOOL" Usage="Output" Radix="Decimal" Required="false" Visible="false" ExternalAccess="Read Only">
<Description>
<![CDATA[Enable Output - System Defined Parameter]]>
</Description>
</Parameter>
<Parameter Name="auto_manual_switch" TagType="Base" DataType="BOOL" Usage="Input" Radix="Decimal" Required="true" Visible="true" ExternalAccess="Read/Write">
<Description>
<![CDATA[0-手动，1-自动]]>
</Description>
<DefaultData Format="L5K">
<![CDATA[0]]>
</DefaultData>
<DefaultData Format="Decorated">
<DataValue DataType="BOOL" Radix="Decimal" Value="0"/>
</DefaultData>
</Parameter>
<Parameter Name="dosing_rate_mg_L" TagType="Base" DataType="REAL" Usage="Input" Radix="Float" Required="true" Visible="true" ExternalAccess="Read/Write">
<Description>
<![CDATA[mg/L]]>
</Description>
<DefaultData Format="L5K">
<![CDATA[0.00000000e+000]]>
</DefaultData>
<DefaultData Format="Decorated">
<DataValue DataType="REAL" Radix="Float" Value="0.0"/>
</DefaultData>
</Parameter>
<Parameter Name="manual_flow_setting" TagType="Base" DataType="REAL" Usage="Input" Radix="Float" Required="true" Visible="true" ExternalAccess="Read/Write">
<DefaultData Format="L5K">
<![CDATA[0.00000000e+000]]>
</DefaultData>
<DefaultData Format="Decorated">
<DataValue DataType="REAL" Radix="Float" Value="0.0"/>
</DefaultData>
</Parameter>
<Parameter Name="source_water_flow" TagType="Base" DataType="REAL" Usage="Input" Radix="Float" Required="true" Visible="true" ExternalAccess="Read/Write">
<DefaultData Format="L5K">
<![CDATA[0.00000000e+000]]>
</DefaultData>
<DefaultData Format="Decorated">
<DataValue DataType="REAL" Radix="Float" Value="0.0"/>
</DefaultData>
</Parameter>
<Parameter Name="flow_setting" TagType="Base" DataType="REAL" Usage="Output" Radix="Float" Required="true" Visible="true" ExternalAccess="Read/Write">
<DefaultData Format="L5K">
<![CDATA[0.00000000e+000]]>
</DefaultData>
<DefaultData Format="Decorated">
<DataValue DataType="REAL" Radix="Float" Value="0.0"/>
</DefaultData>
</Parameter>
<Parameter Name="concentration" TagType="Base" DataType="REAL" Usage="Input" Radix="Float" Required="true" Visible="true" ExternalAccess="Read/Write">
<Description>
<![CDATA[0-100%]]>
</Description>
<DefaultData Format="L5K">
<![CDATA[0.00000000e+000]]>
</DefaultData>
<DefaultData Format="Decorated">
<DataValue DataType="REAL" Radix="Float" Value="0.0"/>
</DefaultData>
</Parameter>
</Parameters>
<LocalTags/>
<Routines>
<Routine Name="Logic" Type="ST">
<Description>
<![CDATA[计算投加流量：
1、手动设置时，以触摸屏设置流量为准；
2、自动控制时，以自动计算公式计算投加流量为准。]]>
</Description>
<STContent>
<Line Number="0">
<![CDATA[(*本程序用于计算投加流量*)]]>
</Line>
<Line Number="1">
<![CDATA[if auto_manual_switch then]]>
</Line>
<Line Number="2">
<![CDATA[    (*自动控制时，投加流量由计算公式确定*)]]>
</Line>
<Line Number="3">
<![CDATA[    (*计算公式：*)]]>
</Line>
<Line Number="4">
<![CDATA[    (*1m3=1000L;1mg=1/(1000*1000)kg*)]]>
</Line>
<Line Number="5">
<![CDATA[    (*纯物质投加量(kg/h)=源水流量(m3/h)*1000*溶液投率(mg/L)/(1000*1000)=源水流量(m3/h)*溶液投率(mg/L)/1000*)]]>
</Line>
<Line Number="6">
<![CDATA[    (*纯物质投加量(kg/h)=投加流量(L/h)*溶液浓度%*)]]>
</Line>
<Line Number="7">
<![CDATA[    (*投加流量(L/h)=纯物质投加量(kg/h)/溶液浓度%=源水流量(m3/h)*溶液投率(mg/L)/1000/溶液浓度%*)]]>
</Line>
<Line Number="8">
<![CDATA[    flow_setting := source_water_flow * dosing_rate_mg_L / 1000.0 / concentration; ]]>
</Line>
<Line Number="9">
<![CDATA[else]]>
</Line>
<Line Number="10">
<![CDATA[    (*手动控制时，投加流量由触摸屏控制*)]]>
</Line>
<Line Number="11">
<![CDATA[    flow_setting := manual_flow_setting;]]>
</Line>
<Line Number="12">
<![CDATA[end_if;]]>
</Line>
<Line Number="13">
<![CDATA[]]>
</Line>
</STContent>
</Routine>
</Routines>
</AddOnInstructionDefinition>
