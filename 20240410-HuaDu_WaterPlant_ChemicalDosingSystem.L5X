</Routine>
<Routine Name="MainRoutine" Type="RLL">
<Description>
<![CDATA[主程序]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[设置KMnO4系统4-20mA输入输出参数。]]>
</Comment>
<Text>
<![CDATA[JSR(analog_IO_setting_KMnO4,0);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[将I/O输入的数值，同步到系统变量，方便触摸屏及上位机读取]]>
</Comment>
<Text>
<![CDATA[JSR(synchronize_KMnO4,0);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[数字泵的启动/停止控制]]>
</Comment>
<Text>
<![CDATA[JSR(pump_action_KMnO4,0);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[计算各数字泵投加流量，并传到相关AO模块输出。]]>
</Comment>
<Text>
<![CDATA[JSR(dosing_flow_set_KMnO4,0);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="pump_action_KMnO4" Type="RLL">
<Description>
<![CDATA[控制数字泵的启动/停止]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[1#数字泵控制]]>
</Comment>
<Text>
<![CDATA[pump_start_stop_KMnO4(pump_action_KMnO4_1,KMnO4_level_low_alarm_1,VE_KMnO4_01_open,P_KMnO4_1_actuate,RemoteIO4:2:O.Data.0,VE_KMnO4_01_actuate);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[2#数字泵控制]]>
</Comment>
<Text>
<![CDATA[pump_start_stop_KMnO4(pump_action_KMnO4_2,KMnO4_level_low_alarm_1,VE_KMnO4_02_open,P_KMnO4_2_actuate,RemoteIO4:2:O.Data.1,VE_KMnO4_02_actuate);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[3#数字泵控制]]>
</Comment>
<Text>
<![CDATA[pump_start_stop_KMnO4(pump_action_KMnO4_3,KMnO4_level_low_alarm_2,VE_KMnO4_03_open,P_KMnO4_3_actuate,RemoteIO4:2:O.Data.2,VE_KMnO4_03_actuate);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[4#数字泵控制]]>
</Comment>
<Text>
<![CDATA[pump_start_stop_KMnO4(pump_action_KMnO4_4,KMnO4_level_low_alarm_2,VE_KMnO4_04_open,P_KMnO4_4_actuate,RemoteIO4:2:O.Data.3,VE_KMnO4_04_actuate);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="synchronize_KMnO4" Type="ST">
<Description>
<![CDATA[同步I/O输入的数值。]]>
</Description>
<STContent>
<Line Number="0">
<![CDATA[(*数字泵故障状态*)]]>
</Line>
<Line Number="1">
<![CDATA[P_KMnO4_1_err:=RemoteIO4:1:I.Data.0;]]>
</Line>
<Line Number="2">
<![CDATA[P_KMnO4_2_err:=RemoteIO4:1:I.Data.1;]]>
</Line>
<Line Number="3">
<![CDATA[P_KMnO4_3_err:=RemoteIO4:1:I.Data.2;]]>
</Line>
<Line Number="4">
<![CDATA[P_KMnO4_4_err:=RemoteIO4:1:I.Data.3;]]>
</Line>
<Line Number="5">
<![CDATA[]]>
</Line>
<Line Number="6">
<![CDATA[(*电动阀阀位反馈*)]]>
</Line>
<Line Number="7">
<![CDATA[VE_KMnO4_01_open:=RemoteIO4:1:I.Data.4;]]>
</Line>
<Line Number="8">
<![CDATA[VE_KMnO4_01_close:=RemoteIO4:1:I.Data.5;]]>
</Line>
<Line Number="9">
<![CDATA[VE_KMnO4_02_open:=RemoteIO4:1:I.Data.6;]]>
</Line>
<Line Number="10">
<![CDATA[VE_KMnO4_02_close:=RemoteIO4:1:I.Data.7;]]>
</Line>
<Line Number="11">
<![CDATA[VE_KMnO4_03_open:=RemoteIO4:1:I.Data.8;]]>
</Line>
<Line Number="12">
<![CDATA[VE_KMnO4_03_close:=RemoteIO4:1:I.Data.9;]]>
</Line>
<Line Number="13">
<![CDATA[VE_KMnO4_04_open:=RemoteIO4:1:I.Data.10;]]>
</Line>
<Line Number="14">
<![CDATA[VE_KMnO4_04_close:=RemoteIO4:1:I.Data.11;]]>
</Line>
<Line Number="15">
<![CDATA[VE_KMnO4_05_open:=RemoteIO4:1:I.Data.12;]]>
</Line>
<Line Number="16">
<![CDATA[VE_KMnO4_05_close:=RemoteIO4:1:I.Data.13;]]>
</Line>
