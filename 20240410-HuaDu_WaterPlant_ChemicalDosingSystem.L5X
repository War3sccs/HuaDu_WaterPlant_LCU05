</Line>
<Line Number="58">
<![CDATA[    );]]>
</Line>
<Line Number="59">
<![CDATA[(*AO模块4-20mA输出*)]]>
</Line>
<Line Number="60">
<![CDATA[SCL_LP1010_AO_16.In:=flow_calculate_KMnO4_4;]]>
</Line>
<Line Number="61">
<![CDATA[RemoteIO4:4:O.Ch3Data:=SCL_LP1010_AO_16.Out;]]>
