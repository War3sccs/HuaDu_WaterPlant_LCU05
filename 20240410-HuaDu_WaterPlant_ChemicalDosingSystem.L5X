<Routine Name="tank_control_NaOH" Type="RLL">
<Description>
<![CDATA[储液罐液位控制流程。
液位过高过低报警。
液位过高时关闭进液阀，防止储液罐过满；
液位过低时关闭出液阀，防止计量泵空吸。]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[1#NaOH储罐]]>
</Comment>
<Text>
<![CDATA[Tank_level(tank_control_5,NaOH_tank_level_8LT05,NaOH_level_high_setting,NaOH_level_low_setting,NaOH_level_high_alarm_1,NaOH_level_low_alarm_1,VE_NaOH_13_actuate,VE_NaOH_21_actuate);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[2#NaOH储罐]]>
</Comment>
<Text>
<![CDATA[Tank_level(tank_control_6,NaOH_tank_level_8LT06,NaOH_level_high_setting,NaOH_level_low_setting,NaOH_level_high_alarm_2,NaOH_level_low_alarm_2,VE_NaOH_14_actuate,VE_NaOH_22_actuate);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[3#NaOH储罐]]>
</Comment>
<Text>
<![CDATA[Tank_level(tank_control_7,NaOH_tank_level_8LT07,NaOH_level_high_setting,NaOH_level_low_setting,NaOH_level_high_alarm_3,NaOH_level_low_alarm_3,VE_NaOH_27_actuate,VE_NaOH_29_actuate);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[4#NaOH储罐]]>
</Comment>
<Text>
<![CDATA[Tank_level(tank_control_8,NaOH_tank_level_8LT08,NaOH_level_high_setting,NaOH_level_low_setting,NaOH_level_high_alarm_4,NaOH_level_low_alarm_4,VE_NaOH_28_actuate,VE_NaOH_30_actuate);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
</Routines>
</Program>
