</Line>
<Line Number="29">
<![CDATA[    NaClO_quantity(*PAC用量kg/h*)]]>
</Line>
<Line Number="30">
<![CDATA[    );]]>
</Line>
<Line Number="31">
<![CDATA[(*AO模块4-20mA输出*)]]>
</Line>
<Line Number="32">
<![CDATA[SCL(SCL_LP400_AO_2);]]>
</Line>
<Line Number="33">
<![CDATA[SCL_LP400_AO_2.In:=flow_calculate_NaClO_2;]]>
</Line>
<Line Number="34">
<![CDATA[]]>
</Line>
