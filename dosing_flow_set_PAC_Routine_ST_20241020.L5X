<Programs Use="Context">
<Program Use="Context" Name="PAC">
<Routines Use="Context">
<Routine Use="Target" Name="dosing_flow_set_PAC" Type="ST">
<Description>
<![CDATA[计算各数字泵投加流量：
1、手动设置时，以触摸屏设置流量为准；
2、自动控制时，以自动计算公式计算投加流量为准。
得出计算结果后，将流量传送到相关AO模块]]>
</Description>
<STContent>
<Line Number="0">
<![CDATA[(*1#数字泵流量计算*)]]>
</Line>
<Line Number="1">
<![CDATA[(*计算流量*)]]>
</Line>
<Line Number="2">
<![CDATA[dosing_flow_setting(]]>
</Line>
<Line Number="3">
<![CDATA[    dosing_flow_setting_1,]]>
</Line>
<Line Number="4">
<![CDATA[    PAC_control_auto_manual[1],(*控制状态：手动-0，自动-1*)]]>
</Line>
<Line Number="5">
<![CDATA[    PAC_dosing_mg_L_mixing_tank_1,(*PAC溶液投加率，原设计最大60mg/L*)]]>
</Line>
<Line Number="6">
<![CDATA[    P_PAC1_flow_set,(*手动控制状态时，手动指定的投加流量L/h*)]]>
</Line>
<Line Number="7">
<![CDATA[    water_data_LCU05[3],(*源水流量m3/h*)]]>
</Line>
<Line Number="8">
<![CDATA[    flow_calculate_PAC_1,(*计算出来的投加量：手动时手动指定，自动时由计算得出*)]]>
</Line>
<Line Number="9">
<![CDATA[    PAC_concentration, (*PAC浓度*)]]>
</Line>
<Line Number="10">
<![CDATA[    PAC_density,(*PAC密度*)]]>
</Line>
<Line Number="11">
<![CDATA[    PAC_quantity(*PAC用量kg/h*)]]>
</Line>
<Line Number="12">
<![CDATA[    );]]>
</Line>
<Line Number="13">
<![CDATA[    (*AO模块4-20mA输出*)]]>
</Line>
<Line Number="14">
<![CDATA[    SCL(SCL_LP1010_AO_1);]]>
</Line>
<Line Number="15">
<![CDATA[    SCL_LP1010_AO_1.In:=flow_calculate_PAC_1;]]>
</Line>
<Line Number="16">
<![CDATA[]]>
</Line>
<Line Number="17">
<![CDATA[(*2#数字泵流量计算*)]]>
</Line>
<Line Number="18">
<![CDATA[(*计算流量*)]]>
</Line>
<Line Number="19">
<![CDATA[dosing_flow_setting(]]>
</Line>
<Line Number="20">
<![CDATA[    dosing_flow_setting_2,]]>
</Line>
<Line Number="21">
<![CDATA[    PAC_control_auto_manual[1],(*控制状态：手动-0，自动-1*)]]>
</Line>
<Line Number="22">
<![CDATA[    PAC_dosing_mg_L_mixing_tank_1,(*PAC溶液投加率，原设计最大60mg/L*)]]>
</Line>
<Line Number="23">
<![CDATA[    P_PAC2_flow_set,(*手动控制状态时，手动指定的投加流量L/h*)]]>
</Line>
<Line Number="24">
<![CDATA[    water_data_LCU05[3],(*源水流量m3/h*)]]>
</Line>
<Line Number="25">
<![CDATA[    flow_calculate_PAC_2,(*计算出来的投加量：手动时手动指定，自动时由计算得出*)]]>
</Line>
<Line Number="26">
<![CDATA[    PAC_concentration, (*PAC浓度*)]]>
</Line>
<Line Number="27">
<![CDATA[    PAC_density,(*PAC密度*)]]>
</Line>
<Line Number="28">
<![CDATA[    PAC_quantity(*PAC用量kg/h*)]]>
</Line>
<Line Number="29">
<![CDATA[    );]]>
</Line>
<Line Number="30">
<![CDATA[    (*AO模块4-20mA输出*)]]>
</Line>
<Line Number="31">
<![CDATA[    SCL(SCL_LP1010_AO_2);]]>
</Line>
<Line Number="32">
<![CDATA[    SCL_LP1010_AO_2.In:=flow_calculate_PAC_2;]]>
</Line>
<Line Number="33">
<![CDATA[]]>
</Line>
<Line Number="34">
<![CDATA[(*3#数字泵流量计算*)]]>
</Line>
<Line Number="35">
<![CDATA[(*计算流量*)]]>
</Line>
<Line Number="36">
<![CDATA[dosing_flow_setting(]]>
</Line>
<Line Number="37">
<![CDATA[    dosing_flow_setting_3,]]>
</Line>
<Line Number="38">
<![CDATA[    PAC_control_auto_manual[2],(*控制状态：手动-0，自动-1*)]]>
</Line>
<Line Number="39">
<![CDATA[    PAC_dosing_mg_L_mixing_tank_2,(*PAC溶液投加率，原设计最大60mg/L*)]]>
</Line>
<Line Number="40">
<![CDATA[    P_PAC3_flow_set,(*手动控制状态时，手动指定的投加流量L/h*)]]>
</Line>
<Line Number="41">
<![CDATA[    water_data_LCU05[4],(*源水流量m3/h*)]]>
</Line>
<Line Number="42">
<![CDATA[    flow_calculate_PAC_3,(*计算出来的投加量：手动时手动指定，自动时由计算得出*)]]>
</Line>
<Line Number="43">
<![CDATA[    PAC_concentration, (*PAC浓度*)]]>
</Line>
<Line Number="44">
<![CDATA[    PAC_density,(*PAC密度*)]]>
</Line>
<Line Number="45">
<![CDATA[    PAC_quantity(*PAC用量kg/h*)]]>
</Line>
<Line Number="46">
<![CDATA[    );]]>
</Line>
<Line Number="47">
<![CDATA[    (*AO模块4-20mA输出*)]]>
</Line>
<Line Number="48">
<![CDATA[    SCL(SCL_LP1010_AO_3);]]>
</Line>
<Line Number="49">
<![CDATA[    SCL_LP1010_AO_3.In:=flow_calculate_PAC_3;]]>
</Line>
<Line Number="50">
<![CDATA[]]>
</Line>
<Line Number="51">
<![CDATA[(*4#数字泵流量计算*)]]>
</Line>
<Line Number="52">
<![CDATA[(*计算流量*)]]>
</Line>
<Line Number="53">
<![CDATA[dosing_flow_setting(]]>
</Line>
<Line Number="54">
<![CDATA[    dosing_flow_setting_4,]]>
</Line>
<Line Number="55">
<![CDATA[    PAC_control_auto_manual[2],(*控制状态：手动-0，自动-1*)]]>
</Line>
<Line Number="56">
<![CDATA[    PAC_dosing_mg_L_mixing_tank_2,(*PAC溶液投加率，原设计最大60mg/L*)]]>
</Line>
<Line Number="57">
<![CDATA[    P_PAC4_flow_set,(*手动控制状态时，手动指定的投加流量L/h*)]]>
</Line>
<Line Number="58">
<![CDATA[    water_data_LCU05[4],(*源水流量m3/h*)]]>
</Line>
<Line Number="59">
<![CDATA[    flow_calculate_PAC_4,(*计算出来的投加量：手动时手动指定，自动时由计算得出*)]]>
</Line>
<Line Number="60">
<![CDATA[    PAC_concentration, (*PAC浓度*)]]>
</Line>
<Line Number="61">
<![CDATA[    PAC_density,(*PAC密度*)]]>
</Line>
<Line Number="62">
<![CDATA[    PAC_quantity(*PAC用量kg/h*)]]>
</Line>
<Line Number="63">
<![CDATA[    );]]>
</Line>
<Line Number="64">
<![CDATA[    (*AO模块4-20mA输出*)]]>
</Line>
<Line Number="65">
<![CDATA[    SCL(SCL_LP1010_AO_4);]]>
</Line>
<Line Number="66">
<![CDATA[    SCL_LP1010_AO_4.In:=flow_calculate_PAC_4;]]>
</Line>
<Line Number="67">
<![CDATA[]]>
</Line>
<Line Number="68">
<![CDATA[(*数字泵故障时，流量切换*)]]>
</Line>
<Line Number="69">
<![CDATA[if P_PAC1_err and not P_PAC2_err then]]>
</Line>
<Line Number="70">
<![CDATA[	P_PAC2_flow_set:=P_PAC1_flow_read+P_PAC2_flow_read;]]>
</Line>
<Line Number="71">
<![CDATA[	end_if;]]>
</Line>
<Line Number="72">
<![CDATA[if not P_PAC1_err and P_PAC2_err then]]>
</Line>
<Line Number="73">
<![CDATA[	P_PAC1_flow_set:=P_PAC1_flow_read+P_PAC2_flow_read;]]>
</Line>
<Line Number="74">
<![CDATA[	end_if;]]>
</Line>
<Line Number="75">
<![CDATA[]]>
</Line>
<Line Number="76">
<![CDATA[if P_PAC3_err and not P_PAC4_err then]]>
</Line>
<Line Number="77">
<![CDATA[	P_PAC4_flow_set:=P_PAC3_flow_read+P_PAC4_flow_read;]]>
</Line>
<Line Number="78">
<![CDATA[	end_if;]]>
</Line>
<Line Number="79">
<![CDATA[if not P_PAC3_err and P_PAC4_err then]]>
</Line>
<Line Number="80">
<![CDATA[	P_PAC3_flow_set:=P_PAC3_flow_read+P_PAC4_flow_read;]]>
</Line>
<Line Number="81">
<![CDATA[end_if;]]>
</Line>
<Line Number="82">
<![CDATA[]]>
</Line>
<Line Number="83">
<![CDATA[]]>
</Line>
</STContent>
</Routine>
</Routines>
</Program>
</Programs>
</Controller>
