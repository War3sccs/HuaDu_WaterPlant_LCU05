<Tag Name="water_data_LCU05" TagType="Base" DataType="REAL" Dimensions="20" Radix="Float" Constant="false" ExternalAccess="Read/Write">
<Comments>
<Comment Operand="[0]">
<![CDATA[水厂进水温度,Temp_In_Plant.PV,]]>
</Comment>
<Comment Operand="[1]">
<![CDATA[水厂进水浊度,Turb_In_Plant.PV,单位：NTU]]>
</Comment>
<Comment Operand="[2]">
<![CDATA[水厂进水pH，PH_In_Plant]]>
</Comment>
<Comment Operand="[3]">
<![CDATA[絮凝沉淀池A进水流量，Flow1.current，单位:m3/h]]>
</Comment>
<Comment Operand="[4]">
<![CDATA[絮凝沉淀池B进水流量，Flow2.current，单位:m3/h]]>
</Comment>
<Comment Operand="[5]">
<![CDATA[絮凝沉淀池A2出水余氯，CL_Out_SediT[2].PV,单位:mg/L]]>
</Comment>
<Comment Operand="[6]">
<![CDATA[絮凝沉淀池B1出水余氯，CL_Out_SediT[3].PV,单位:mg/L]]>
</Comment>
<Comment Operand="[7]">
<![CDATA[滤池出水余氯，单位:mg/L]]>
</Comment>
<Comment Operand="[8]">
<![CDATA[水厂出水余氯1,CL_Out_Plant_1,单位:mg/L]]>
</Comment>
<Comment Operand="[9]">
<![CDATA[水厂出水余氯2,CL_Out_Plant_2,单位:mg/L]]>
</Comment>
<Comment Operand="[10]">
<![CDATA[清水池液位，Level_C-Well,单位:m]]>
</Comment>
