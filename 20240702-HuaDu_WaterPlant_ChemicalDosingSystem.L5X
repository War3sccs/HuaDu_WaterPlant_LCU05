<Routine Name="dosing_flow_set_NaClO" Type="ST">
<Description>
<![CDATA[计算各数字泵投加流量：
1、手动设置时，以触摸屏设置流量为准；
2、自动控制时，以自动计算公式计算投加流量为准。
得出计算结果后，将流量传送到相关AO模块]]>
</Description>
<STContent>
<Line Number="0">
<![CDATA[(*1-6号数字泵流量范围:0.0-390.0L/h*)]]>
</Line>
<Line Number="1">
<![CDATA[(*1#数字泵流量计算*)]]>
</Line>
<Line Number="2">
<![CDATA[(*计算流量*)]]>
</Line>
<Line Number="3">
<![CDATA[dosing_flow_setting(]]>
</Line>
<Line Number="4">
<![CDATA[    dosing_flow_setting_9,]]>
</Line>
<Line Number="5">
<![CDATA[    NaClO_control_auto_manual,(*控制状态：手动-0，自动-1*)]]>
</Line>
<Line Number="6">
<![CDATA[    NaClO_dosing_mg_L_mixing_tank_1,(*NaClO溶液投加率，原设计最大1mg/L*)]]>
</Line>
<Line Number="7">
<![CDATA[    P_NaClO1_flow_set,(*手动控制状态时，手动指定的投加流量L/h*)]]>
</Line>
<Line Number="8">
<![CDATA[    source_water_flow,(*源水流量m3/h*)]]>
</Line>
<Line Number="9">
<![CDATA[    flow_calculate_NaClO_1,(*计算出来的投加量：手动时手动指定，自动时由计算得出*)]]>
</Line>
<Line Number="10">
<![CDATA[    NaClO_concentration (*NaClO溶液浓度*)]]>
</Line>
<Line Number="11">
<![CDATA[    );]]>
</Line>
<Line Number="12">
<![CDATA[(*AO模块4-20mA输出*)]]>
</Line>
<Line Number="13">
<![CDATA[SCL(SCL_LP400_AO_1);]]>
</Line>
<Line Number="14">
<![CDATA[SCL_LP400_AO_1.In:=flow_calculate_NaClO_1;]]>
</Line>
<Line Number="15">
<![CDATA[]]>
</Line>
<Line Number="16">
<![CDATA[(*2#数字泵流量计算*)]]>
</Line>
<Line Number="17">
<![CDATA[(*计算流量*)]]>
</Line>
<Line Number="18">
<![CDATA[dosing_flow_setting(]]>
</Line>
<Line Number="19">
<![CDATA[    dosing_flow_setting_10,]]>
</Line>
<Line Number="20">
<![CDATA[    NaClO_control_auto_manual,(*控制状态：手动-0，自动-1*)]]>
</Line>
<Line Number="21">
<![CDATA[    NaClO_dosing_mg_L_mixing_tank_1,(*NaClO溶液投加率，原设计最大1mg/L*)]]>
</Line>
<Line Number="22">
<![CDATA[    P_NaClO2_flow_set,(*手动控制状态时，手动指定的投加流量L/h*)]]>
</Line>
<Line Number="23">
<![CDATA[    source_water_flow,(*源水流量m3/h*)]]>
</Line>
<Line Number="24">
<![CDATA[    flow_calculate_NaClO_2,(*计算出来的投加量：手动时手动指定，自动时由计算得出*)]]>
</Line>
<Line Number="25">
<![CDATA[    NaClO_concentration (*NaClO溶液浓度*)]]>
</Line>
<Line Number="26">
<![CDATA[    );]]>
</Line>
<Line Number="27">
<![CDATA[(*AO模块4-20mA输出*)]]>
</Line>
<Line Number="28">
<![CDATA[SCL(SCL_LP400_AO_2);]]>
</Line>
<Line Number="29">
<![CDATA[SCL_LP400_AO_2.In:=flow_calculate_NaClO_2;]]>
</Line>
<Line Number="30">
<![CDATA[]]>
</Line>
<Line Number="31">
<![CDATA[(*3#数字泵流量计算*)]]>
</Line>
<Line Number="32">
<![CDATA[(*计算流量*)]]>
</Line>
