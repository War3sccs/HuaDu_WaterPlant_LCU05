<![CDATA[EQU(Wrk_MSGStep,530)COP(Ref_Connection.MSG_Dest[8],Wrk_TempString.LEN,1)[GRT(Wrk_TempString.LEN,0) COP(Ref_Connection.MSG_Dest[12],Wrk_TempString.DATA[0],Wrk_TempString.LEN) CONCAT(Wrk_Main_Read_Buffer,Wrk_TempString,Wrk_Main_Read_Buffer) ,MOV(540,Wrk_MSGStep) ];]]>
