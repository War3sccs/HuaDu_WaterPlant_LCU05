<![CDATA[EQU(Wrk_MSGStep,430)[XIC(Ref_Transactions[Wrk_WrIndex].TransComplete) RES(Ref_Transactions[Wrk_WrIndex].Diagnostic.NoReplyCounter) ,XIC(Wrk_WriteNow[Wrk_WrIndex]) MOV(440,Wrk_MSGStep) ];]]>
