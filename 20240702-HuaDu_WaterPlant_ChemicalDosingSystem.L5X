<![CDATA[EQU(Wrk_MSGStep,650)MOV(660,Wrk_MSGStep)EQU(Wrk_CmdFromReadPacket,2)MOV(690,Wrk_MSGStep)[MOV(Wrk_ModbusCmdString.DATA[1],Wrk_ModbusCmdLen) raC_Tec_NetModbusTCPClient_ChkWrReply(Wrk_CWR,Ref_Transactions,Wrk_ModbusTransID,Wrk_ModbusBytes,Wrk_CmdFromReadPacket,Wrk_LastTransaction) ,XIC(Wrk_CWR.TransFound) CMP(Wrk_CWR.Count<=Wrk_ModbusCmdLen*8) raC_Tec_NetModbusTCPClient_RespStrBit(Wrk_RSB,1,Wrk_CWR.Count,Wrk_CWR.LocalOffset,Ref_ModbusData,Wrk_ModbusCmdString) ];]]>
