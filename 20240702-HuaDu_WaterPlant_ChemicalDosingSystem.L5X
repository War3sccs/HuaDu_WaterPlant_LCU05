<![CDATA[EQU(Wrk_MSGStep,420)XIC(Ref_Transactions[Wrk_WrIndex].Diagnostic.ReqBuilt)XIC(Wrk_TransactionTriggers[Wrk_WrIndex])[[EQU(Wrk_IDCounter,32767) MOV(0,Wrk_IDCounter) ,ADD(Wrk_IDCounter,1,Wrk_IDCounter) ] MOV(Wrk_IDCounter,Ref_Transactions[Wrk_WrIndex].Diagnostic.TransID) ,SWPB(Ref_Transactions[Wrk_WrIndex].Diagnostic.TransID,REVERSE,Wrk_TempInt) COP(Wrk_TempInt,Ref_Transactions[Wrk_WrIndex].Diagnostic.Request.DATA[0],2) ][OTL(Wrk_WriteNow[Wrk_WrIndex]) ,OTU(Wrk_TransactionTriggers[Wrk_WrIndex]) ,MOV(430,Wrk_MSGStep) ];]]>
