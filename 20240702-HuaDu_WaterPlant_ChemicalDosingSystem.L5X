<Routine Name="dosing_flow_set_PAC" Type="ST">
<Description>
<![CDATA[计算各数字泵投加流量：
1、手动设置时，以触摸屏设置流量为准；
2、自动控制时，以自动计算公式计算投加流量为准。
得出计算结果后，将流量传送到相关AO模块]]>
</Description>
<STContent>
<Line Number="0">
<![CDATA[(*1#数字泵流量计算*)]]>
</Line>
<Line Number="1">
<![CDATA[(*计算流量*)]]>
</Line>
<Line Number="2">
<![CDATA[dosing_flow_setting(]]>
</Line>
<Line Number="3">
<![CDATA[    dosing_flow_setting_1,]]>
</Line>
<Line Number="4">
<![CDATA[    PAC_control_auto_manual,(*控制状态：手动-0，自动-1*)]]>
</Line>
<Line Number="5">
<![CDATA[    PAC_dosing_mg_L_mixing_tank_1,(*PAC溶液投加率，原设计最大60mg/L*)]]>
</Line>
<Line Number="6">
<![CDATA[    P_PAC1_flow_set,(*手动控制状态时，手动指定的投加流量L/h*)]]>
</Line>
<Line Number="7">
<![CDATA[    source_water_flow,(*源水流量m3/h*)]]>
</Line>
<Line Number="8">
<![CDATA[    flow_calculate_PAC_1,(*计算出来的投加量：手动时手动指定，自动时由计算得出*)]]>
</Line>
<Line Number="9">
<![CDATA[    0.98 (*PAC纯度，按98%计算*)]]>
</Line>
<Line Number="10">
<![CDATA[    );]]>
</Line>
<Line Number="11">
<![CDATA[(*AO模块4-20mA输出*)]]>
</Line>
<Line Number="12">
<![CDATA[SCL(SCL_LP1010_AO_1);]]>
</Line>
<Line Number="13">
<![CDATA[SCL_LP1010_AO_1.In:=flow_calculate_PAC_1;]]>
</Line>
<Line Number="14">
<![CDATA[]]>
</Line>
<Line Number="15">
<![CDATA[(*2#数字泵流量计算*)]]>
</Line>
<Line Number="16">
<![CDATA[(*计算流量*)]]>
</Line>
<Line Number="17">
<![CDATA[dosing_flow_setting(]]>
</Line>
<Line Number="18">
<![CDATA[    dosing_flow_setting_2,]]>
</Line>
<Line Number="19">
<![CDATA[    PAC_control_auto_manual,(*控制状态：手动-0，自动-1*)]]>
</Line>
<Line Number="20">
<![CDATA[    PAC_dosing_mg_L_mixing_tank_1,(*PAC溶液投加率，原设计最大60mg/L*)]]>
</Line>
<Line Number="21">
<![CDATA[    P_PAC2_flow_set,(*手动控制状态时，手动指定的投加流量L/h*)]]>
</Line>
<Line Number="22">
<![CDATA[    source_water_flow,(*源水流量m3/h*)]]>
</Line>
<Line Number="23">
<![CDATA[    flow_calculate_PAC_2,(*计算出来的投加量：手动时手动指定，自动时由计算得出*)]]>
</Line>
<Line Number="24">
<![CDATA[    0.98 (*PAC纯度，按98%计算*)]]>
</Line>
<Line Number="25">
<![CDATA[    );]]>
</Line>
<Line Number="26">
<![CDATA[(*AO模块4-20mA输出*)]]>
</Line>
<Line Number="27">
<![CDATA[SCL(SCL_LP1010_AO_2);]]>
</Line>
<Line Number="28">
<![CDATA[SCL_LP1010_AO_2.In:=flow_calculate_PAC_2;]]>
</Line>
<Line Number="29">
<![CDATA[]]>
</Line>
<Line Number="30">
<![CDATA[(*3#数字泵流量计算*)]]>
</Line>
<Line Number="31">
<![CDATA[(*计算流量*)]]>
</Line>
<Line Number="32">
<![CDATA[dosing_flow_setting(]]>
</Line>
<Line Number="33">
<![CDATA[    dosing_flow_setting_3,]]>
</Line>
<Line Number="34">
<![CDATA[    PAC_control_auto_manual,(*控制状态：手动-0，自动-1*)]]>
</Line>
<Line Number="35">
<![CDATA[    PAC_dosing_mg_L_mixing_tank_2,(*PAC溶液投加率，原设计最大60mg/L*)]]>
</Line>
<Line Number="36">
<![CDATA[    P_PAC3_flow_set,(*手动控制状态时，手动指定的投加流量L/h*)]]>
</Line>
<Line Number="37">
<![CDATA[    source_water_flow,(*源水流量m3/h*)]]>
</Line>
<Line Number="38">
<![CDATA[    flow_calculate_PAC_3,(*计算出来的投加量：手动时手动指定，自动时由计算得出*)]]>
</Line>
<Line Number="39">
<![CDATA[    0.98 (*PAC纯度，按98%计算*)]]>
</Line>
<Line Number="40">
<![CDATA[    );]]>
</Line>
<Line Number="41">
<![CDATA[(*AO模块4-20mA输出*)]]>
</Line>
<Line Number="42">
