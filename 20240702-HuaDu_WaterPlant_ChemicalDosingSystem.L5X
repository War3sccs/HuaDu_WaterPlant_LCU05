<Routines>
<Routine Name="analog_IO_setting_NaOH" Type="ST">
<Description>
<![CDATA[设备4-20mA输入输出参数。]]>
</Description>
<STContent>
<Line Number="0">
<![CDATA[(*4-20mA输入输出参数设置*)]]>
</Line>
<Line Number="1">
<![CDATA[(*通过内置函数SCL配置输入输出4-20mA数值*)]]>
</Line>
<Line Number="2">
<![CDATA[(*模拟量输出范围:4-20mA*)]]>
</Line>
<Line Number="3">
<![CDATA[]]>
</Line>
<Line Number="4">
<![CDATA[(*1-6号投加泵流量范围:0.0-2000.0L/h*)]]>
</Line>
<Line Number="5">
<![CDATA[(*投加泵使用西门子V20变频器，默认采用0-20mA输出，所以设置为0-20mA输出*)]]>
</Line>
<Line Number="6">
<![CDATA[(*投加泵运行频率:0-50Hz*)]]>
</Line>
<Line Number="7">
<![CDATA[(*AI模块数值范围:0-31208*)]]>
</Line>
<Line Number="8">
<![CDATA[SCL_frequency_AI_1.InEUMax:=50.0;]]>
</Line>
<Line Number="9">
<![CDATA[SCL_frequency_AI_1.InEUMin:=0.0;]]>
</Line>
<Line Number="10">
<![CDATA[SCL_frequency_AI_1.InRawMax:=31208;]]>
</Line>
<Line Number="11">
<![CDATA[SCL_frequency_AI_1.InRawMin:=0;]]>
</Line>
<Line Number="12">
<![CDATA[]]>
</Line>
<Line Number="13">
<![CDATA[SCL_frequency_AI_2.InEUMax:=50.0;]]>
</Line>
<Line Number="14">
<![CDATA[SCL_frequency_AI_2.InEUMin:=0.0;]]>
</Line>
<Line Number="15">
<![CDATA[SCL_frequency_AI_2.InRawMax:=31208;]]>
</Line>
<Line Number="16">
<![CDATA[SCL_frequency_AI_2.InRawMin:=0;]]>
</Line>
<Line Number="17">
<![CDATA[]]>
</Line>
<Line Number="18">
<![CDATA[SCL_frequency_AI_3.InEUMax:=50.0;]]>
</Line>
<Line Number="19">
<![CDATA[SCL_frequency_AI_3.InEUMin:=0.0;]]>
</Line>
<Line Number="20">
