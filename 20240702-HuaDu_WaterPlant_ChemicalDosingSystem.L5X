<Text>
<![CDATA[pump_start_stop_NaClO(pump_action_NaClO_2,VE_NaClO45_open,VE_NaClO11_open,VE_NaClO12_open,VE_NaClO13_open,VE_NaClO14_open,VE_NaClO2_open,P_NaClO2_actuate,RemoteIO3:3:O.Data.1,VE_NaClO15_open,VE_NaClO16_open,VE_NaClO17_open,VE_NaClO18_open);]]>
