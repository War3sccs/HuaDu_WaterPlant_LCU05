<Line Number="200">
<![CDATA[(*将读取的压力数值转变为重量*)]]>
</Line>
<Line Number="201">
<![CDATA[(*计算公式：m(kg)=p*S/g=p*pi*(d/2)^2/g*)]]>
</Line>
<Line Number="202">
<![CDATA[(*1000Pa*3.14*(3.5/2)^2/9.8/1000，单位:吨*)]]>
</Line>
<Line Number="203">
<![CDATA[(*g=9.8m/s^2,pi=3.14,压力变送器测量范围0-240kPa*)]]>
</Line>
<Line Number="204">
<![CDATA[NaOH_weight_8PT01:=(NaOH_tank_pressure_1*3.14*(3.5/2)**2/9.8);]]>
</Line>
<Line Number="205">
<![CDATA[NaOH_weight_8PT02:=(NaOH_tank_pressure_2*3.14*(3.5/2)**2/9.8);]]>
</Line>
<Line Number="206">
<![CDATA[NaOH_weight_8PT03:=(NaOH_tank_pressure_3*3.14*(3.5/2)**2/9.8);]]>
</Line>
<Line Number="207">
<![CDATA[NaOH_weight_8PT04:=(NaOH_tank_pressure_4*3.14*(3.5/2)**2/9.8);]]>
