<DefaultData Format="L5K">
<![CDATA[0]]>
</DefaultData>
<DefaultData Format="Decorated">
<DataValue DataType="INT" Radix="Decimal" Value="0"/>
</DefaultData>
</LocalTag>
<LocalTag Name="Wrk_TempASCII_462" DataType="STR0500" ExternalAccess="None">
<DefaultData Format="L5K">
<![CDATA[[0,'$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00$00']]]>
</DefaultData>
<DefaultData Format="String" Length="0">
<![CDATA['']]>
</DefaultData>
</LocalTag>
<LocalTag Name="Wrk_Bit" DataType="DINT" Radix="Decimal" ExternalAccess="None">
<DefaultData Format="L5K">
<![CDATA[0]]>
</DefaultData>
<DefaultData Format="Decorated">
<DataValue DataType="DINT" Radix="Decimal" Value="0"/>
</DefaultData>
</LocalTag>
<LocalTag Name="Wrk_Byte" DataType="DINT" Radix="Decimal" ExternalAccess="None">
<DefaultData Format="L5K">
<![CDATA[0]]>
</DefaultData>
<DefaultData Format="Decorated">
<DataValue DataType="DINT" Radix="Decimal" Value="0"/>
</DefaultData>
</LocalTag>
<LocalTag Name="Wrk_Index" DataType="DINT" Radix="Decimal" ExternalAccess="None">
<DefaultData Format="L5K">
<![CDATA[0]]>
</DefaultData>
<DefaultData Format="Decorated">
<DataValue DataType="DINT" Radix="Decimal" Value="0"/>
</DefaultData>
</LocalTag>
<LocalTag Name="Wrk_LastAddr" DataType="DINT" Radix="Decimal" ExternalAccess="None">
<DefaultData Format="L5K">
<![CDATA[0]]>
</DefaultData>
<DefaultData Format="Decorated">
<DataValue DataType="DINT" Radix="Decimal" Value="0"/>
</DefaultData>
</LocalTag>
<LocalTag Name="Wrk_ValidRemoteRange" DataType="BOOL" Radix="Decimal" ExternalAccess="None">
<DefaultData Format="L5K">
<![CDATA[0]]>
</DefaultData>
<DefaultData Format="Decorated">
<DataValue DataType="BOOL" Radix="Decimal" Value="0"/>
</DefaultData>
</LocalTag>
</LocalTags>
<Routines>
<Routine Name="Logic" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Text>
<![CDATA[OTU(ER);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[First make sure we have a good transaction Code.  
If not set the last error and clear the enable for this transaction.]]>
</Comment>
<Text>
<![CDATA[[LES(Transaction.TransType,1) ,GRT(Transaction.TransType,6) ]NEQ(Transaction.TransType,15)NEQ(Transaction.TransType,16)MOV(-12,Transaction.Diagnostic.TransLastError)MOV(-1,Transaction.TransStat)OTU(Transaction.Enabled)OTL(ER)JMP(ExitLabel);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[These are single write operations set the count to 1
 for range checking.]]>
</Comment>
<Text>
<![CDATA[[EQU(Transaction.TransType,5) ,EQU(Transaction.TransType,6) ]MOV(1,Transaction.Count);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[Check discrete operations to make sure the transaction will fit in the local data arrays.]]>
</Comment>
<Text>
<![CDATA[[EQU(Transaction.TransType,1) ,EQU(Transaction.TransType,2) ,EQU(Transaction.TransType,5) ,EQU(Transaction.TransType,15) ][CMP(Transaction.LocalAddress + Transaction.Count > 1024) ,LES(Transaction.LocalAddress,0) ,LES(Transaction.Count,0) ,GRT(Transaction.Count,256) ]MOV(-13,Transaction.Diagnostic.TransLastError)MOV(-1,Transaction.TransStat)OTU(Transaction.Enabled)OTL(ER)JMP(ExitLabel);]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Comment>
<![CDATA[Check Register operations to make sure they fit within the local data arrays.]]>
</Comment>
<Text>
<![CDATA[[EQU(Transaction.TransType,3) ,EQU(Transaction.TransType,4) ,EQU(Transaction.TransType,6) ,EQU(Transaction.TransType,16) ][CMP(Transaction.LocalAddress + Transaction.Count > 1024) ,LES(Transaction.LocalAddress,0) ,LES(Transaction.Count,0) ,GRT(Transaction.Count,120) ]MOV(-13,Transaction.Diagnostic.TransLastError)MOV(-1,Transaction.TransStat)OTU(Transaction.Enabled)OTL(ER)JMP(ExitLabel);]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Text>
<![CDATA[LIM(0,Transaction.BeginAddress,16#ffff)CMP((Transaction.BeginAddress+Transaction.Count-1)<=16#ffff)BTD(Transaction.BeginAddress,0,Wrk_TempBeginInt,0,16)OTE(Wrk_ValidRemoteRange);]]>
</Text>
</Rung>
<Rung Number="6" Type="N">
<Text>
<![CDATA[XIO(Wrk_ValidRemoteRange)MOV(-13,Transaction.Diagnostic.TransLastError)MOV(-1,Transaction.TransStat)MOV(-1,Transaction.BeginAddress)MOV(0,Wrk_TempBeginInt)OTU(Transaction.Enabled)OTL(ER)JMP(ExitLabel);]]>
</Text>
</Rung>
<Rung Number="7" Type="N">
<Comment>
<![CDATA[Begin by building the MBAP Header
Transaction Identifier
Protocol Identifier (always 0)
Length (based on transaction)
Unit Identifier]]>
</Comment>
<Text>
<![CDATA[SWPB(Transaction.Diagnostic.TransID,REVERSE,Wrk_TempInt)COP(Wrk_TempInt,Transaction.Diagnostic.Request.DATA[0],2)CLR(Transaction.Diagnostic.Request.DATA[2])CLR(Transaction.Diagnostic.Request.DATA[3])MOV(4,Transaction.Diagnostic.Request.LEN);]]>
</Text>
</Rung>
<Rung Number="8" Type="N">
<Comment>
<![CDATA[Handle all length 6 transactions here  This adds the additional length to the header.
]]>
</Comment>
<Text>
<![CDATA[[GEQ(Transaction.TransType,1) LEQ(Transaction.TransType,6) MOV(6,Wrk_TempInt) ,EQU(Transaction.TransType,15) DIV(Transaction.Count,8,Wrk_TempInt) [CMP(Wrk_TempInt*8=Transaction.Count) ,CMP(Wrk_TempInt*8<Transaction.Count) ADD(Wrk_TempInt,1,Wrk_TempInt) ] ADD(Wrk_TempInt,7,Wrk_TempInt) ,EQU(Transaction.TransType,16) MOV(Transaction.Count,Wrk_TempInt) MUL(Wrk_TempInt,2,Wrk_TempInt) ADD(Wrk_TempInt,7,Wrk_TempInt) ]SWPB(Wrk_TempInt,REVERSE,Wrk_TempInt)COP(Wrk_TempInt,Transaction.Diagnostic.Request.DATA[4],2)MOV(6,Transaction.Diagnostic.Request.LEN);]]>
</Text>
</Rung>
<Rung Number="9" Type="N">
<Comment>
<![CDATA[This adds the Unit ID to the header.  Most of the time this will be 0 unless the Ethernet device is a gateway and a remote address on the other side of the gateway needs to be specified.]]>
</Comment>
<Text>
<![CDATA[COP(Transaction.StationID,Transaction.Diagnostic.Request.DATA[6],1)COP(Transaction.TransType,Transaction.Diagnostic.Request.DATA[7],1)SWPB(Wrk_TempBeginInt,REVERSE,Wrk_TempInt)COP(Wrk_TempInt,Transaction.Diagnostic.Request.DATA[8],2)MOV(10,Transaction.Diagnostic.Request.LEN);]]>
</Text>
</Rung>
<Rung Number="10" Type="N">
<Comment>
<![CDATA[Add a reference count next for transactions requiring them.  This includes all multiple reads and writes.  Singles get filled in in subsequent rungs.]]>
</Comment>
<Text>
<![CDATA[[GEQ(Transaction.TransType,1) LEQ(Transaction.TransType,4) ,EQU(Transaction.TransType,15) ,EQU(Transaction.TransType,16) ]SWPB(Transaction.Count,REVERSE,Wrk_TempInt)COP(Wrk_TempInt,Transaction.Diagnostic.Request.DATA[Transaction.Diagnostic.Request.LEN],2)ADD(2,Transaction.Diagnostic.Request.LEN,Transaction.Diagnostic.Request.LEN);]]>
</Text>
</Rung>
<Rung Number="11" Type="N">
<Comment>
<![CDATA[Write Single Coil gets a value of either 0x0000 or 0xFF00
We are writing 00FF to avoid using SWPB instruction here]]>
</Comment>
<Text>
<![CDATA[EQU(Transaction.TransType,5)[XIO(ModbusData.Coils_0xxx[Transaction.LocalAddress]) CLR(Wrk_TempInt) ,XIC(ModbusData.Coils_0xxx[Transaction.LocalAddress]) MOV(16#00ff,Wrk_TempInt) ]COP(Wrk_TempInt,Transaction.Diagnostic.Request.DATA[Transaction.Diagnostic.Request.LEN],2)ADD(2,Transaction.Diagnostic.Request.LEN,Transaction.Diagnostic.Request.LEN);]]>
</Text>
</Rung>
<Rung Number="12" Type="N">
<Comment>
<![CDATA[Write Single Register Puts the SingleValue next]]>
</Comment>
<Text>
<![CDATA[EQU(Transaction.TransType,6)SWPB(ModbusData.HoldRegisters_4xxx[Transaction.LocalAddress],REVERSE,Wrk_TempInt)COP(Wrk_TempInt,Transaction.Diagnostic.Request.DATA[Transaction.Diagnostic.Request.LEN],2)ADD(2,Transaction.Diagnostic.Request.LEN,Transaction.Diagnostic.Request.LEN);]]>
</Text>
</Rung>
<Rung Number="13" Type="N">
<Comment>
<![CDATA[Write Mult Registers
Add Register Data

The next two rungs add byte count for trans types of 15 and 16.

]]>
</Comment>
<Text>
<![CDATA[EQU(Transaction.TransType,15)[DIV(Transaction.Count,8,Wrk_TempInt) [CMP(Wrk_TempInt*8=Transaction.Count) ,CMP(Wrk_TempInt*8<>Transaction.Count) ADD(Wrk_TempInt,1,Wrk_TempInt) ] COP(Wrk_TempInt,Transaction.Diagnostic.Request.DATA[Transaction.Diagnostic.Request.LEN],1) ADD(1,Transaction.Diagnostic.Request.LEN,Transaction.Diagnostic.Request.LEN) ,CLR(Wrk_Bit) CLR(Wrk_Byte) MOV(Wrk_TempInt,Wrk_TempASCII_462.LEN) CLR(Wrk_TempASCII_462.DATA[0]) ,MOV(Transaction.LocalAddress,Wrk_Index) SUB(Transaction.Count,1,Wrk_TempInt) ADD(Wrk_TempInt,Transaction.LocalAddress,Wrk_LastAddr) ];]]>
</Text>
</Rung>
<Rung Number="14" Type="N">
<Text>
<![CDATA[LBL(CMD15)EQU(Transaction.TransType,15)[XIC(ModbusData.Coils_0xxx[Wrk_Index]) OTE(Wrk_TempASCII_462.DATA[Wrk_Byte].[Wrk_Bit]) ,ADD(Wrk_Bit,1,Wrk_Bit) GRT(Wrk_Bit,7) CLR(Wrk_Bit) ADD(Wrk_Byte,1,Wrk_Byte) CLR(Wrk_TempASCII_462.DATA[Wrk_Byte]) ,LES(Wrk_Index,Wrk_LastAddr) ADD(Wrk_Index,1,Wrk_Index) JMP(CMD15) ];]]>
</Text>
</Rung>
<Rung Number="15" Type="N">
<Text>
<![CDATA[EQU(Transaction.TransType,15)CONCAT(Transaction.Diagnostic.Request,Wrk_TempASCII_462,Transaction.Diagnostic.Request);]]>
</Text>
</Rung>
<Rung Number="16" Type="N">
<Text>
<![CDATA[EQU(Transaction.TransType,16)[MUL(Transaction.Count,2,Wrk_TempInt) COP(Wrk_TempInt,Transaction.Diagnostic.Request.DATA[Transaction.Diagnostic.Request.LEN],1) ADD(1,Transaction.Diagnostic.Request.LEN,Transaction.Diagnostic.Request.LEN) ,MOV(Transaction.LocalAddress,Wrk_Index) SUB(Transaction.Count,1,Wrk_TempInt) ADD(Wrk_TempInt,Transaction.LocalAddress,Wrk_LastAddr) ];]]>
</Text>
</Rung>
<Rung Number="17" Type="N">
<Text>
<![CDATA[LBL(CMD16)EQU(Transaction.TransType,16)SWPB(ModbusData.HoldRegisters_4xxx[Wrk_Index],REVERSE,Wrk_TempInt)COP(Wrk_TempInt,Transaction.Diagnostic.Request.DATA[Transaction.Diagnostic.Request.LEN],2)ADD(2,Transaction.Diagnostic.Request.LEN,Transaction.Diagnostic.Request.LEN)LES(Wrk_Index,Wrk_LastAddr)ADD(Wrk_Index,1,Wrk_Index)JMP(CMD16);]]>
</Text>
</Rung>
<Rung Number="18" Type="N">
<Text>
<![CDATA[LBL(ExitLabel)NOP();]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="Prescan" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Text>
<![CDATA[CLR(Wrk_Bit)CLR(Wrk_Byte)CLR(Wrk_Index);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
</Routines>
</AddOnInstructionDefinition>
<AddOnInstructionDefinition Name="raC_Tec_NetModbusTCPClient_ChkWrReply" Revision="2.0" ExecutePrescan="true" ExecutePostscan="false" ExecuteEnableInFalse="false" CreatedDate="2019-12-09T13:02:33.945Z" CreatedBy="Not Available" EditedDate="2020-02-04T13:58:02.801Z" EditedBy="Not Available" SoftwareRevision="v30.01">
