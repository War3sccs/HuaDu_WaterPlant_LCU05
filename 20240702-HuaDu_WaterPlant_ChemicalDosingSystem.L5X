<STContent>
<Line Number="0">
<![CDATA[(*数字泵运行状态*)]]>
</Line>
<Line Number="1">
<![CDATA[pump_run_status_indicate(pump_run_status_indicate_15,P_KMnO4_1_actuate,P_KMnO4_1_flow_read,P_KMnO4_1_run);]]>
