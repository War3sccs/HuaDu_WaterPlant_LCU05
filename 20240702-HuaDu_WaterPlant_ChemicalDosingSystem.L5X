<AddOnInstructionDefinition Name="raC_Tec_NetModbusTCPClient_BuildReqStr" Revision="2.1" ExecutePrescan="true" ExecutePostscan="false" ExecuteEnableInFalse="false" CreatedDate="2019-12-06T19:33:01.433Z" CreatedBy="Not Available" EditedDate="2022-09-14T17:18:17.355Z" EditedBy="Not Available" SoftwareRevision="v31.02">
<Description>
<![CDATA[This routine builds a request string.]]>
</Description>
<RevisionNote>
<![CDATA[Moved to DINT in BeginAddress with boundary enforcement]]>
</RevisionNote>
<Parameters>
