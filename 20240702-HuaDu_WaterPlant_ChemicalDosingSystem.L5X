</Line>
<Line Number="43">
<![CDATA[SCL_LP1010_AO_3.In:=flow_calculate_PAC_3;]]>
</Line>
<Line Number="44">
<![CDATA[]]>
</Line>
<Line Number="45">
<![CDATA[(*4#数字泵流量计算*)]]>
</Line>
<Line Number="46">
<![CDATA[(*计算流量*)]]>
</Line>
<Line Number="47">
<![CDATA[dosing_flow_setting(]]>
</Line>
<Line Number="48">
<![CDATA[    dosing_flow_setting_4,]]>
</Line>
<Line Number="49">
<![CDATA[    PAC_control_auto_manual,(*控制状态：手动-0，自动-1*)]]>
</Line>
<Line Number="50">
<![CDATA[    PAC_dosing_mg_L_mixing_tank_2,(*PAC溶液投加率，原设计最大60mg/L*)]]>
</Line>
<Line Number="51">
<![CDATA[    P_PAC4_flow_set,(*手动控制状态时，手动指定的投加流量L/h*)]]>
</Line>
<Line Number="52">
<![CDATA[    source_water_flow,(*源水流量m3/h*)]]>
</Line>
<Line Number="53">
<![CDATA[    flow_calculate_PAC_4,(*计算出来的投加量：手动时手动指定，自动时由计算得出*)]]>
</Line>
<Line Number="54">
<![CDATA[    0.98 (*PAC纯度，按98%计算*)]]>
</Line>
<Line Number="55">
<![CDATA[    );]]>
</Line>
<Line Number="56">
<![CDATA[(*AO模块4-20mA输出*)]]>
</Line>
<Line Number="57">
<![CDATA[SCL(SCL_LP1010_AO_4);]]>
</Line>
<Line Number="58">
<![CDATA[SCL_LP1010_AO_4.In:=flow_calculate_PAC_4;]]>
</Line>
<Line Number="59">
<![CDATA[]]>
</Line>
<Line Number="60">
<![CDATA[]]>
</Line>
<Line Number="61">
<![CDATA[]]>
</Line>
<Line Number="62">
<![CDATA[]]>
</Line>
</STContent>
</Routine>
<Routine Name="MainRoutine" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[设置PAC系统4-20mA输入输出参数。]]>
</Comment>
<Text>
<![CDATA[JSR(analog_IO_setting_PAC,0);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[将I/O输入的数值，同步到系统变量，方便触摸屏及上位机读取]]>
</Comment>
<Text>
<![CDATA[JSR(synchronize_PAC,0);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[将4个PAC池当前液位，与液位过高报警值、液位过低报警值对照，如果液位过高、过低，则发出报警。
如果液位过高，则自动关闭进液阀。如果液位过低，则自动关闭出液位。]]>
</Comment>
<Text>
<![CDATA[JSR(tank_control_PAC,0);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[数字泵的启动/停止控制]]>
</Comment>
<Text>
<![CDATA[JSR(pump_action_PAC,0);]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Comment>
<![CDATA[计算各数字泵投加流量，并传到相关AO模块输出。]]>
</Comment>
<Text>
<![CDATA[JSR(dosing_flow_set_PAC,0);]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Comment>
<![CDATA[阀门动作控制]]>
</Comment>
<Text>
<![CDATA[JSR(valve_action_PAC,0);]]>
</Text>
</Rung>
<Rung Number="6" Type="N">
<Comment>
<![CDATA[将计算得出的数字泵流量设置值传送到AO模块]]>
</Comment>
<Text>
<![CDATA[MOV(SCL_LP1010_AO_1.Out,RemoteIO1:4:O.Ch0Data)MOV(SCL_LP1010_AO_2.Out,RemoteIO1:4:O.Ch1Data)MOV(SCL_LP1010_AO_3.Out,RemoteIO1:4:O.Ch2Data)MOV(SCL_LP1010_AO_4.Out,RemoteIO1:4:O.Ch3Data);]]>
</Text>
</Rung>
<Rung Number="7" Type="N">
<Comment>
<![CDATA[搅拌机控制程序]]>
</Comment>
<Text>
<![CDATA[JSR(mixer_action_PAC,0);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="mixer_action_PAC" Type="RLL">
<Description>
<![CDATA[搅拌机启动/停止]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Text>
<![CDATA[XIC(MI_PAC1_actuate)OTE(RemoteIO1:2:O.Data.0);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Text>
<![CDATA[XIC(MI_PAC2_actuate)OTE(RemoteIO1:2:O.Data.1);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Text>
<![CDATA[XIC(MI_PAC3_actuate)OTE(RemoteIO1:2:O.Data.2);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Text>
<![CDATA[XIC(MI_PAC4_actuate)OTE(RemoteIO1:2:O.Data.3);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="pump_action_PAC" Type="RLL">
<Description>
<![CDATA[控制数字泵的启动/停止]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[1#数字泵控制]]>
</Comment>
<Text>
<![CDATA[pump_start_stop_PAC(PAC_pump_action_1,VE_PAC_11_open,VE_PAC_07_open,VE_PAC_08_open,VE_PAC_09_open,VE_PAC_10_open,VE_PAC_01_open,P_PAC1_actuate,RemoteIO1:2:O.Data.4,RemoteIO1:2:O.Data.8);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[2#数字泵控制]]>
</Comment>
<Text>
<![CDATA[pump_start_stop_PAC(PAC_pump_action_2,VE_PAC_11_open,VE_PAC_07_open,VE_PAC_08_open,VE_PAC_09_open,VE_PAC_10_open,VE_PAC_02_open,P_PAC2_actuate,RemoteIO1:2:O.Data.5,RemoteIO1:2:O.Data.9);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[3#数字泵控制]]>
</Comment>
<Text>
<![CDATA[pump_start_stop_PAC(PAC_pump_action_3,VE_PAC_11_open,VE_PAC_07_open,VE_PAC_08_open,VE_PAC_09_open,VE_PAC_10_open,VE_PAC_03_open,P_PAC3_actuate,RemoteIO1:2:O.Data.6,RemoteIO1:2:O.Data.10);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[4#数字泵控制]]>
</Comment>
<Text>
<![CDATA[pump_start_stop_PAC(PAC_pump_action_4,VE_PAC_11_open,VE_PAC_07_open,VE_PAC_08_open,VE_PAC_09_open,VE_PAC_10_open,VE_PAC_04_open,P_PAC4_actuate,RemoteIO1:2:O.Data.7,RemoteIO1:2:O.Data.11);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="synchronize_PAC" Type="ST">
<Description>
<![CDATA[同步I/O输入的数值。]]>
</Description>
<STContent>
<Line Number="0">
<![CDATA[(*搅拌机运行状态*)]]>
</Line>
<Line Number="1">
<![CDATA[MI_PAC1_run:=RemoteIO1:0:I.Data.0;]]>
</Line>
<Line Number="2">
<![CDATA[MI_PAC2_run:=RemoteIO1:0:I.Data.1;]]>
</Line>
<Line Number="3">
<![CDATA[MI_PAC3_run:=RemoteIO1:0:I.Data.2;]]>
</Line>
<Line Number="4">
<![CDATA[MI_PAC4_run:=RemoteIO1:0:I.Data.3;]]>
</Line>
<Line Number="5">
<![CDATA[(*数字泵运行状态*)]]>
</Line>
<Line Number="6">
<![CDATA[pump_run_status_indicate(pump_run_status_indicate_1,P_PAC1_actuate,P_PAC1_flow_read,P_PAC1_run);]]>
</Line>
<Line Number="7">
<![CDATA[pump_run_status_indicate(pump_run_status_indicate_2,P_PAC2_actuate,P_PAC2_flow_read,P_PAC2_run);]]>
