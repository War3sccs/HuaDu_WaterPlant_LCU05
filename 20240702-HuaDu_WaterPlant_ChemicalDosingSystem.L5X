<Routines>
<Routine Name="Logic" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Called from Packet_Processing to parse register data and write it to the local arrays .

First Check the range of registers to make sure we're within specified limits.
Length is limited to 120]]>
</Comment>
<Text>
<![CDATA[NOP();]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Text>
<![CDATA[LES(Modbus_CMD_Len,1)GRT(Modbus_CMD_Len,120)JMP(end1);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Set up values for the _Sub_4x_WR routine.  Starting position and length.
]]>
</Comment>
<Text>
<![CDATA[MOV(2,Wrk_StringPosition)SUB(Modbus_CMD_Len,1,Wrk_Cmd_Last)ADD(Wrk_Cmd_Last,LocalOffset,Wrk_Cmd_Last)MOV(LocalOffset,Wrk_Index);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Text>
<![CDATA[LBL(Loop)COP(CommandString.DATA[Wrk_StringPosition],Wrk_Temp_Int,1)[XIO(Reg3xx) SWPB(Wrk_Temp_Int,REVERSE,ModbusData.HoldRegisters_4xxx[Wrk_Index]) ,XIC(Reg3xx) SWPB(Wrk_Temp_Int,REVERSE,ModbusData.InpRegisters_3xxx[Wrk_Index]) ]ADD(Wrk_StringPosition,2,Wrk_StringPosition);]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Text>
<![CDATA[LES(Wrk_Index,Wrk_Cmd_Last)ADD(Wrk_Index,1,Wrk_Index)JMP(Loop);]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Text>
<![CDATA[LBL(end1)NOP();]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="Prescan" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Text>
<![CDATA[CLR(Wrk_Index);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
</Routines>
</AddOnInstructionDefinition>
