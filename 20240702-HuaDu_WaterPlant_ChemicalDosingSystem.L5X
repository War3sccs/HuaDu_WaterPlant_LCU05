<Text>
<![CDATA[EQU(Wrk_MSGStep,440)XIC(Wrk_WriteNow[Wrk_WrIndex])XIO(Ref_MsgWrite.EN)XIO(Ref_MsgRead.EN)[MOV(20,Wrk_TempDINT) COP(Wrk_TempDINT,Ref_Connection.MSG_Src[0],4) FLL(0,Ref_Connection.MSG_Src[4],8) ,COP(Ref_Transactions[Wrk_WrIndex].Diagnostic.Request.LEN,Ref_Connection.MSG_Src[12],4) COP(Ref_Transactions[Wrk_WrIndex].Diagnostic.Request.DATA[0],Ref_Connection.MSG_Src[16],Ref_Transactions[Wrk_WrIndex].Diagnostic.Request.LEN) ADD(Ref_Transactions[Wrk_WrIndex].Diagnostic.Request.LEN,16,Ref_MsgWrite.REQ_LEN) ,XIO(Ref_Transactions[Wrk_WrIndex].TransComplete) MOV(2,Ref_Transactions[Wrk_WrIndex].TransStat) [MOV(10,Ref_Transactions[Wrk_WrIndex].Diagnostic.NoReplyCounter.PRE) ,CTU(Ref_Transactions[Wrk_WrIndex].Diagnostic.NoReplyCounter,10,0) ] ,XIC(Ref_Transactions[Wrk_WrIndex].TransComplete) MOV(1,Ref_Transactions[Wrk_WrIndex].TransStat) ,OTU(Ref_Transactions[Wrk_WrIndex].TransComplete) OTU(Wrk_WriteNow[Wrk_WrIndex]) MOV(450,Wrk_MSGStep) ];]]>
