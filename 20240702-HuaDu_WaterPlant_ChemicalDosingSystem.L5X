<Routine Name="synchronize_NaClO" Type="ST">
<Description>
<![CDATA[同步I/O输入的数值。]]>
</Description>
<STContent>
<Line Number="0">
<![CDATA[(*数字泵运行状态*)]]>
</Line>
<Line Number="1">
<![CDATA[pump_run_status_indicate(pump_run_status_indicate_5,P_NaClO1_actuate,P_NaClO1_flow_read,P_NaClO1_run);]]>
</Line>
<Line Number="2">
<![CDATA[pump_run_status_indicate(pump_run_status_indicate_6,P_NaClO2_actuate,P_NaClO2_flow_read,P_NaClO2_run);]]>
