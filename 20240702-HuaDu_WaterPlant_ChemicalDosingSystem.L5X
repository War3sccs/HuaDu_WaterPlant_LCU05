<Routine Name="MainRoutine" Type="RLL">
<Description>
<![CDATA[主程序]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[设置KMnO4系统4-20mA输入输出参数。]]>
</Comment>
<Text>
<![CDATA[JSR(analog_IO_setting_KMnO4,0);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[将I/O输入的数值，同步到系统变量，方便触摸屏及上位机读取]]>
</Comment>
<Text>
<![CDATA[JSR(synchronize_KMnO4,0);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[数字泵的启动/停止控制]]>
</Comment>
<Text>
<![CDATA[JSR(pump_action_KMnO4,0);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[计算各数字泵投加流量，并传到相关AO模块输出。]]>
</Comment>
<Text>
<![CDATA[JSR(dosing_flow_set_KMnO4,0);]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Comment>
<![CDATA[阀门动作控制]]>
</Comment>
<Text>
<![CDATA[JSR(valve_action_KMnO4,0);]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Comment>
<![CDATA[将计算得出的数字泵流量设置值传送到AO模块]]>
</Comment>
<Text>
<![CDATA[MOV(SCL_LP1010_AO_13.Out,RemoteIO4:4:O.Ch0Data)MOV(SCL_LP1010_AO_14.Out,RemoteIO4:4:O.Ch1Data)MOV(SCL_LP1010_AO_15.Out,RemoteIO4:4:O.Ch2Data)MOV(SCL_LP1010_AO_16.Out,RemoteIO4:4:O.Ch3Data);]]>
</Text>
</Rung>
<Rung Number="6" Type="N">
<Comment>
<![CDATA[和其他PLC通讯]]>
</Comment>
<Text>
<![CDATA[JSR(communicate_KMnO4,0);]]>
</Text>
</Rung>
<Rung Number="7" Type="N">
<Text>
<![CDATA[JSR(real_translation,0);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="pump_action_KMnO4" Type="RLL">
<Description>
<![CDATA[控制数字泵的启动/停止]]>
</Description>
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[1#数字泵控制]]>
</Comment>
<Text>
<![CDATA[pump_start_stop_KMnO4(pump_action_KMnO4_1,KMnO4_level_low_alarm_1,VE_KMnO4_01_open,P_KMnO4_1_actuate,RemoteIO4:2:O.Data.0);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[2#数字泵控制]]>
</Comment>
<Text>
<![CDATA[pump_start_stop_KMnO4(pump_action_KMnO4_2,KMnO4_level_low_alarm_1,VE_KMnO4_02_open,P_KMnO4_2_actuate,RemoteIO4:2:O.Data.1);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[3#数字泵控制]]>
</Comment>
<Text>
<![CDATA[pump_start_stop_KMnO4(pump_action_KMnO4_3,KMnO4_level_low_alarm_2,VE_KMnO4_03_open,P_KMnO4_3_actuate,RemoteIO4:2:O.Data.2);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[4#数字泵控制]]>
</Comment>
<Text>
<![CDATA[pump_start_stop_KMnO4(pump_action_KMnO4_4,KMnO4_level_low_alarm_2,VE_KMnO4_04_open,P_KMnO4_4_actuate,RemoteIO4:2:O.Data.3);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
