<Routine Name="analog_IO_setting_PAC" Type="ST">
<Description>
<![CDATA[设备4-20mA输入输出参数。]]>
</Description>
<STContent>
<Line Number="0">
<![CDATA[(*4-20mA输入输出参数设置*)]]>
</Line>
<Line Number="1">
<![CDATA[(*通过内置函数SCL配置输入输出4-20mA数值*)]]>
</Line>
<Line Number="2">
<![CDATA[(*模拟量输出范围:4-20mA*)]]>
</Line>
<Line Number="3">
<![CDATA[]]>
</Line>
<Line Number="4">
<![CDATA[(*数字泵反馈流量*)]]>
</Line>
<Line Number="5">
<![CDATA[(*4-20mA读入参数设置*)]]>
</Line>
<Line Number="6">
<![CDATA[(*通过内置函数SCL读取4-20mA数值*)]]>
</Line>
<Line Number="7">
<![CDATA[(*数字泵流量范围0-1020L/h*)]]>
</Line>
<Line Number="8">
<![CDATA[(*4-20mA输入范围对应是0-30480*)]]>
</Line>
<Line Number="9">
<![CDATA[SCL_LP1010_AI_1.InEUMax:=1020.0;]]>
</Line>
<Line Number="10">
<![CDATA[SCL_LP1010_AI_1.InEUMin:=0.0;]]>
</Line>
<Line Number="11">
<![CDATA[SCL_LP1010_AI_1.InRawMax:=30840;]]>
</Line>
<Line Number="12">
<![CDATA[SCL_LP1010_AI_1.InRawMin:=0;]]>
</Line>
<Line Number="13">
<![CDATA[SCL_LP1010_AI_1.Limiting:=1;]]>
</Line>
<Line Number="14">
<![CDATA[]]>
</Line>
<Line Number="15">
<![CDATA[SCL_LP1010_AI_2.InEUMax:=1020.0;]]>
</Line>
<Line Number="16">
<![CDATA[SCL_LP1010_AI_2.InEUMin:=0.0;]]>
