</Line>
<Line Number="21">
<![CDATA[SCL_frequency_AI_3.InRawMin:=0;]]>
</Line>
<Line Number="22">
<![CDATA[]]>
</Line>
<Line Number="23">
<![CDATA[SCL_frequency_AI_4.InEUMax:=50.0;]]>
</Line>
<Line Number="24">
<![CDATA[SCL_frequency_AI_4.InEUMin:=0.0;]]>
</Line>
<Line Number="25">
