<Text>
<![CDATA[EQU(Wrk_MSGStep,520)XIO(Ref_MsgWrite.EN)XIO(Ref_MsgRead.EN)[MOV(50,Wrk_TempDINT) COP(Wrk_TempDINT,Ref_Connection.MSG_Src[0],4) FLL(0,Ref_Connection.MSG_Src[4],8) ,COP(Wrk_Instances[Wrk_RdWrIndex].WrString.LEN,Ref_Connection.MSG_Src[12],4) COP(Wrk_Instances[Wrk_RdWrIndex].WrString.DATA[0],Ref_Connection.MSG_Src[16],Wrk_Instances[Wrk_RdWrIndex].WrString.LEN) ADD(Wrk_Instances[Wrk_RdWrIndex].WrString.LEN,16,Ref_MsgWrite.REQ_LEN) ,MOV(Wrk_Instances[Wrk_RdWrIndex].Info.RWInstance,Ref_MsgWrite.Instance) OTU(Wrk_Instances[Wrk_RdWrIndex].WriteTrigger) MOV(530,Wrk_MSGStep) ];]]>
</Text>
</Rung>
<Rung Number="50" Type="N">
<Text>
<![CDATA[EQU(Wrk_MSGStep,530)[MOV(3000000,Ref_MsgWrite.UnconnectedTimeout) MSG(Ref_MsgWrite) ,XIC(Ref_MsgWrite.DN) MOV(540,Wrk_MSGStep) ,XIC(Ref_MsgWrite.ER) MOV(-2,Sts_LastError) MOV(940,Wrk_MSGStep) ];]]>
