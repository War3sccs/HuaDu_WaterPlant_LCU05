<Parameter Name="Sts_LastError" TagType="Base" DataType="DINT" Usage="Output" Radix="Decimal" Required="false" Visible="false" ExternalAccess="Read Only">
<Description>
<![CDATA[The last recorded socket error for this connection.  
0  good, 
-2- Write Error, 
-4 - Read Error,
-6 connection failed, -7 Delete all failed, -8 Create Soc failed, -9 Connection failed, -10 connection dropped, -11 error in setting socket parameter.
-12 - Enable removed
-15 - Max number of connected clients exceeded]]>
</Description>
