<Routines>
<Routine Name="Logic" Type="RLL">
<RLLContent>
<Labels>
<Label Name="end"/>
<Label Name="loop_inst"/>
</Labels>
<Rung Number="0" Type="N">
<Text>
<![CDATA[SIZE(Sockets,0,Wrk_Size)SUB(Wrk_Size,1,Wrk_LastElement)CLR(Wrk_InstIndex);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Text>
<![CDATA[LBL(loop_inst)EQU(Sockets[Wrk_InstIndex].Info.RWInstance,0)MOV(NewInstance,Sockets[Wrk_InstIndex].Info.RWInstance)BTD(NewAddress,0,Sockets[Wrk_InstIndex].Info.RemoteAddress[3],0,8)BTD(NewAddress,8,Sockets[Wrk_InstIndex].Info.RemoteAddress[2],0,8)BTD(NewAddress,16,Sockets[Wrk_InstIndex].Info.RemoteAddress[1],0,8)BTD(NewAddress,24,Sockets[Wrk_InstIndex].Info.RemoteAddress[0],0,8)OTL(Assigned)OTU(NoRoom)JMP(end);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Limit to Array Size]]>
</Comment>
<Text>
<![CDATA[LES(Wrk_InstIndex,Wrk_LastElement)ADD(Wrk_InstIndex,1,Wrk_InstIndex)JMP(loop_inst);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Text>
<![CDATA[OTL(NoRoom)OTU(Assigned);]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Text>
<![CDATA[LBL(end)NOP();]]>
</Text>
</Rung>
</RLLContent>
</Routine>
</Routines>
