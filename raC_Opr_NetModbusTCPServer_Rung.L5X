<Routines>
<Routine Name="Logic" Type="RLL">
<RLLContent>
<Labels>
<Label Name="Loop12"/>
<Label Name="Loop15"/>
</Labels>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[This routine unpacks the reply data for binary read operations and writes the data to the local arrays.

Check for a valid response length in bits.
Currently limited to 120, but can be increased]]>
</Comment>
<Text>
<![CDATA[NOP();]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Calculate boundaries, Size doe not work so hard coded 2047]]>
</Comment>
<Text>
<![CDATA[MOV(2047,Wrk_AddrLimit);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Return LEN string is always 2 characters]]>
</Comment>
<Text>
<![CDATA[MOV(2,Wrk_ret_len.LEN);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Text>
<![CDATA[GEQ(Modbus_CMD_Start,0)LEQ(Modbus_CMD_Start,Wrk_AddrLimit)OTE(Wrk_Valid_Start);]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Text>
<![CDATA[GEQ(Modbus_CMD_Len,1)LEQ(Modbus_CMD_Len,120)[EQU(Modbus_CMD,1) ,EQU(Modbus_CMD,2) ,EQU(Modbus_CMD,15) ]OTE(Wrk_Valid_Len);]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Text>
<![CDATA[[EQU(Modbus_CMD_Len,0) ,EQU(Modbus_CMD_Len,-256) ]EQU(Modbus_CMD,5)OTE(Wrk_Valid_Value_05);]]>
</Text>
</Rung>
<Rung Number="6" Type="N">
<Text>
<![CDATA[CPT(Wrk_CMD_END,Modbus_CMD_Start+Modbus_CMD_Len-1)LEQ(Wrk_CMD_END,Wrk_AddrLimit)OTE(Wrk_Valid_End);]]>
</Text>
</Rung>
<Rung Number="7" Type="N">
<Text>
<![CDATA[XIC(Wrk_Valid_Start)XIC(Wrk_Valid_Len)XIC(Wrk_Valid_End)[EQU(Modbus_CMD,1) OTE(Wrk_Valid_CMD1) ,EQU(Modbus_CMD,2) OTE(Wrk_Valid_CMD2) ,EQU(Modbus_CMD,15) OTE(Wrk_Valid_CMD15) ];]]>
</Text>
</Rung>
<Rung Number="8" Type="N">
<Text>
<![CDATA[XIC(Wrk_Valid_Start)XIC(Wrk_Valid_Value_05)EQU(Modbus_CMD,5)OTE(Wrk_Valid_CMD5);]]>
</Text>
</Rung>
<Rung Number="9" Type="N">
<Text>
<![CDATA[[XIC(Wrk_Valid_CMD1) ,XIC(Wrk_Valid_CMD2) ]MOV(Modbus_CMD_Start,Wrk_MbBitIndex);]]>
</Text>
</Rung>
<Rung Number="10" Type="N">
<Text>
<![CDATA[[XIC(Wrk_Valid_CMD1) ,XIC(Wrk_Valid_CMD2) ][CPT(Wrk_Byte_Count,(Modbus_CMD_Len-1)/8+1) MOV(Wrk_Byte_Count,ResponseString.DATA[0]) MOV(1,Wrk_ret_CMD.LEN) BTD(Modbus_CMD,0,Wrk_ret_CMD.DATA[0],0,8) ,ADD(Wrk_Byte_Count,3,Wrk_TempInt) SWPB(Wrk_TempInt,REVERSE,Wrk_TempInt1) COP(Wrk_TempInt1,Wrk_ret_len.DATA[0],2) ];]]>
</Text>
</Rung>
<Rung Number="11" Type="N">
<Comment>
<![CDATA[Set up and call the _SUB_0x_WR function and call it to unpack the data and write it into the local data arrays at the LocalOffset specified in the transaction.
]]>
</Comment>
<Text>
<![CDATA[[XIC(Wrk_Valid_CMD1) ,XIC(Wrk_Valid_CMD2) ]MOV(2,ResponseString.LEN)MOV(1,Wrk_BufferByteIndex)MOV(0,Wrk_BufferBitIndex)MOV(Modbus_CMD_Len,Wrk_Cmd_Last)MOV(1,Wrk_Index);]]>
</Text>
</Rung>
<Rung Number="12" Type="N">
<Comment>
<![CDATA[Here is where the data is written locally.]]>
</Comment>
<Text>
<![CDATA[LBL(Loop12)[[XIC(Wrk_Valid_CMD1) XIC(ModbusData.Coils_0xxx[Wrk_MbBitIndex]) ,XIC(Wrk_Valid_CMD2) XIC(ModbusData.DiscInputs_1xxx[Wrk_MbBitIndex]) ] OTL(ResponseString.DATA[Wrk_BufferByteIndex].[Wrk_BufferBitIndex]) ,[XIC(Wrk_Valid_CMD1) XIO(ModbusData.Coils_0xxx[Wrk_MbBitIndex]) ,XIC(Wrk_Valid_CMD2) XIO(ModbusData.DiscInputs_1xxx[Wrk_MbBitIndex]) ] OTU(ResponseString.DATA[Wrk_BufferByteIndex].[Wrk_BufferBitIndex]) ];]]>
</Text>
</Rung>
<Rung Number="13" Type="N">
<Text>
<![CDATA[[XIC(Wrk_Valid_CMD1) ,XIC(Wrk_Valid_CMD2) ]LES(Wrk_Index,Wrk_Cmd_Last)[ADD(Wrk_BufferBitIndex,1,Wrk_BufferBitIndex) GRT(Wrk_BufferBitIndex,7) CLR(Wrk_BufferBitIndex) ADD(Wrk_BufferByteIndex,1,Wrk_BufferByteIndex) ADD(ResponseString.LEN,1,ResponseString.LEN) ,ADD(Wrk_MbBitIndex,1,Wrk_MbBitIndex) ADD(Wrk_Index,1,Wrk_Index) ]JMP(Loop12);]]>
</Text>
</Rung>
<Rung Number="14" Type="N">
<Text>
<![CDATA[XIC(Wrk_Valid_CMD5)MOV(Modbus_CMD_Start,Wrk_MbBitIndex5);]]>
</Text>
</Rung>
<Rung Number="15" Type="N">
<Text>
<![CDATA[XIC(Wrk_Valid_CMD5)[EQU(Modbus_CMD_Len,0) OTU(ModbusData.Coils_0xxx[Wrk_MbBitIndex5]) ,EQU(Modbus_CMD_Len,-256) OTL(ModbusData.Coils_0xxx[Wrk_MbBitIndex5]) ];]]>
</Text>
</Rung>
<Rung Number="16" Type="N">
<Text>
<![CDATA[XIC(Wrk_Valid_CMD15)MOV(Modbus_CMD_Start,Wrk_MbBitIndex15);]]>
</Text>
</Rung>
<Rung Number="17" Type="N">
<Text>
<![CDATA[XIC(Wrk_Valid_CMD15)MOV(6,Wrk_BufferByteIndex)MOV(0,Wrk_BufferBitIndex)MOV(Modbus_CMD_Len,Wrk_Cmd_Last)MOV(1,Wrk_Index);]]>
</Text>
</Rung>
<Rung Number="18" Type="N">
<Text>
<![CDATA[LBL(Loop15)XIC(Wrk_Valid_CMD15)[[XIC(CommandString.DATA[Wrk_BufferByteIndex].[Wrk_BufferBitIndex]) OTL(ModbusData.Coils_0xxx[Wrk_MbBitIndex15]) ,XIO(CommandString.DATA[Wrk_BufferByteIndex].[Wrk_BufferBitIndex]) OTU(ModbusData.Coils_0xxx[Wrk_MbBitIndex15]) ] ,LES(Wrk_Index,Wrk_Cmd_Last) [ADD(Wrk_MbBitIndex15,1,Wrk_MbBitIndex15) ADD(Wrk_BufferBitIndex,1,Wrk_BufferBitIndex) GRT(Wrk_BufferBitIndex,7) CLR(Wrk_BufferBitIndex) ADD(Wrk_BufferByteIndex,1,Wrk_BufferByteIndex) ,ADD(Wrk_Index,1,Wrk_Index) ] JMP(Loop15) ];]]>
</Text>
</Rung>
<Rung Number="19" Type="N">
<Text>
<![CDATA[[XIC(Wrk_Valid_CMD5) ,XIC(Wrk_Valid_CMD15) ]MOV(0,Wrk_ret_len.DATA[0])MOV(6,Wrk_ret_len.DATA[1])MID(CommandString,5,1,ResponseString)MOV(0,Wrk_ret_CMD.LEN);]]>
</Text>
</Rung>
<Rung Number="20" Type="N">
<Text>
<![CDATA[[EQU(Modbus_CMD,1) XIO(Wrk_Valid_CMD1) ,EQU(Modbus_CMD,2) XIO(Wrk_Valid_CMD2) ,EQU(Modbus_CMD,5) XIO(Wrk_Valid_CMD5) ,EQU(Modbus_CMD,15) XIO(Wrk_Valid_CMD15) ][MOV(1,Wrk_ret_CMD.LEN) OR(Modbus_CMD,16#80,Wrk_ret_CMD.DATA[0]) ,MOV(0,Wrk_ret_len.DATA[0]) MOV(3,Wrk_ret_len.DATA[1]) ,MOV(1,ResponseString.LEN) MOV(2,ResponseString.DATA[0]) ];]]>
</Text>
</Rung>
<Rung Number="21" Type="N">
<Text>
<![CDATA[[[EQU(Modbus_CMD,1) ,EQU(Modbus_CMD,2) ,EQU(Modbus_CMD,15) ] XIO(Wrk_Valid_Len) ,EQU(Modbus_CMD,5) XIO(Wrk_Valid_Value_05) ]MOV(1,ResponseString.LEN)MOV(3,ResponseString.DATA[0]);]]>
</Text>
</Rung>
<Rung Number="22" Type="N">
<Text>
<![CDATA[CONCAT(Wrk_ret_CMD,ResponseString,ResponseString)CONCAT(Wrk_ret_len,ResponseString,ResponseString);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="Prescan" Type="RLL">
<RLLContent>
<Labels/>
<Rung Number="0" Type="N">
<Text>
<![CDATA[CLR(Wrk_BufferByteIndex)CLR(Wrk_BufferBitIndex)CLR(Wrk_Index);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
</Routines>
