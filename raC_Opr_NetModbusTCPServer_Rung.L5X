<![CDATA[EQU(Wrk_MSGStep,700)RES(Wrk_StepLockTimer)[CMP(Wrk_RdWrIndex<(Wrk_InstSize-1)) OTE(Wrk_OkToIncement) ADD(Wrk_RdWrIndex,1,Wrk_RdWrIndex) ,XIO(Wrk_OkToIncement) CLR(Wrk_RdWrIndex) ,MOV(200,Wrk_MSGStep) ];]]>
