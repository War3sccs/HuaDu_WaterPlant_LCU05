<Routines>
<Routine Name="Logic" Type="RLL">
<RLLContent>
<Labels>
<Label Name="loop0x1x"/>
<Label Name="loop_instance"/>
<Label Name="loop_instance_HMI"/>
<Label Name="step320"/>
<Label Name="steplock"/>
</Labels>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Modbus Server Add-On Instruction.
Must use Rung Import]]>
</Comment>
<Text>
<![CDATA[NOP();]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Text>
<![CDATA[XIC(s:fs)OTU(Wrk_InitCompleted);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Text>
<![CDATA[XIO(Wrk_InitCompleted)CLR(Wrk_TransIndex)CLR(Wrk_WrIndex)CLR(Wrk_TimerIndex)CLR(Wrk_ClrReqIndex)CLR(Wrk_RdWrIndex)CLR(Wrk_MSGStep);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Text>
<![CDATA[XIO(Wrk_InitCompleted)GSV(ControllerDevice,,DeviceName,Wrk_Controller_Name[0])COP(Wrk_Controller_Name[1],Wrk_Controller_Type,1);]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Text>
<![CDATA[XIO(Wrk_InitCompleted)SIZE(Wrk_Instances,0,Wrk_InstSize)FLL(0,Wrk_Instances[0],Wrk_InstSize);]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Text>
<![CDATA[OTL(Wrk_InitCompleted);]]>
</Text>
</Rung>
<Rung Number="6" Type="N">
<Text>
<![CDATA[EQU(Wrk_MSGStep,0)MOV(5000,Wrk_RetryTimer.PRE)TON(Wrk_RetryTimer,?,?)XIC(Wrk_RetryTimer.DN)MOV(10,Wrk_MSGStep);]]>
</Text>
</Rung>
<Rung Number="7" Type="N">
<Comment>
<![CDATA[Constants for Sockets]]>
</Comment>
<Text>
<![CDATA[EQU(Wrk_MSGStep,10)MOV(1,Wrk_CreateReq.Type)MOV(2,Wrk_CreateReq.Family)BTD(Ref_Connection.LocalPort,0,Wrk_CreateReq.Port,0,16)MOV(15,Wrk_MSGStep);]]>
</Text>
</Rung>
<Rung Number="8" Type="N">
<Comment>
<![CDATA[Force Controller slot to 0 for 1769 and 5069 controllers]]>
</Comment>
<Text>
<![CDATA[EQU(Wrk_MSGStep,15)MOV(20,Wrk_MSGStep)[EQU(Wrk_Controller_Type,16#39363731) ,EQU(Wrk_Controller_Type,16#39363035) ]CLR(Ref_Connection.LocalSlot);]]>
</Text>
</Rung>
<Rung Number="9" Type="N">
<Comment>
<![CDATA[Parse Local IP String. - Steps 20-29
This is only needed for 5380/5480 with dual port mode.]]>
</Comment>
<Text>
<![CDATA[EQU(Wrk_MSGStep,20)COP(Ref_Connection.LocalAddress,Wrk_TempIPStr,1)FLL(0,Wrk_TempOctet[0],4)[MOV(21,Wrk_MSGStep) ,LES(Wrk_TempIPStr.LEN,7) MOV(29,Wrk_MSGStep) ];]]>
</Text>
</Rung>
<Rung Number="10" Type="N">
<Comment>
<![CDATA[Parse 1st octet]]>
</Comment>
<Text>
<![CDATA[EQU(Wrk_MSGStep,21)STOD(Wrk_TempIPStr,Wrk_TempOctet[3])DTOS(Wrk_TempOctet[3],Wrk_TempStrOctet)ADD(Wrk_TempStrOctet.LEN,1,Wrk_TempStrOctetlen)[LEQ(Wrk_TempIPStr.LEN,Wrk_TempStrOctetlen) MOV(29,Wrk_MSGStep) ,GRT(Wrk_TempIPStr.LEN,Wrk_TempStrOctetlen) DELETE(Wrk_TempIPStr,Wrk_TempStrOctetlen,1,Wrk_TempIPStr) MOV(22,Wrk_MSGStep) ];]]>
</Text>
</Rung>
<Rung Number="11" Type="N">
<Comment>
<![CDATA[Parse second octet]]>
</Comment>
<Text>
<![CDATA[EQU(Wrk_MSGStep,22)STOD(Wrk_TempIPStr,Wrk_TempOctet[2])DTOS(Wrk_TempOctet[2],Wrk_TempStrOctet)ADD(Wrk_TempStrOctet.LEN,1,Wrk_TempStrOctetlen)[LEQ(Wrk_TempIPStr.LEN,Wrk_TempStrOctetlen) MOV(29,Wrk_MSGStep) ,GRT(Wrk_TempIPStr.LEN,Wrk_TempStrOctetlen) DELETE(Wrk_TempIPStr,Wrk_TempStrOctetlen,1,Wrk_TempIPStr) MOV(23,Wrk_MSGStep) ];]]>
</Text>
</Rung>
<Rung Number="12" Type="N">
<Comment>
<![CDATA[Parse 3rd octet]]>
</Comment>
<Text>
