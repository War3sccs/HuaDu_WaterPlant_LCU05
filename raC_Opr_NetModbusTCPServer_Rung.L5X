<Routines>
<Routine Name="Logic" Type="RLL">
<RLLContent>
<Labels>
<Label Name="loop16"/>
<Label Name="Loop_3_4"/>
</Labels>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[This routing handles checking incoming request for proper values and building replies to register operations 3, 4, 6, 16

Check for a valid start address
For registers 0..1023]]>
</Comment>
<Text>
<![CDATA[NOP();]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Calculate Boundaries]]>
</Comment>
<Text>
<![CDATA[[EQU(Modbus_CMD,4) SIZE(ModbusData.InpRegisters_3xxx,0,Wrk_Size3x) SUB(Wrk_Size3x,1,Wrk_AddrLimit) ,[EQU(Modbus_CMD,3) ,EQU(Modbus_CMD,6) ,EQU(Modbus_CMD,16) ] SIZE(ModbusData.HoldRegisters_4xxx,0,Wrk_Size4x) SUB(Wrk_Size4x,1,Wrk_AddrLimit) ];]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Return LEN string is always 2 characters]]>
</Comment>
<Text>
<![CDATA[MOV(2,Wrk_ret_len.LEN);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Text>
<![CDATA[GEQ(Modbus_CMD_Start,0)LEQ(Modbus_CMD_Start,Wrk_AddrLimit)OTE(Wrk_Valid_Start);]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Text>
<![CDATA[GEQ(Modbus_CMD_Len,1)LEQ(Modbus_CMD_Len,120)OTE(Wrk_Valid_Len);]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Text>
<![CDATA[EQU(Modbus_CMD,16)AND(CommandString.DATA[5],255,Wrk_ByteCount)CMP(Modbus_CMD_Len*2=Wrk_ByteCount)OTE(Wrk_Valid_Len_16);]]>
</Text>
</Rung>
<Rung Number="6" Type="N">
<Text>
<![CDATA[CPT(Wrk_CMD_End,Modbus_CMD_Start+Modbus_CMD_Len-1)LEQ(Wrk_CMD_End,Wrk_AddrLimit)OTE(Wrk_Valid_end);]]>
</Text>
</Rung>
<Rung Number="7" Type="N">
<Text>
<![CDATA[XIC(Wrk_Valid_Start)XIC(Wrk_Valid_Len)XIC(Wrk_Valid_end)[EQU(Modbus_CMD,3) OTE(Wrk_Valid_CMD3) ,EQU(Modbus_CMD,4) OTE(Wrk_Valid_CMD4) ];]]>
</Text>
</Rung>
<Rung Number="8" Type="N">
<Text>
<![CDATA[XIC(Wrk_Valid_Start)XIC(Wrk_Valid_end)XIC(Wrk_Valid_Len_16)OTE(Wrk_Valid_CMD16);]]>
</Text>
</Rung>
<Rung Number="9" Type="N">
<Text>
<![CDATA[XIC(Wrk_Valid_Start)EQU(Modbus_CMD,6)OTE(Wrk_Valid_CMD6);]]>
</Text>
</Rung>
<Rung Number="10" Type="N">
<Text>
<![CDATA[[XIC(Wrk_Valid_CMD3) ,XIC(Wrk_Valid_CMD4) ]ADD(Modbus_CMD_Len,Modbus_CMD_Len,Wrk_TempByteLength)BTD(Wrk_TempByteLength,0,ResponseString.DATA[0],0,8)MOV(1,ResponseString.LEN)MOV(Modbus_CMD_Start,Wrk_Index)MOV(Wrk_CMD_End,Wrk_Cmd_Last);]]>
</Text>
</Rung>
<Rung Number="11" Type="N">
<Text>
<![CDATA[LBL(Loop_3_4)[XIC(Wrk_Valid_CMD3) SWPB(ModbusData.HoldRegisters_4xxx[Wrk_Index],REVERSE,Wrk_TempInt) ,XIC(Wrk_Valid_CMD4) SWPB(ModbusData.InpRegisters_3xxx[Wrk_Index],REVERSE,Wrk_TempInt) ]COP(Wrk_TempInt,ResponseString.DATA[ResponseString.LEN],2)ADD(ResponseString.LEN,2,ResponseString.LEN);]]>
</Text>
</Rung>
<Rung Number="12" Type="N">
<Text>
<![CDATA[[XIC(Wrk_Valid_CMD3) ,XIC(Wrk_Valid_CMD4) ]LES(Wrk_Index,Wrk_Cmd_Last)ADD(Wrk_Index,1,Wrk_Index)JMP(Loop_3_4);]]>
</Text>
</Rung>
<Rung Number="13" Type="N">
<Text>
<![CDATA[[XIC(Wrk_Valid_CMD3) ,XIC(Wrk_Valid_CMD4) ]MOV(1,Wrk_ret_CMD.LEN)BTD(Modbus_CMD,0,Wrk_ret_CMD.DATA[0],0,8)ADD(Wrk_TempByteLength,3,Wrk_TempInt)SWPB(Wrk_TempInt,REVERSE,Wrk_TempInt)COP(Wrk_TempInt,Wrk_ret_len.DATA[0],2);]]>
</Text>
</Rung>
<Rung Number="14" Type="N">
<Text>
<![CDATA[XIC(Wrk_Valid_CMD6)COP(Modbus_CMD_Len,ModbusData.HoldRegisters_4xxx[Modbus_CMD_Start],1)MOV(6,Wrk_ret_len.DATA[1])MOV(0,Wrk_ret_len.DATA[0])MID(CommandString,5,1,ResponseString)MOV(0,Wrk_ret_CMD.LEN);]]>
</Text>
</Rung>
<Rung Number="15" Type="N">
<Text>
<![CDATA[XIC(Wrk_Valid_CMD16)MID(CommandString,5,1,ResponseString)MOV(6,Wrk_ret_len.DATA[1])MOV(0,Wrk_ret_len.DATA[0])MOV(0,Wrk_ret_CMD.LEN)MOV(6,Wrk_StrPos)MOV(Modbus_CMD_Start,Wrk_Index)MOV(Wrk_CMD_End,Wrk_Cmd_Last);]]>
</Text>
</Rung>
<Rung Number="16" Type="N">
<Text>
<![CDATA[LBL(loop16)XIC(Wrk_Valid_CMD16)[COP(CommandString.DATA[Wrk_StrPos],Wrk_TempInt,1) SWPB(Wrk_TempInt,REVERSE,ModbusData.HoldRegisters_4xxx[Wrk_Index]) ADD(Wrk_StrPos,2,Wrk_StrPos) ,LES(Wrk_Index,Wrk_Cmd_Last) ADD(Wrk_Index,1,Wrk_Index) JMP(loop16) ];]]>
</Text>
</Rung>
<Rung Number="17" Type="N">
<Text>
<![CDATA[[EQU(Modbus_CMD,3) XIO(Wrk_Valid_CMD3) ,EQU(Modbus_CMD,4) XIO(Wrk_Valid_CMD4) ,EQU(Modbus_CMD,6) XIO(Wrk_Valid_CMD6) ,EQU(Modbus_CMD,16) XIO(Wrk_Valid_CMD16) ][MOV(1,Wrk_ret_CMD.LEN) OR(Modbus_CMD,16#80,Wrk_ret_CMD.DATA[0]) ,MOV(0,Wrk_ret_len.DATA[0]) MOV(3,Wrk_ret_len.DATA[1]) ,MOV(1,ResponseString.LEN) MOV(2,ResponseString.DATA[0]) ];]]>
</Text>
</Rung>
<Rung Number="18" Type="N">
<Text>
<![CDATA[[[EQU(Modbus_CMD,3) ,EQU(Modbus_CMD,4) ] XIO(Wrk_Valid_Len) ,EQU(Modbus_CMD,16) XIO(Wrk_Valid_Len_16) ]MOV(1,ResponseString.LEN)MOV(3,ResponseString.DATA[0]);]]>
</Text>
</Rung>
<Rung Number="19" Type="N">
<Text>
<![CDATA[CONCAT(Wrk_ret_CMD,ResponseString,ResponseString)CONCAT(Wrk_ret_len,ResponseString,ResponseString);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
<Routine Name="Prescan" Type="RLL">
<RLLContent>
<Labels/>
<Rung Number="0" Type="N">
<Text>
<![CDATA[CLR(Wrk_Index);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
</Routines>
