<AddOnInstructionDefinition Name="raC_Opr_NetModbusTCPServer" Revision="2.4" RevisionExtension="0" Vendor="Rockwell Automation" ExecutePrescan="true" ExecutePostscan="false" ExecuteEnableInFalse="false" CreatedDate="2019-12-05T18:51:23.267Z" CreatedBy="Not Available" EditedDate="2022-09-14T17:13:48.586Z" EditedBy="Not Available"
 SoftwareRevision="v31.02">
<Description>
<![CDATA[Modbus TCP Server   ]]>
</Description>
<RevisionNote>
<![CDATA[2.0.0 Initial release in AOI format
2.0.1 Corrected local IP address logic
2.1.0 Corrected power-up and Redundancy anomalies
2.2.0 Force LocalSlot 0 for CompactLogix
2.3.0 Added incoming Client IP address reference tag and HMI structure
2.4.0 Improved malformed packet handling and reconnect]]>
</RevisionNote>
