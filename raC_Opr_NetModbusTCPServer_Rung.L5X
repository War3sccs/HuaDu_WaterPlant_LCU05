<![CDATA[LBL(step320)EQU(Wrk_MSGStep,320)[EQU(Wrk_Instances[Wrk_RdWrIndex].Info.RWInstance,0) [CMP(Wrk_RdWrIndex<(Wrk_InstSize-1)) OTE(Wrk_OkToIncement320) ADD(Wrk_RdWrIndex,1,Wrk_RdWrIndex) JMP(step320) ,XIO(Wrk_OkToIncement320) CLR(Wrk_RdWrIndex) RES(Wrk_StepLockTimer) MOV(200,Wrk_MSGStep) ] ,NEQ(Wrk_Instances[Wrk_RdWrIndex].Info.RWInstance,0) MOV(330,Wrk_MSGStep) ];]]>
