<![CDATA[EQU(Wrk_MSGStep,984)[XIC(Ref_MsgDelete.DN) ,XIC(Ref_MsgDelete.ER) ]NEQ(Wrk_BaseInstance,0)MOV(200,Wrk_MSGStep);]]>
