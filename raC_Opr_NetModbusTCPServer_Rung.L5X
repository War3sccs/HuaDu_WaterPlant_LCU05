<Comment>
<![CDATA[Finished packet processing 
]]>
</Comment>
<Text>
<![CDATA[EQU(Wrk_MSGStep,480)CONCAT(Wrk_ModbusID,Wrk_ModbusRespString,Wrk_ModbusRespString)INSERT(Wrk_ModbusRespString,Wrk_ModbusUnit,7,Wrk_ModbusRespString)COP(Wrk_ModbusRespString,Wrk_Instances[Wrk_RdWrIndex].WrString,1)MOV(490,Wrk_MSGStep);]]>
</Text>
</Rung>
