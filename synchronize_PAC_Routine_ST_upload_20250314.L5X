<LocalTags/>
<Routines>
<Routine Name="Logic" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Text>
<![CDATA[MOV(overtime_setting,timer.PRE);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Text>
<![CDATA[[XIC(valve_opening) ,XIC(valve_closing) ]TON(timer,?,?);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Text>
<![CDATA[XIC(timer.DN)OTE(action_overtime);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
</Routines>
